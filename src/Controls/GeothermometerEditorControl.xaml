<UserControl x:Class="GeoChemistryNexus.Controls.GeothermometerEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
             xmlns:panels="clr-namespace:GeoChemistryNexus.Controls.GeothermometerEditorPanels"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="1180"
             Background="#F5F5F7">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/GeoChemistryNexus;component/Themes/EditorStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 左侧栏 -->
        <Border Grid.Column="0" Grid.Row="0"
                Background="{StaticResource EditorSidebarBrush}"
                BorderBrush="{StaticResource EditorBorderBrushLight}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0,16,0,16">
                <StackPanel DockPanel.Dock="Top" Margin="12,0,12,20">
                    <TextBlock Text="{Binding EditorTitle}" FontSize="15" FontWeight="SemiBold"
                               Foreground="#1D1D1F" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="#86868B">
                        <Run Text="{Binding [geo_current_app_format_version], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay, FallbackValue=当前软件温压计版本}"/>
                        <Run Text=" "/>
                        <Run Text="{Binding AppFormatVersion, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top">
                    <RadioButton x:Name="NavBasic" Style="{StaticResource GeoTNavItemStyle}" IsChecked="True"
                                 Checked="NavSection_Checked" Tag="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [geo_step_basic], Source={x:Static lg:LanguageService.Instance}, FallbackValue=基本信息}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavScript" Style="{StaticResource GeoTNavItemStyle}"
                                 Checked="NavSection_Checked" Tag="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [geo_step_script], Source={x:Static lg:LanguageService.Instance}, FallbackValue=公式脚本}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavHelp" Style="{StaticResource GeoTNavItemStyle}"
                                 Checked="NavSection_Checked" Tag="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE736;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [geo_step_help_doc], Source={x:Static lg:LanguageService.Instance}, FallbackValue=帮助文档}"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Column="1" Grid.Row="0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="16,16,16,16"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                            <Setter Property="Margin" Value="16,16,8,16"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 只读提示 -->
            <Border Grid.Row="0" Background="#FFF8E1" BorderBrush="#FFE082" BorderThickness="1" CornerRadius="6"
                    Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="#F9A825" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock FontSize="12" Foreground="#795548" VerticalAlignment="Center"
                               Text="{Binding [geo_editor_readonly_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=官方温压计的基本信息、公式脚本和帮助文档仅可查看与复制，不可修改。}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <!-- 基本信息：可滚动 -->
                <hc:ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <hc:ScrollViewer.Style>
                        <Style TargetType="hc:ScrollViewer" BasedOn="{StaticResource {x:Type hc:ScrollViewer}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </hc:ScrollViewer.Style>
                    <panels:GeoTBasicInfoPanel x:Name="BasicPanel" DataContext="{Binding}"/>
                </hc:ScrollViewer>

                <!-- 公式脚本：占满高度 -->
                <panels:GeoTScriptPanel x:Name="ScriptPanel" DataContext="{Binding}">
                    <panels:GeoTScriptPanel.Style>
                        <Style TargetType="panels:GeoTScriptPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </panels:GeoTScriptPanel.Style>
                </panels:GeoTScriptPanel>

                <!-- 帮助文档：占满高度 -->
                <panels:GeoTHelpDocPanel x:Name="HelpPanel" DataContext="{Binding}">
                    <panels:GeoTHelpDocPanel.Style>
                        <Style TargetType="panels:GeoTHelpDocPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </panels:GeoTHelpDocPanel.Style>
                </panels:GeoTHelpDocPanel>
            </Grid>
        </Grid>

        <!-- 右侧预览（仅基本信息页显示） -->
        <panels:GeoTPreviewPanel Grid.Column="2" Grid.Row="0" DataContext="{Binding}" Width="280">
            <panels:GeoTPreviewPanel.Style>
                <Style TargetType="panels:GeoTPreviewPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </panels:GeoTPreviewPanel.Style>
        </panels:GeoTPreviewPanel>

        <!-- 底部操作栏 -->
        <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1"
                Background="White" BorderBrush="{StaticResource EditorBorderBrushLight}" BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Button HorizontalAlignment="Left"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource GeoTFooterButtonStyle}"
                        Background="White" BorderBrush="#D0D0D0" BorderThickness="1">
                    <TextBlock Text="{Binding [Cancel], Source={x:Static lg:LanguageService.Instance}, FallbackValue=取消}"/>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding SaveAndExportCommand}" Margin="0,0,8,0"
                            Style="{StaticResource GeoTFooterButtonStyle}"
                            Background="White" BorderBrush="#D0D0D0" BorderThickness="1"
                            Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityReConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE78C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding [geo_btn_save_export_zip], Source={x:Static lg:LanguageService.Instance}, FallbackValue=保存并导出 ZIP}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource GeoTFooterButtonStyle}"
                            Background="{StaticResource EditorPrimaryBrush}"
                            Foreground="White" BorderThickness="0"
                            Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityReConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding [geo_btn_save], Source={x:Static lg:LanguageService.Instance}, FallbackValue=保存}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
