<UserControl x:Class="GeoChemistryNexus.Controls.DiagramPlotEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:vm="clr-namespace:GeoChemistryNexus.ViewModels"
             xmlns:local="clr-namespace:GeoChemistryNexus.Controls"
             xmlns:cvs="clr-namespace:GeoChemistryNexus.Converter"
             x:Name="RootEditorControl"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1000"
             Background="#F5F5F7">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E8F2FC"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushLight" Color="#E5E5EA"/>
        <SolidColorBrush x:Key="ModernPrimaryBrush" Color="#007AFF"/>
        <SolidColorBrush x:Key="ModernPrimarySoftBrush" Color="#EAF3FF"/>
        <SolidColorBrush x:Key="ModernCardBorderBrush" Color="#E5E5EA"/>
        <SolidColorBrush x:Key="ModernSelectedCardBorderBrush" Color="#0A84FF"/>
        <SolidColorBrush x:Key="ModernSelectedCardBackgroundBrush" Color="#F3F8FF"/>
        <SolidColorBrush x:Key="ModernTextPrimaryBrush" Color="#1D1D1F"/>
        <SolidColorBrush x:Key="ModernTextSecondaryBrush" Color="#86868B"/>

        <!-- 覆盖 ComboBoxExtend 中带 ItemsControl 祖先绑定的 ComboBoxItem，避免下拉关闭后绑定报错 -->
        <Style x:Key="DiagramEditorComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F2F2F7"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource ModernPrimarySoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiagramEditorComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ComboBoxExtend}">
            <Setter Property="ItemContainerStyle" Value="{StaticResource DiagramEditorComboBoxItemStyle}"/>
        </Style>

        <cvs:GraphMapPathToIconConverter x:Key="GraphMapPathToIconConverter"/>

        <Style x:Key="CategoryPreviewTreeViewItemStyle" BasedOn="{StaticResource ModernStyleTreeViewItemStyle}" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
        </Style>

        <Style x:Key="TranslationDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEEEEE"/>
        </Style>

        <Style x:Key="TranslationDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Top"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource ModernPrimarySoftBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource ModernTextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlotTypeListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#3C3C43"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="EditorNav"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="8" Margin="8,2">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F2F2F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#86868B"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PanelControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                                <Setter Property="Foreground" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D4D4D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TokenBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#EBF3FF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="CategoryTokenStyle" TargetType="Border" BasedOn="{StaticResource TokenBorderStyle}">
            <Setter Property="Background" Value="#FFF4EB"/>
        </Style>

        <Style x:Key="TokenLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="LineHeight" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,1,0,1"/>
        </Style>

        <Style x:Key="TokenCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseBd" Background="{TemplateBinding Background}" CornerRadius="7">
                            <TextBlock Text="✕" FontSize="9" FontWeight="Bold"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseBd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategorySelectButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource ModernCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource ModernTextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F2F2F7"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C7C7CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E5EA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HelpFormatButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F2F2F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HelpFormatToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F2F2F7"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8F2FC"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrushLight}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0,16,0,16">
                <StackPanel DockPanel.Dock="Top" Margin="12,0,12,20">
                    <TextBlock Text="{Binding WindowTitle}" FontSize="15" FontWeight="SemiBold" Foreground="#1D1D1F" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="#86868B">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} {1}">
                                <Binding Source="{x:Static lg:LanguageService.Instance}" Path="[current_diagram_version]" Mode="OneWay"/>
                                <Binding Path="SidebarVersionText" Mode="OneWay"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top">
                    <RadioButton x:Name="NavBasic" Style="{StaticResource NavItemStyle}" IsChecked="True"
                                 Checked="NavSection_Checked" Tag="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [diagram_editor_basic_settings], Source={x:Static lg:LanguageService.Instance}, TargetNullValue='基本设置'}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavTranslation" Style="{StaticResource NavItemStyle}"
                                 Checked="NavSection_Checked" Tag="1"
                                 IsEnabled="{Binding IsTranslationSectionEnabled}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🌐" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [diagram_editor_content_translation], Source={x:Static lg:LanguageService.Instance}, TargetNullValue='内容翻译'}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavScript" Style="{StaticResource NavItemStyle}"
                                 Checked="NavSection_Checked" Tag="2"
                                 IsEnabled="{Binding IsScriptSectionEnabled}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📜" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [script_definition], Source={x:Static lg:LanguageService.Instance}, TargetNullValue='图解脚本'}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavHelp" Style="{StaticResource NavItemStyle}"
                                 Checked="NavSection_Checked" Tag="3"
                                 IsEnabled="{Binding IsHelpSectionEnabled}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [geo_step_help_doc], Source={x:Static lg:LanguageService.Instance}, TargetNullValue='帮助文档'}"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Basic settings -->
            <ScrollViewer x:Name="BasicPanel" VerticalScrollBarVisibility="Auto" Padding="28,24">
                <StackPanel MaxWidth="720">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"
                               Text="{Binding [diagram_editor_basic_settings], Source={x:Static lg:LanguageService.Instance}, TargetNullValue='基本设置'}"/>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="{Binding [geo_field_version], Source={x:Static lg:LanguageService.Instance}, FallbackValue=版本}"
                                           FontWeight="SemiBold"/>

                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Margin="12,0,8,0"
                                           FontSize="12"
                                           Foreground="#86868B"
                                           Text="{Binding VersionSectionCollapsedSummary, Mode=OneWay}"
                                           Visibility="{Binding IsVersionSectionExpanded, Converter={StaticResource BooleanToVisibilityReConverter}}"/>

                                <Button Grid.Column="2"
                                        Style="{StaticResource PanelControlButtonStyle}"
                                        Command="{Binding ToggleVersionSectionCommand}"
                                        ToolTip="{Binding [cipw_tooltip_expand], Source={x:Static lg:LanguageService.Instance}, FallbackValue=展开/收缩}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xE70E;"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVersionSectionExpanded}" Value="True">
                                                        <Setter Property="Text" Value="&#xE70D;"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </Grid>

                            <Grid Margin="0,10,0,0"
                                  Visibility="{Binding IsVersionSectionExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock FontSize="12"
                                               Foreground="#86868B"
                                               Margin="0,0,0,4"
                                               Text="{Binding [current_diagram_version], Source={x:Static lg:LanguageService.Instance}, FallbackValue=当前图解版本}"/>
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#1D1D1F"
                                               Text="{Binding OriginalTemplateVersion, Mode=OneWay}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="12"
                                               Foreground="#86868B"
                                               Margin="0,0,0,4"
                                               Text="{Binding [diagram_editor_new_version], Source={x:Static lg:LanguageService.Instance}, FallbackValue=新版本}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0"
                                                   Foreground="#666"
                                                   FontSize="13"
                                                   Text="{Binding FormatVersionPrefix, Mode=OneWay}"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding PatchVersion, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalAlignment="Center"
                                                 Padding="8,6"
                                                 FontSize="13"
                                                 ToolTip="{Binding [geo_tooltip_version_patch], Source={x:Static lg:LanguageService.Instance}, FallbackValue=修订号 z；格式基线 x.y 跟随程序版本}"/>
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   FontSize="12"
                                                   Foreground="#86868B">
                                            <Run Text="{Binding [diagram_editor_saved_version], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay, FallbackValue=保存后版本：}"/>
                                            <Run Text="{Binding TemplateVersion, Mode=OneWay}" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding [enter_supported_languages], Source={x:Static lg:LanguageService.Instance}}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding LanguageParts}" Margin="0,0,0,0" ClipToBounds="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TokenBorderStyle}"
                                                Tag="{Binding DataContext, ElementName=RootEditorControl}">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{Binding [set_default_diagram_language], Source={x:Static lg:LanguageService.Instance}, FallbackValue='设为默认图解语言'}"
                                                              Command="{Binding PlacementTarget.Tag.SetDefaultLanguageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Style>
                                                            <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsDefault, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </MenuItem.Style>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="★" FontSize="9" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,4,0"
                                                           Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBlock Text="{Binding DisplayText}" Style="{StaticResource TokenLabelStyle}" Foreground="#0078D4"/>
                                                <Button Tag="{Binding}" Click="RemoveLanguage_Click"
                                                        Style="{StaticResource TokenCloseButtonStyle}" Foreground="#0078D4"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <hc:ComboBox x:Name="LanguageCombo"
                                             Grid.Column="0"
                                             IsEditable="True"
                                             IsTextSearchEnabled="False"
                                             StaysOpenOnEdit="True"
                                             hc:InfoElement.Placeholder="{Binding [enter_language_add], Source={x:Static lg:LanguageService.Instance}}"
                                             DisplayMemberPath="DisplayName"
                                             SelectedValuePath="Code"
                                             SelectionChanged="LanguageCombo_SelectionChanged"
                                             PreviewKeyDown="LanguageCombo_PreviewKeyDown"
                                             Style="{StaticResource DiagramEditorComboBoxStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding [enter_language_add], Source={x:Static lg:LanguageService.Instance}}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource ModernTextSecondaryBrush}"
                                           Margin="16,0,0,0"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding [enter_category_structure], Source={x:Static lg:LanguageService.Instance}}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="260"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <ItemsControl ItemsSource="{Binding CategoryParts}" Margin="0,0,0,0" ClipToBounds="False">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CategoryTokenStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource TokenLabelStyle}" Foreground="#FF6B00"/>
                                                        <Button Tag="{Binding}" Click="RemoveCategory_Click"
                                                                Style="{StaticResource TokenCloseButtonStyle}" Foreground="#FF6B00"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <hc:ComboBox x:Name="CategoryCombo"
                                                     Grid.Column="0"
                                                     IsEditable="True"
                                                     StaysOpenOnEdit="True"
                                                     hc:InfoElement.Placeholder="{Binding [enter_level_add], Source={x:Static lg:LanguageService.Instance}}"
                                                     DisplayMemberPath="DisplayName"
                                                     SelectedValuePath="DisplayName"
                                                     SelectionChanged="CategoryCombo_SelectionChanged"
                                                     PreviewKeyDown="CategoryCombo_PreviewKeyDown"
                                                     Style="{StaticResource DiagramEditorComboBoxStyle}"/>
                                        <Button Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource CategorySelectButtonStyle}"
                                                Click="SelectExistingCategoryStructure_Click"
                                                ToolTip="{Binding [select_existing_category_structure_tooltip], Source={x:Static lg:LanguageService.Instance}, FallbackValue='Select a category path from existing diagram templates.'}">
                                            <TextBlock Text="&#xe71b;"
                                                       FontFamily="pack://application:,,,/GeoChemistryNexus;component/Data/Icon/#iconfont"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="{Binding [enter_level_add], Source={x:Static lg:LanguageService.Instance}}"
                                               Foreground="{StaticResource ModernTextSecondaryBrush}"
                                               Margin="0,6,0,0"
                                               FontSize="13"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Border Grid.Column="2"
                                        Background="#FAFAFA"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource ModernCardBorderBrush}"
                                        BorderThickness="1"
                                        Padding="12"
                                        MinHeight="160">
                                    <StackPanel>
                                        <TextBlock Text="{Binding [category_structure_preview], Source={x:Static lg:LanguageService.Instance}, FallbackValue='Preview'}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="{StaticResource ModernTextPrimaryBrush}"
                                                   Margin="0,0,0,8"/>
                                        <TreeView ItemsSource="{Binding CategoryStructurePreviewRoot.Children}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  ItemContainerStyle="{StaticResource CategoryPreviewTreeViewItemStyle}"
                                                  Visibility="{Binding HasCategoryStructurePreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TreeView.ItemTemplate>
                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding GraphMapPath, Converter={StaticResource GraphMapPathToIconConverter}}"
                                                                   FontSize="14"
                                                                   Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </HierarchicalDataTemplate>
                                            </TreeView.ItemTemplate>
                                        </TreeView>
                                        <TextBlock Text="{Binding [category_structure_preview_empty], Source={x:Static lg:LanguageService.Instance}, FallbackValue='Add levels to preview the category hierarchy.'}"
                                                   Foreground="{StaticResource ModernTextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding HasCategoryStructurePreview, Converter={StaticResource BooleanToVisibilityReConverter}}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}"
                            Visibility="{Binding IsPlotTypeSelectionEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding [plot_type], Source={x:Static lg:LanguageService.Instance}}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <ListBox x:Name="PlotTypeList"
                                     ItemsSource="{Binding PlotTypeOptions}"
                                     SelectedValue="{Binding SelectedPlotType, Mode=TwoWay}"
                                     SelectedValuePath="Key"
                                     IsEnabled="{Binding IsPlotTypeSelectionEnabled}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ItemContainerStyle="{StaticResource PlotTypeListBoxItemStyle}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <primitives:UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="PlotTypeCard" Padding="18" CornerRadius="12"
                                                Background="White" BorderBrush="{StaticResource ModernCardBorderBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 选中勾标叠在图标角上，不占标题区域 -->
                                                <Grid Width="40" Height="40" Margin="0,0,14,0">
                                                    <Border x:Name="PlotTypeIcon" Width="40" Height="40" CornerRadius="10"
                                                            Background="#F2F4F7">
                                                        <TextBlock x:Name="PlotTypeBadgeText" Text="{Binding Badge}"
                                                                   FontSize="15" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource ModernTextPrimaryBrush}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Border x:Name="SelectionCheck" Width="18" Height="18" CornerRadius="9"
                                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                            Margin="0,0,-3,-3"
                                                            Background="{StaticResource ModernPrimaryBrush}"
                                                            BorderBrush="White" BorderThickness="1.5"
                                                            Visibility="Collapsed" Panel.ZIndex="1">
                                                        <TextBlock Text="✓" FontSize="10" FontWeight="Bold" Foreground="White"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Margin="0,-1,0,0"/>
                                                    </Border>
                                                </Grid>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock x:Name="PlotTypeTitle" Text="{Binding Title}"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{StaticResource ModernTextPrimaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock x:Name="PlotTypeDescription" Text="{Binding Description}"
                                                               Margin="0,6,0,0" FontSize="12"
                                                               Foreground="{StaticResource ModernTextSecondaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                <Setter TargetName="PlotTypeCard" Property="BorderBrush" Value="#C6DAFF"/>
                                                <Setter TargetName="PlotTypeCard" Property="Background" Value="#FAFCFF"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                <Setter TargetName="PlotTypeCard" Property="BorderBrush" Value="{StaticResource ModernSelectedCardBorderBrush}"/>
                                                <Setter TargetName="PlotTypeCard" Property="BorderThickness" Value="2"/>
                                                <Setter TargetName="PlotTypeCard" Property="Background" Value="{StaticResource ModernSelectedCardBackgroundBrush}"/>
                                                <Setter TargetName="PlotTypeIcon" Property="Background" Value="{StaticResource ModernPrimaryBrush}"/>
                                                <Setter TargetName="PlotTypeTitle" Property="Foreground" Value="{StaticResource ModernPrimaryBrush}"/>
                                                <Setter TargetName="PlotTypeBadgeText" Property="Foreground" Value="White"/>
                                                <Setter TargetName="SelectionCheck" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Translation -->
            <Grid x:Name="TranslationPanel" Visibility="Collapsed" Margin="20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleStyle}"
                           Text="{Binding [diagram_editor_content_translation], Source={x:Static lg:LanguageService.Instance}, TargetNullValue='内容翻译'}"/>
                <TextBlock Grid.Row="1" Style="{StaticResource SectionHintStyle}"
                           Text="{Binding [diagram_editor_translation_hint], Source={x:Static lg:LanguageService.Instance}, TargetNullValue='编辑标题、坐标轴与图解内文本的多语言内容。'}"/>

                <Border Grid.Row="2" Background="White" CornerRadius="10" BorderBrush="{StaticResource BorderBrushLight}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#FAFAFA" Padding="12,8" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                            <WrapPanel>
                                <Button Content="{Binding [swap_language_columns], Source={x:Static lg:LanguageService.Instance}}"
                                        Click="SwapTranslationLanguage_Click" Margin="0,0,8,0"/>
                                <Button Content="{Binding [diagram_translation_export], Source={x:Static lg:LanguageService.Instance}, FallbackValue=导出}"
                                        Command="{Binding ExportTranslationsCommand}" Margin="0,0,8,0"/>
                                <Button Content="{Binding [diagram_translation_import], Source={x:Static lg:LanguageService.Instance}, FallbackValue=导入}"
                                        Command="{Binding ImportTranslationsCommand}"/>
                            </WrapPanel>
                        </Border>

                        <DataGrid x:Name="TranslationGrid" Grid.Row="1"
                                  ItemsSource="{Binding TranslationTable}"
                                  Style="{StaticResource TranslationDataGridStyle}"
                                  CellStyle="{StaticResource TranslationDataGridCellStyle}"
                                  AutoGenerateColumns="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  EnableRowVirtualization="False"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True"
                                  AutoGeneratingColumn="TranslationGrid_AutoGeneratingColumn"
                                  PreparingCellForEdit="TranslationGrid_PreparingCellForEdit"
                                  LoadingRow="TranslationGrid_LoadingRow"
                                  CellEditEnding="TranslationGrid_CellEditEnding">
                            <DataGrid.Resources>
                                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ScrollBarBaseStyle}"/>
                            </DataGrid.Resources>
                        </DataGrid>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="3" Text="{Binding TranslationStatusMessage}" Margin="0,10,0,0"
                           FontSize="12" Foreground="#86868B" TextTrimming="CharacterEllipsis"/>
            </Grid>

            <!-- Diagram script -->
            <Grid x:Name="ScriptPanel" Visibility="Collapsed" Margin="0">
                <local:ScriptDefinitionControl ScriptDefinition="{Binding ScriptDefinition, Mode=OneWay}"
                                               UseStandaloneValidation="True"/>
            </Grid>

            <!-- Help documents -->
            <Grid x:Name="HelpPanel" Visibility="Collapsed" Margin="20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleStyle}"
                           Text="{Binding [geo_step_help_doc], Source={x:Static lg:LanguageService.Instance}, TargetNullValue='帮助文档'}"/>
                <TextBlock Grid.Row="1" Style="{StaticResource SectionHintStyle}"
                           Text="{Binding [geo_help_optional_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue='帮助文档为可选内容，支持多语言 RTF 富文本格式。'}"/>

                <Border Grid.Row="2" Background="#FAFAFA" Padding="12,8" Margin="0,0,0,0"
                        CornerRadius="10,10,0,0" BorderBrush="{StaticResource BorderBrushLight}" BorderThickness="1,1,1,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding [geo_help_current_lang], Source={x:Static lg:LanguageService.Instance}, FallbackValue='当前语言：'}"
                                   FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox ItemsSource="{Binding LanguageParts}"
                                  DisplayMemberPath="DisplayText"
                                  SelectedValuePath="Text"
                                  SelectedValue="{Binding SelectedHelpLanguage, Mode=TwoWay}"
                                  Width="130" VerticalAlignment="Center"/>

                        <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="14,0"/>

                        <Button Style="{StaticResource HelpFormatButtonStyle}" Click="BoldButton_Click"
                                ToolTip="{Binding [geo_help_bold], Source={x:Static lg:LanguageService.Instance}, FallbackValue='加粗 (Ctrl+B)'}">
                            <TextBlock Text="B" FontWeight="Bold" FontSize="13"/>
                        </Button>
                        <Button Style="{StaticResource HelpFormatButtonStyle}" Click="ItalicButton_Click" Margin="4,0,0,0"
                                ToolTip="{Binding [geo_help_italic], Source={x:Static lg:LanguageService.Instance}, FallbackValue='斜体 (Ctrl+I)'}">
                            <TextBlock Text="I" FontStyle="Italic" FontSize="13"/>
                        </Button>
                        <Button Style="{StaticResource HelpFormatButtonStyle}" Click="UnderlineButton_Click" Margin="4,0,0,0"
                                ToolTip="{Binding [geo_help_underline], Source={x:Static lg:LanguageService.Instance}, FallbackValue='下划线 (Ctrl+U)'}">
                            <TextBlock Text="U" FontSize="13" TextDecorations="Underline"/>
                        </Button>

                        <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="10,0"/>

                        <ToggleButton x:Name="HelpColorButton" Style="{StaticResource HelpFormatToggleButtonStyle}" Margin="0,0,4,0" Focusable="False"
                                      ToolTip="{Binding [font_color], Source={x:Static lg:LanguageService.Instance}, FallbackValue='字体颜色'}">
                            <Grid>
                                <TextBlock Text="A" FontSize="13" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,3"/>
                                <Border Height="3" VerticalAlignment="Bottom" Margin="4,0,4,3"
                                        Background="{Binding ElementName=HelpDocColorPicker, Path=SelectedBrush}" CornerRadius="1"/>
                            </Grid>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=HelpColorButton}" StaysOpen="False"
                               PlacementTarget="{Binding ElementName=HelpColorButton}" Placement="Bottom" AllowsTransparency="True">
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="5">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="#20000000" Opacity="0.4"/>
                                </Border.Effect>
                                <local:CustomColorPicker x:Name="HelpDocColorPicker" Width="270" Height="Auto" SelectedColor="Black"/>
                            </Border>
                        </Popup>

                        <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="10,0"/>

                        <TextBlock Text="{Binding [geo_help_font_size], Source={x:Static lg:LanguageService.Instance}, FallbackValue='字号：'}"
                                   FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="FontSizeComboBox" Width="65" SelectedIndex="1" IsEditable="True"
                                  SelectionChanged="FontSizeComboBox_SelectionChanged">
                            <ComboBoxItem Content="10"/>
                            <ComboBoxItem Content="12"/>
                            <ComboBoxItem Content="14"/>
                            <ComboBoxItem Content="16"/>
                            <ComboBoxItem Content="18"/>
                            <ComboBoxItem Content="20"/>
                            <ComboBoxItem Content="24"/>
                            <ComboBoxItem Content="28"/>
                            <ComboBoxItem Content="36"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Background="White" CornerRadius="0,0,10,10"
                        BorderBrush="{StaticResource BorderBrushLight}" BorderThickness="1,0,1,1">
                    <RichTextBox x:Name="HelpDocEditor"
                                 Padding="16,12" BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 AcceptsTab="True">
                        <RichTextBox.Resources>
                            <Style TargetType="{x:Type FlowDocument}">
                                <Setter Property="ColumnWidth" Value="999999"/>
                                <Setter Property="PagePadding" Value="10"/>
                            </Style>
                        </RichTextBox.Resources>
                        <FlowDocument/>
                    </RichTextBox>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushLight}" BorderThickness="0,1,0,0" Padding="20,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding [Cancel], Source={x:Static lg:LanguageService.Instance}}"
                            Style="{StaticResource FooterButtonStyle}" Background="White" BorderBrush="#D1D1D6" BorderThickness="1"
                            Margin="0,0,10,0" Click="CancelButton_Click"/>
                    <Button Content="{Binding [Confirm], Source={x:Static lg:LanguageService.Instance}}"
                            Style="{StaticResource FooterButtonStyle}" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"
                            Click="ConfirmButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
