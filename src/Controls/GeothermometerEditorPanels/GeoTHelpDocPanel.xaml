<UserControl x:Class="GeoChemistryNexus.Controls.GeothermometerEditorPanels.GeoTHelpDocPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="600"
             VerticalAlignment="Stretch">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/GeoChemistryNexus;component/Themes/EditorStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="HelpLangListBoxItemStyle" TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="TokenBd" Style="{StaticResource GeoTTokenBorderStyle}" Padding="10,7"
                                    Background="#EBF3FF" BorderBrush="Transparent" BorderThickness="1">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TokenBd" Property="Background" Value="{StaticResource EditorPrimarySoftBrush}"/>
                                    <Setter TargetName="TokenBd" Property="BorderBrush" Value="{StaticResource EditorPrimaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TokenBd" Property="Opacity" Value="0.92"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="10" BorderBrush="{StaticResource EditorBorderBrushLight}" BorderThickness="1"
            VerticalAlignment="Stretch">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 语言管理 -->
            <Border Grid.Row="0" Background="#F8F8FA" Padding="14,12"
                    BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource GeoTSectionTitleStyle}" Margin="0,0,0,8"
                               Text="{Binding [geo_step_help_doc], Source={x:Static lg:LanguageService.Instance}, FallbackValue=帮助文档}"/>
                    <TextBlock Style="{StaticResource GeoTSectionHintStyle}" Margin="0,0,0,10"
                               Text="{Binding [geo_help_optional_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=帮助文档为可选内容，支持多语言 RTF 富文本格式。}"/>

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,6"
                               Text="{Binding [geo_help_current_lang], Source={x:Static lg:LanguageService.Instance}, FallbackValue=当前语言}"/>
                    <ListBox ItemsSource="{Binding AddedLanguageOptions}"
                             SelectedValue="{Binding SelectedLanguage, Mode=TwoWay}"
                             SelectedValuePath="Code"
                             DisplayMemberPath="DisplayName"
                             ItemContainerStyle="{StaticResource HelpLangListBoxItemStyle}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityReConverter}}">
                        <TextBlock Text="{Binding [geo_help_add_lang], Source={x:Static lg:LanguageService.Instance}, FallbackValue=添加语言：}"
                                   FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguageOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Code"
                                  SelectedValue="{Binding NewLanguageToAdd}"
                                  Width="140" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource LangActionButtonStyle}"
                                Command="{Binding AddLanguageCommand}" Margin="6,0,0,0"
                                ToolTip="{Binding [geo_help_add_doc], Source={x:Static lg:LanguageService.Instance}, FallbackValue=添加该语言的帮助文档}">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#0078D4"/>
                        </Button>
                        <Button Style="{StaticResource LangActionButtonStyle}"
                                Command="{Binding RemoveLanguageCommand}" Margin="4,0,0,0"
                                ToolTip="{Binding [geo_help_delete_doc], Source={x:Static lg:LanguageService.Instance}, FallbackValue=删除当前语言的帮助文档}">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#D13438"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 格式工具栏 -->
            <Border Grid.Row="1" Background="White" Padding="12,6" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedLanguage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsContentReadOnly}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource HelpFormatButtonStyle}" Click="BoldButton_Click"
                            ToolTip="{Binding [geo_help_bold], Source={x:Static lg:LanguageService.Instance}, FallbackValue=加粗 (Ctrl+B)}">
                        <TextBlock Text="B" FontWeight="Bold" FontSize="13"/>
                    </Button>
                    <Button Style="{StaticResource HelpFormatButtonStyle}" Click="ItalicButton_Click" Margin="4,0,0,0"
                            ToolTip="{Binding [geo_help_italic], Source={x:Static lg:LanguageService.Instance}, FallbackValue=斜体 (Ctrl+I)}">
                        <TextBlock Text="I" FontStyle="Italic" FontSize="13"/>
                    </Button>
                    <Button Style="{StaticResource HelpFormatButtonStyle}" Click="UnderlineButton_Click" Margin="4,0,0,0"
                            ToolTip="{Binding [geo_help_underline], Source={x:Static lg:LanguageService.Instance}, FallbackValue=下划线 (Ctrl+U)}">
                        <TextBlock Text="U" FontSize="13" TextDecorations="Underline"/>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="10,0"/>

                    <TextBlock Text="{Binding [geo_help_font_size], Source={x:Static lg:LanguageService.Instance}, FallbackValue=字号：}"
                               FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="FontSizeComboBox" Width="65" SelectedIndex="1" IsEditable="True"
                              SelectionChanged="FontSizeComboBox_SelectionChanged">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="12"/>
                        <ComboBoxItem Content="14"/>
                        <ComboBoxItem Content="16"/>
                        <ComboBoxItem Content="18"/>
                        <ComboBoxItem Content="20"/>
                        <ComboBoxItem Content="24"/>
                        <ComboBoxItem Content="28"/>
                        <ComboBoxItem Content="36"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <RichTextBox Grid.Row="2" x:Name="HelpDocEditor"
                         Padding="16,12" BorderThickness="0"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         AcceptsTab="True"
                         IsReadOnly="{Binding IsContentReadOnly}">
                <RichTextBox.Style>
                    <Style TargetType="RichTextBox">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedLanguage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </RichTextBox.Style>
                <RichTextBox.Resources>
                    <Style TargetType="{x:Type FlowDocument}">
                        <Setter Property="ColumnWidth" Value="999999"/>
                        <Setter Property="PagePadding" Value="10"/>
                    </Style>
                </RichTextBox.Resources>
                <FlowDocument/>
            </RichTextBox>

            <!-- 无语言空状态 -->
            <StackPanel Grid.Row="1" Grid.RowSpan="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedLanguage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                           Foreground="#CCC" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="{Binding [geo_help_no_lang_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=请点击上方的 + 按钮添加语言，然后编辑帮助文档。}"
                           FontSize="14" Foreground="#999" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
