<UserControl x:Class="GeoChemistryNexus.Controls.GeothermometerEditorPanels.GeoTScriptPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="600"
             VerticalAlignment="Stretch">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/GeoChemistryNexus;component/Themes/EditorStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 表格与公式映射卡片 -->
        <Border Grid.Row="0" Style="{StaticResource GeoTPanelCardStyle}" Margin="0,0,0,12" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="280">
                <StackPanel Margin="16,14">
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_script_headers], Source={x:Static lg:LanguageService.Instance}, FallbackValue=表头 *（逗号分隔）}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding HeadersText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding [geo_tooltip_headers], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: SiO2, TiO2, Al2O3, T(K)'}"
                                     IsReadOnly="{Binding IsContentReadOnly}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_script_sample_row], Source={x:Static lg:LanguageService.Instance}, FallbackValue=示例行（逗号分隔）}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding ExampleRowText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding [geo_tooltip_sample_row_eg], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: 45.2, 0.8, 12.3, =MyFormula(A2,B2,C2)'}"
                                     IsReadOnly="{Binding IsContentReadOnly}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_script_inputs], Source={x:Static lg:LanguageService.Instance}, FallbackValue=输入列（逗号分隔）}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding InputColumnsText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding [geo_tooltip_inputs_eg], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: SiO2, TiO2, Al2O3'}"
                                     IsReadOnly="{Binding IsContentReadOnly}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource FieldLabelStyle}"
                               Text="{Binding [geo_formulas_title], Source={x:Static lg:LanguageService.Instance}, FallbackValue=Grid 公式 *}"/>
                    <TextBlock Style="{StaticResource FieldHintStyle}" Margin="0,0,0,8"
                               Text="{Binding [geo_formulas_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=将 Grid 自定义函数名映射到下方 JS 脚本中的函数。首行主公式固定调用 calculate(args)。}"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="2" FontSize="10" Foreground="#888" FontWeight="SemiBold"
                                   Text="{Binding [geo_additional_formula_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=Grid 公式名}"/>
                        <TextBlock Grid.Column="4" FontSize="10" Foreground="#888" FontWeight="SemiBold"
                                   Text="{Binding [geo_additional_function_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=JS 函数名}"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#E8F4FD" BorderBrush="#B3D9F2" BorderThickness="1"
                                CornerRadius="4" Padding="6,4" VerticalAlignment="Center">
                            <TextBlock FontSize="10" Foreground="#0078D4" FontWeight="SemiBold" TextAlignment="Center"
                                       Text="{Binding [geo_main_formula_badge], Source={x:Static lg:LanguageService.Instance}, FallbackValue=主公式}"/>
                        </Border>
                        <TextBox Grid.Column="2" Style="{StaticResource FieldInputStyle}"
                                 Text="{Binding FormulaName, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="{Binding [geo_tooltip_formula_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=仅限字母、数字和下划线，如 MyFormula_v1}"
                                 IsReadOnly="{Binding IsContentReadOnly}"/>
                        <Border Grid.Column="4" Background="#F5F5F5" BorderBrush="#D0D0D0" BorderThickness="1"
                                CornerRadius="4" Padding="6,4" VerticalAlignment="Center">
                            <TextBlock FontSize="12" Foreground="#666" FontFamily="Consolas, Courier New"
                                       Text="{Binding MainFunctionName, Mode=OneWay}"/>
                        </Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding AdditionalFormulaItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F0F0F0" BorderBrush="#E0E0E0" BorderThickness="1"
                                            CornerRadius="4" Padding="6,4" VerticalAlignment="Center">
                                        <TextBlock FontSize="10" Foreground="#666" FontWeight="SemiBold" TextAlignment="Center"
                                                   Text="{Binding [geo_additional_formula_badge], Source={x:Static lg:LanguageService.Instance}, FallbackValue=附加}"/>
                                    </Border>
                                    <TextBox Grid.Column="2" Style="{StaticResource FieldInputStyle}"
                                             Text="{Binding FormulaName, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{Binding [geo_tooltip_formula_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=仅限字母、数字和下划线，如 MyFormula_v1}"
                                             IsReadOnly="{Binding DataContext.IsContentReadOnly, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    <TextBox Grid.Column="4" Style="{StaticResource FieldInputStyle}"
                                             Text="{Binding FunctionName, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{Binding [geo_tooltip_additional_function_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=脚本中的 JS 函数名，如 calcPressure}"
                                             IsReadOnly="{Binding DataContext.IsContentReadOnly, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    <Button Grid.Column="5"
                                            Command="{Binding DataContext.RemoveAdditionalFormulaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource LangActionButtonStyle}"
                                            VerticalAlignment="Center"
                                            ToolTip="{Binding [Delete], Source={x:Static lg:LanguageService.Instance}, FallbackValue=删除}"
                                            Visibility="{Binding DataContext.IsContentReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityReConverter}}">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#D13438"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Command="{Binding AddAdditionalFormulaCommand}"
                            HorizontalAlignment="Left" Margin="0,2,0,0" Padding="10,4"
                            FontSize="11" Cursor="Hand"
                            Background="#F0F7FF" Foreground="#0078D4" BorderBrush="#B3D9F2" BorderThickness="1"
                            Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityReConverter}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E0EEFB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding [geo_btn_add_additional_formula], Source={x:Static lg:LanguageService.Instance}, FallbackValue=添加附加公式}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 脚本编辑器 -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" BorderBrush="{StaticResource EditorBorderBrushLight}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F8F8FA" Padding="14,10"
                        BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="#0078D4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding [geo_script_javascript], Source={x:Static lg:LanguageService.Instance}, FallbackValue=JavaScript 脚本}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                        <TextBlock Text="  calculate(args) + calculateDetailed(inputs)"
                                   FontSize="11" Foreground="#999" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <TextBox Grid.Row="1"
                         Text="{Binding ScriptContent, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas, Courier New" FontSize="13"
                         AcceptsReturn="True" AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" BorderThickness="0" Padding="14,10"
                         Background="White"
                         IsReadOnly="{Binding IsContentReadOnly}"/>

                <Border Grid.Row="2" Background="#F8F8FA" Padding="14,10,14,12"
                        BorderBrush="#E8E8E8" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding [geo_script_test_input], Source={x:Static lg:LanguageService.Instance}, FallbackValue=测试输入：}"
                                   FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Style="{StaticResource FieldInputStyle}"
                                 Text="{Binding TestInputText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="{Binding [geo_tooltip_test_input_eg], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: 45.2, 0.8, 12.3'}"
                                 MinHeight="32" FontSize="12" VerticalAlignment="Center"/>

                        <Button Grid.Column="2" Content="{Binding [geo_script_run_test], Source={x:Static lg:LanguageService.Instance}, FallbackValue=运行测试}"
                                Command="{Binding TestScriptCommand}" Margin="8,0"
                                FontSize="12" Padding="12,4" Cursor="Hand" VerticalAlignment="Center"
                                Background="#E8F4FD" Foreground="#0078D4" BorderBrush="#B3D9F2" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#D0EAFB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Grid.Column="3" Text="{Binding [geo_script_result], Source={x:Static lg:LanguageService.Instance}, FallbackValue=结果：}"
                                   FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="8,0,8,0"/>
                        <TextBlock Grid.Column="4" Text="{Binding TestResultText}" FontSize="12" VerticalAlignment="Center"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D13438"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTestSuccess}" Value="True">
                                            <Setter Property="Foreground" Value="#107C10"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
