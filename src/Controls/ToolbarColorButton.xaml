<UserControl x:Class="GeoChemistryNexus.Controls.ToolbarColorButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GeoChemistryNexus.Controls"
             mc:Ignorable="d"
             Width="28" Height="28"
             d:DesignHeight="28" d:DesignWidth="28">
    <Grid>
        <Button Width="28" Height="28"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding ShowColorPickerCommand, RelativeSource={RelativeSource AncestorType=local:ToolbarColorButton}}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" ToolTip="{TemplateBinding ToolTip}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E5E5E5"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#D1D1D1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <Grid Width="20" Height="20">
                <TextBlock Text="{Binding IconText, RelativeSource={RelativeSource AncestorType=local:ToolbarColorButton}}"
                           FontFamily="{Binding IconFontFamily, RelativeSource={RelativeSource AncestorType=local:ToolbarColorButton}}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#333"/>
                <Border Height="3"
                        VerticalAlignment="Bottom"
                        Margin="1,0,1,1"
                        CornerRadius="1"
                        Background="{Binding IndicatorBrush, RelativeSource={RelativeSource AncestorType=local:ToolbarColorButton}}"/>
            </Grid>
        </Button>

        <Popup x:Name="ColorPopup"
               PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=local:ToolbarColorButton}}"
               StaysOpen="False"
               AllowsTransparency="True"
               Placement="Bottom">
            <Border Background="White" CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1" Padding="10">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="5" Opacity="0.4"/>
                </Border.Effect>
                <local:CustomColorPicker SelectedBrush="{Binding SelectedBrush, RelativeSource={RelativeSource AncestorType=local:ToolbarColorButton}, Mode=TwoWay}"/>
            </Border>
        </Popup>
    </Grid>
</UserControl>
