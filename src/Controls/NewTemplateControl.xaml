<UserControl x:Class="GeoChemistryNexus.Controls.NewTemplateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GeoChemistryNexus.Controls"
             xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#F5F5F7">

    <UserControl.Resources>
        <SolidColorBrush x:Key="ModernPrimaryBrush" Color="#007AFF"/>
        <SolidColorBrush x:Key="ModernPrimarySoftBrush" Color="#EAF3FF"/>
        <SolidColorBrush x:Key="ModernTextPrimaryBrush" Color="#1D1D1F"/>
        <SolidColorBrush x:Key="ModernTextSecondaryBrush" Color="#86868B"/>
        <SolidColorBrush x:Key="ModernCardBorderBrush" Color="#E5E5EA"/>
        <SolidColorBrush x:Key="ModernSelectedCardBorderBrush" Color="#0A84FF"/>
        <SolidColorBrush x:Key="ModernSelectedCardBackgroundBrush" Color="#F3F8FF"/>
        
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource ModernTextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernTokenStyle" TargetType="Border">
            <Setter Property="Background" Value="#EBF3FF"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <Style x:Key="ModernTokenTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#007AFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="ModernTokenCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Width="16" Height="16" CornerRadius="8">
                            <TextBlock Text="✕" FontSize="10" FontWeight="Bold" Foreground="#007AFF" 
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                         <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D6E6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default Language Highlight -->
         <Style x:Key="ModernTokenDefaultTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ModernTokenTextStyle}">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Text" Value="★"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDefault}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                             <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlotTypeListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="PlotTypeListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Margin" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="40,30">
            <StackPanel MaxWidth="700">
                <!-- Header Info -->
                <TextBlock Text="{Binding [new_template_description], Source={x:Static lg:LanguageService.Instance}, TargetNullValue='配置新建绘图模板的属性。'}" 
                           Foreground="{StaticResource ModernTextSecondaryBrush}" FontSize="13" Margin="0,0,0,20" TextWrapping="Wrap"/>

                <!-- Language Section -->
                <Border Style="{StaticResource ModernCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                             <TextBlock Text="🌐" Margin="0,0,8,0" FontSize="16" VerticalAlignment="Center"/>
                             <TextBlock Text="{Binding [enter_supported_languages],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource ModernSectionTitleStyle}"/>
                        </StackPanel>

                        <ItemsControl x:Name="LanguageItemsControl" Grid.Row="1" Margin="0,0,0,16">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ModernTokenStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource ModernTokenDefaultTextStyle}"/>
                                            <TextBlock Text="{Binding Text}" Style="{StaticResource ModernTokenTextStyle}"/>
                                            <Button Tag="{Binding}" Click="RemoveLanguageButton_Click" 
                                                    Style="{StaticResource ModernTokenCloseButtonStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <hc:ComboBox x:Name="LanguageInputComboBox" 
                                         IsEditable="True"
                                         StaysOpenOnEdit="True"
                                         hc:InfoElement.Placeholder="{Binding [enter_language_add],Source={x:Static lg:LanguageService.Instance}}"
                                         DisplayMemberPath="Name"
                                         SelectedValuePath="Code"
                                         SelectionChanged="LanguageInputComboBox_SelectionChanged"
                                         PreviewKeyDown="LanguageInputComboBox_PreviewKeyDown"
                                         Style="{StaticResource ComboBoxExtend}"/>

                            <TextBlock Grid.Column="1" Text="{Binding [enter_language_add],Source={x:Static lg:LanguageService.Instance}}" 
                                       VerticalAlignment="Center" Foreground="{StaticResource ModernTextSecondaryBrush}" 
                                       Margin="16,0,0,0" FontSize="13" TextWrapping="Wrap"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Category Section -->
                <Border Style="{StaticResource ModernCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                             <TextBlock Text="🗂" Margin="0,0,8,0" FontSize="16" VerticalAlignment="Center"/>
                             <TextBlock Text="{Binding [enter_category_structure],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource ModernSectionTitleStyle}"/>
                        </StackPanel>

                        <ItemsControl x:Name="CategoryItemsControl" Grid.Row="1" Margin="0,0,0,16">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ModernTokenStyle}" Background="#FFF0E6"> <!-- Light Orange/Red for Category -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource ModernTokenTextStyle}" Foreground="#FF6B00"/>
                                            <Button Tag="{Binding}" Click="RemoveCategoryButton_Click" 
                                                    Style="{StaticResource ModernTokenCloseButtonStyle}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" Width="16" Height="16" CornerRadius="8">
                                                            <TextBlock Text="✕" FontSize="10" FontWeight="Bold" Foreground="#FF6B00" 
                                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                        </Border>
                                                         <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FFE0CC"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Row="2">
                             <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <hc:ComboBox x:Name="CategoryInputComboBox"
                                         IsEditable="True"
                                         StaysOpenOnEdit="True"
                                         hc:InfoElement.Placeholder="{Binding [enter_level_add],Source={x:Static lg:LanguageService.Instance}}"
                                         DisplayMemberPath="DisplayName"
                                         SelectedValuePath="DisplayName"
                                         SelectionChanged="CategoryInputComboBox_SelectionChanged"
                                         PreviewKeyDown="CategoryInputComboBox_PreviewKeyDown"
                                         Style="{StaticResource ComboBoxExtend}"/>

                            <TextBlock Grid.Column="1" Text="{Binding [enter_level_add],Source={x:Static lg:LanguageService.Instance}}" 
                                       VerticalAlignment="Center" Foreground="{StaticResource ModernTextSecondaryBrush}" 
                                       Margin="16,0,0,0" FontSize="13" TextWrapping="Wrap"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Plot Type Section -->
                <Border Style="{StaticResource ModernCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                             <TextBlock Text="📊" Margin="0,0,8,0" FontSize="16" VerticalAlignment="Center"/>
                             <TextBlock Text="{Binding [plot_type],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource ModernSectionTitleStyle}"/>
                        </StackPanel>

                        <ListBox x:Name="PlotTypeListBox"
                                 Grid.Row="1"
                                 AlternationCount="2"
                                 SelectedValuePath="Key"
                                 BorderThickness="0"
                                 Style="{StaticResource PlotTypeListBoxStyle}"
                                 ItemContainerStyle="{StaticResource PlotTypeListBoxItemStyle}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <primitives:UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="PlotTypeCard"
                                            Padding="18"
                                            CornerRadius="12"
                                            Background="White"
                                            BorderBrush="{StaticResource ModernCardBorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border x:Name="PlotTypeIcon"
                                                    Width="40"
                                                    Height="40"
                                                    CornerRadius="10"
                                                    Background="#F2F4F7"
                                                    Margin="0,0,14,0">
                                                <TextBlock x:Name="PlotTypeBadgeText"
                                                           Text="{Binding Badge}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ModernTextPrimaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="PlotTypeTitle"
                                                           Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ModernTextPrimaryBrush}"/>
                                                <TextBlock x:Name="PlotTypeDescription"
                                                           Text="{Binding Description}"
                                                           Margin="0,6,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource ModernTextSecondaryBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Border x:Name="SelectionBadge"
                                                    Grid.Column="2"
                                                    MinWidth="44"
                                                    Height="24"
                                                    CornerRadius="12"
                                                    Background="{StaticResource ModernPrimarySoftBrush}"
                                                    Padding="10,0"
                                                    VerticalAlignment="Top"
                                                    Visibility="Collapsed">
                                                <TextBlock Text="{Binding SelectedLabel}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ModernPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                            <Setter TargetName="PlotTypeCard" Property="BorderBrush" Value="#C6DAFF"/>
                                            <Setter TargetName="PlotTypeCard" Property="Background" Value="#FAFCFF"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                            <Setter TargetName="PlotTypeCard" Property="BorderBrush" Value="{StaticResource ModernSelectedCardBorderBrush}"/>
                                            <Setter TargetName="PlotTypeCard" Property="Background" Value="{StaticResource ModernSelectedCardBackgroundBrush}"/>
                                            <Setter TargetName="PlotTypeIcon" Property="Background" Value="{StaticResource ModernPrimaryBrush}"/>
                                            <Setter TargetName="PlotTypeTitle" Property="Foreground" Value="{StaticResource ModernPrimaryBrush}"/>
                                            <Setter TargetName="PlotTypeBadgeText" Property="Foreground" Value="White"/>
                                            <Setter TargetName="SelectionBadge" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=IsEnabled}" Value="False">
                                            <Setter TargetName="PlotTypeCard" Property="Opacity" Value="0.65"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Diagram Version Section (Read-Only) -->
                <Border Style="{StaticResource ModernCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4CB;" Margin="0,0,8,0" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding [current_diagram_version],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource ModernSectionTitleStyle}"/>
                        </StackPanel>

                        <TextBlock x:Name="DiagramVersionText" Grid.Column="1" 
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="14" Foreground="{StaticResource ModernTextSecondaryBrush}"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Bar -->
        <Border Grid.Row="1" Background="#F9F9F9" BorderBrush="#E5E5E5" BorderThickness="0,1,0,0" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="{Binding [Cancel],Source={x:Static lg:LanguageService.Instance}}" 
                        Style="{StaticResource ModernButtonStyle}" Background="White" Foreground="#1D1D1F" 
                        BorderBrush="#D1D1D6" BorderThickness="1"
                        Margin="0,0,12,0" Width="90" Click="CancelButton_Click"/>
                <Button x:Name="ConfirmButton" Content="{Binding [Confirm],Source={x:Static lg:LanguageService.Instance}}" 
                        Style="{StaticResource ModernButtonStyle}" Background="{StaticResource ModernPrimaryBrush}" Foreground="White"
                        Width="90" Click="ConfirmButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
