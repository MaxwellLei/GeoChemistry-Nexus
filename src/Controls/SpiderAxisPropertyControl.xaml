<UserControl x:Class="GeoChemistryNexus.Controls.SpiderAxisPropertyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GeoChemistryNexus.Controls"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:cvs="clr-namespace:GeoChemistryNexus.Converter"
             xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="300"
             Background="#F5F5F7">
    <UserControl.Resources>
        <cvs:StringColorConverter x:Key="StringColorConverter"/>
        <cvs:NumericTypeConverter x:Key="NumericTypeConverter"/>
    </UserControl.Resources>

    <Grid DataContext="{Binding SelectedObject, RelativeSource={RelativeSource AncestorType=local:SpiderAxisPropertyControl}}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12">
                <TextBlock Text="{Binding [axis_style],Source={x:Static lg:LanguageService.Instance}, FallbackValue='Axis Label'}" 
                           Style="{StaticResource ModernSettingsGroupTitle}" Margin="4,10,0,6"/>
                <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,8">
                    <StackPanel Margin="10">
                        <!-- Label -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding [content],Source={x:Static lg:LanguageService.Instance}, FallbackValue='Content'}" 
                                       Style="{StaticResource ModernLabelStyle}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" 
                                     Height="28" FontSize="13" Padding="6,3" VerticalContentAlignment="Center"/>
                        </Grid>
                        <!-- Font Size -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding [font_size],Source={x:Static lg:LanguageService.Instance}, FallbackValue='Font Size'}" 
                                       Style="{StaticResource ModernLabelStyle}" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Column="1" Value="{Binding FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NumericTypeConverter}}" Minimum="8" Maximum="36" Increment="1" 
                                             Style="{StaticResource ModernNumericUpDownStyle}" Height="28"/>
                        </Grid>

                        <!-- Style -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{Binding [style],Source={x:Static lg:LanguageService.Instance}, FallbackValue='Style'}"
                                       Style="{StaticResource ModernLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding [font_color],Source={x:Static lg:LanguageService.Instance}, FallbackValue='Font Color'}"
                                       Style="{StaticResource ModernLabelStyle}"/>

                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                                <ToggleButton Width="40" Height="32" Margin="0,0,8,0"
                                              IsChecked="{Binding IsBold, Mode=TwoWay}"
                                              Style="{StaticResource FontStyleToggleButtonStyle}">
                                    <TextBlock Text="B" FontWeight="Bold"/>
                                </ToggleButton>
                                <ToggleButton Width="40" Height="32"
                                              IsChecked="{Binding IsItalic, Mode=TwoWay}"
                                              Style="{StaticResource FontStyleToggleButtonStyle}">
                                    <TextBlock Text="I" FontStyle="Italic" FontFamily="Times New Roman"/>
                                </ToggleButton>
                            </StackPanel>

                            <local:TextPropertyColorPicker Grid.Row="1" Grid.Column="2"
                                                           SelectedColor="{Binding Color, Mode=TwoWay, Converter={StaticResource StringColorConverter}}"
                                                           Height="32" Width="100"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding [major_tick_style],Source={x:Static lg:LanguageService.Instance}, FallbackValue='Tick Label'}" 
                           Style="{StaticResource ModernSettingsGroupTitle}" Margin="4,10,0,6"/>
                <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,8">
                    <StackPanel Margin="10">
                        <!-- Tick Font Size -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding [font_size],Source={x:Static lg:LanguageService.Instance}, FallbackValue='Font Size'}" 
                                       Style="{StaticResource ModernLabelStyle}" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Column="1" Value="{Binding TickFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NumericTypeConverter}}" Minimum="6" Maximum="24" Increment="1" 
                                             Style="{StaticResource ModernNumericUpDownStyle}" Height="28"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
