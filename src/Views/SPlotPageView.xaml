<Page x:Class="GeoChemistryNexus.Views.SPlotPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      xmlns:local="clr-namespace:GeoChemistryNexus.Views"
      xmlns:models="clr-namespace:GeoChemistryNexus.Models"
      xmlns:cvs="clr-namespace:GeoChemistryNexus.Converter"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="600"
      Title="SPlotPageView"
      UseLayoutRounding="True" TextOptions.TextFormattingMode="Display">

    <Page.Resources>
        <cvs:TemplateCardSizePresetToDisplayConverter x:Key="TemplateCardSizePresetToDisplayConverter"/>
    </Page.Resources>
    <Grid>
        <hc:ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,20,20,40" MaxWidth="800" HorizontalAlignment="Stretch">

                <!-- EXTERNAL APPLICATIONS -->
                <TextBlock Text="{Binding [external_applications],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource ModernSettingsGroupTitle}"/>
                <Border Style="{StaticResource ModernSettingsCard}">
                    <StackPanel>
                        <!-- CorelDRAW -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="CorelDRAW" FontSize="14"/>
                                <TextBlock Text="{Binding [coreldraw_path_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=设置 CorelDRAW 可执行文件路径，用于打开矢量图}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Text="{Binding CorelDRAWPath}" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                         VerticalAlignment="Center" Foreground="Gray" TextAlignment="Right" Width="220" Margin="0,0,8,0"/>
                                <Button Content="..." Command="{Binding SelectCorelDRAWPathCommand}" Width="40" Height="28"/>
                            </StackPanel>
                        </Grid>
                        
                        <Border Height="1" Background="#E5E5E5" Margin="16,0,0,0"/>

                        <!-- Inkscape -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="Inkscape" FontSize="14"/>
                                <TextBlock Text="{Binding [inkscape_path_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=设置 Inkscape 可执行文件路径，用于打开矢量图}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Text="{Binding InkscapePath}" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                         VerticalAlignment="Center" Foreground="Gray" TextAlignment="Right" Width="220" Margin="0,0,8,0"/>
                                <Button Content="..." Command="{Binding SelectInkscapePathCommand}" Width="40" Height="28"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="#E5E5E5" Margin="16,0,0,0"/>

                        <!-- Illustrator -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="Adobe Illustrator" FontSize="14"/>
                                <TextBlock Text="{Binding [adobe_illustrator_path_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=设置 Adobe Illustrator 可执行文件路径，用于打开矢量图}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Text="{Binding AdobeIllustratorPath}" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                         VerticalAlignment="Center" Foreground="Gray" TextAlignment="Right" Width="220" Margin="0,0,8,0"/>
                                <Button Content="..." Command="{Binding SelectAdobeIllustratorPathCommand}" Width="40" Height="28"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="#E5E5E5" Margin="16,0,0,0"/>

                        <!-- Custom -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding [custom_app],Source={x:Static lg:LanguageService.Instance}}" FontSize="14"/>
                                <TextBlock Text="{Binding [custom_app_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=设置自定义第三方绘图软件的可执行文件路径}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Text="{Binding CustomThirdPartyAppPath}" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                         VerticalAlignment="Center" Foreground="Gray" TextAlignment="Right" Width="220" Margin="0,0,8,0"/>
                                <Button Content="..." Command="{Binding SelectCustomThirdPartyAppPathCommand}" Width="40" Height="28"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- PLOT DEFAULTS -->
                <TextBlock Text="{Binding [plot_defaults],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource ModernSettingsGroupTitle}"/>
                <Border Style="{StaticResource ModernSettingsCard}">
                    <StackPanel>
                        <!-- Default Expand Level -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding [default_diagram_expand_level],Source={x:Static lg:LanguageService.Instance}}" FontSize="14"/>
                                <TextBlock Text="{Binding [default_diagram_expand_level_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=图解分类树默认展开到的层级深度}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <ComboBox SelectedValue="{Binding DefaultTreeExpandLevel}" FontSize="12" VerticalAlignment="Center" 
                                      HorizontalAlignment="Right" SelectedValuePath="Content" Width="80" Height="30" Grid.Column="1">
                                <ComboBox.Items>
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                </ComboBox.Items>
                            </ComboBox>
                        </Grid>

                        <Border Height="1" Background="#E5E5E5" Margin="16,0,0,0"/>

                        <!-- Default App -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding [default_third_party_editor],Source={x:Static lg:LanguageService.Instance}}" FontSize="14"/>
                                <TextBlock Text="{Binding [default_third_party_editor_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=编辑或导出矢量图时默认打开的第三方软件}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding ThirdPartyApps}" SelectedValue="{Binding SelectedThirdPartyApp}" 
                                      FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" Width="140" Height="30" Grid.Column="1"/>
                        </Grid>

                        <Border Height="1" Background="#E5E5E5" Margin="16,0,0,0"/>

                        <!-- Object Selection Trigger -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding [object_selection_trigger],Source={x:Static lg:LanguageService.Instance}}" FontSize="14"/>
                                <TextBlock Text="{Binding [object_selection_trigger_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=在绘图画布上选中图形对象的鼠标操作方式}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <ComboBox SelectedValue="{Binding ObjectSelectionTrigger}" FontSize="12" VerticalAlignment="Center" 
                                      HorizontalAlignment="Right" SelectedValuePath="Tag" Width="140" Height="30" Grid.Column="1">
                                <ComboBox.Items>
                                    <ComboBoxItem Content="{Binding [single_click],Source={x:Static lg:LanguageService.Instance}}" Tag="SingleClick"/>
                                    <ComboBoxItem Content="{Binding [double_click],Source={x:Static lg:LanguageService.Instance}}" Tag="DoubleClick"/>
                                </ComboBox.Items>
                            </ComboBox>
                        </Grid>

                        <Border Height="1" Background="#E5E5E5" Margin="16,0,0,0"/>

                        <!-- Mouse Snap Auto Recognition Frame Rate -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding [mouse_snap_auto_recognition_frame_rate],Source={x:Static lg:LanguageService.Instance}}" FontSize="14"/>
                                <TextBlock Text="{Binding [mouse_snap_auto_recognition_frame_rate_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=鼠标吸附自动识别时的刷新帧率，越高越流畅但更耗性能}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding MouseSnapAutoRecognitionFrameRates}"
                                      SelectedValue="{Binding MouseSnapAutoRecognitionFrameRate}"
                                      FontSize="12"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Width="100"
                                      Height="30"
                                      Grid.Column="1"/>
                        </Grid>

                        <Border Height="1" Background="#E5E5E5" Margin="16,0,0,0"/>

                        <!-- Template Card Size Preset -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding [template_card_size_preset],Source={x:Static lg:LanguageService.Instance}}" FontSize="14"/>
                                <TextBlock Text="{Binding [template_card_size_preset_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=图解模板库中卡片的显示尺寸}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <ListBox Grid.Column="1"
                                     Height="32" Width="140"
                                     VerticalAlignment="Center" HorizontalAlignment="Right"
                                     Style="{StaticResource TemplateCardSizeSegmentedStyle}"
                                     ItemContainerStyle="{StaticResource TemplateCardSizeSegmentedItemStyle}"
                                     ItemsSource="{Binding TemplateCardSizePresetOptions}"
                                     SelectedItem="{Binding TemplateCardSizePreset, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource TemplateCardSizePresetToDisplayConverter}}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Border Height="1" Background="#E5E5E5" Margin="16,0,0,0"/>

                        <!-- Current Diagram Version (Read-Only) -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding [current_diagram_version],Source={x:Static lg:LanguageService.Instance}}" FontSize="14"/>
                                <TextBlock Text="{Binding [current_diagram_version_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=当前软件支持的图解模板格式版本（只读）}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentDiagramVersion}" VerticalAlignment="Center" 
                                       FontSize="14" Foreground="Gray" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- AUTOMATIC UPDATES -->
                <TextBlock Text="{Binding [automatic_updates],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource ModernSettingsGroupTitle}"/>
                <Border Style="{StaticResource ModernSettingsCard}">
                    <StackPanel>
                        <!-- Template Updates -->
                        <Grid MinHeight="56" Background="Transparent" Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding [auto_check_diagram_template_updates],Source={x:Static lg:LanguageService.Instance}}" FontSize="14"/>
                                <TextBlock Text="{Binding [auto_check_diagram_template_updates_hint],Source={x:Static lg:LanguageService.Instance}, FallbackValue=启动时自动检查图解模板是否有更新}" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                            </StackPanel>
                            <ToggleButton Style="{StaticResource ToggleButtonSwitch}" IsChecked="{Binding AutoCheckTemplateUpdate}" 
                                          HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </hc:ScrollViewer>
    </Grid>
</Page>
