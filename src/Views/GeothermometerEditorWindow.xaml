<Window x:Class="GeoChemistryNexus.Views.GeothermometerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:GeoChemistryNexus.ViewModels"
        xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
        xmlns:controls="clr-namespace:GeoChemistryNexus.Controls"
        xmlns:converter="clr-namespace:GeoChemistryNexus.Converter"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="{Binding EditorTitle}"
        Height="780" Width="960"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        Background="#F5F5F7">

    <Window.Resources>
        <converter:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converter:BoolToVisibilityReConverter x:Key="BooleanToVisibilityReConverter"/>
        <!-- HandyControl ComboBox（与字段输入框高度一致） -->
        <Style x:Key="EditorFieldComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ComboBoxExtend}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="hc:BorderElement.CornerRadius" Value="4"/>
        </Style>

        <!-- 标签样式 -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- 填写示例提示 -->
        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="FieldInputStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 多行输入框样式 -->
        <Style x:Key="MultiLineInputStyle" TargetType="TextBox" BasedOn="{StaticResource FieldInputStyle}">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Top"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="EditorButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryEditorButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorButtonStyle}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 格式化工具栏按钮样式 -->
        <Style x:Key="FormatButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D1D1D1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 语言管理小按钮样式 -->
        <Style x:Key="LangActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ==================== 内容区域 ==================== -->
            <Grid Grid.Row="0">

            <!-- ========== Step 1: 公式脚本（占满可视区域，避免测试栏被裁切） ========== -->
            <Border Background="White" CornerRadius="8" Padding="0" BorderBrush="#E0E0E0" BorderThickness="1"
                    VerticalAlignment="Stretch">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 表格定义区 -->
                    <Border Grid.Row="0" Padding="16,14" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_script_headers], Source={x:Static lg:LanguageService.Instance}, FallbackValue=表头 *（逗号分隔）}"/>
                                <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding HeadersText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding [geo_tooltip_headers], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: SiO2, TiO2, Al2O3, T(K)'}"
                                         IsReadOnly="{Binding IsContentReadOnly}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_script_sample_row], Source={x:Static lg:LanguageService.Instance}, FallbackValue=示例行（逗号分隔）}"/>
                                <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding ExampleRowText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding [geo_tooltip_sample_row_eg], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: 45.2, 0.8, 12.3, =MyFormula(A2,B2,C2)'}"
                                         IsReadOnly="{Binding IsContentReadOnly}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_script_inputs], Source={x:Static lg:LanguageService.Instance}, FallbackValue=输入列（逗号分隔）}"/>
                                <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding InputColumnsText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding [geo_tooltip_inputs_eg], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: SiO2, TiO2, Al2O3'}"
                                         IsReadOnly="{Binding IsContentReadOnly}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 脚本标题栏 -->
                    <Border Grid.Row="1" Background="#F8F8FA" Padding="14,10"
                            BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                       Foreground="#0078D4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [geo_script_javascript], Source={x:Static lg:LanguageService.Instance}, FallbackValue=JavaScript 脚本}" FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="  calculate(args) + calculateDetailed(inputs)" 
                                       FontSize="11" Foreground="#999" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 脚本编辑器 -->
                    <TextBox Grid.Row="2" 
                             Text="{Binding ScriptContent, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas, Courier New" FontSize="13"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" BorderThickness="0" Padding="14,10"
                             Background="White"
                             IsReadOnly="{Binding IsContentReadOnly}"/>

                    <!-- 测试栏 -->
                    <Border Grid.Row="3" Background="#F8F8FA" Padding="14,10,14,12" CornerRadius="0,0,8,8"
                            BorderBrush="#E8E8E8" BorderThickness="0,1,0,0">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding [geo_script_test_input], Source={x:Static lg:LanguageService.Instance}, FallbackValue=测试输入：}" 
                                       FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" Style="{StaticResource FieldInputStyle}" 
                                     Text="{Binding TestInputText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding [geo_tooltip_test_input_eg], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: 45.2, 0.8, 12.3'}"
                                     MinHeight="32" FontSize="12" VerticalAlignment="Center"/>

                            <Button Grid.Column="2" Content="{Binding [geo_script_run_test], Source={x:Static lg:LanguageService.Instance}, FallbackValue=运行测试}"
                                    Command="{Binding TestScriptCommand}" Margin="8,0"
                                    FontSize="12" Padding="12,4" Cursor="Hand" VerticalAlignment="Center"
                                    Background="#E8F4FD" Foreground="#0078D4" BorderBrush="#B3D9F2" BorderThickness="1">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#D0EAFB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock Grid.Column="3" Text="{Binding [geo_script_result], Source={x:Static lg:LanguageService.Instance}, FallbackValue=结果：}" 
                                       FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="8,0,8,0"/>
                            <TextBlock Grid.Column="4" Text="{Binding TestResultText}" FontSize="12" VerticalAlignment="Center"
                                       FontFamily="Consolas" TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#D13438"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTestSuccess}" Value="True">
                                                <Setter Property="Foreground" Value="#107C10"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
            <Grid Margin="0,0,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <!-- 官方温压计只读提示 -->
            <Border Grid.Row="0" Background="#FFF8E1" BorderBrush="#FFE082" BorderThickness="1" CornerRadius="6"
                    Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="#F9A825" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock FontSize="12" Foreground="#795548" VerticalAlignment="Center"
                               Text="{Binding [geo_editor_readonly_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=官方温压计的基本信息、公式脚本和帮助文档仅可查看与复制，不可修改。}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">

            <!-- ========== Step 0: 基本信息 ========== -->
            <Border Background="White" CornerRadius="8" Padding="20,18" BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Name, Category, Year -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=名称 *}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsContentReadOnly}"/>
                            <TextBlock Style="{StaticResource FieldHintStyle}" Text="{Binding [geo_example_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=例如：石英温压计}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_category], Source={x:Static lg:LanguageService.Instance}, FallbackValue=类别 *}"/>
                            <hc:ComboBox ItemsSource="{Binding CategoryOptions}"
                                         DisplayMemberPath="DisplayName"
                                         SelectedValuePath="Key"
                                         SelectedValue="{Binding SelectedCategory}">
                                <hc:ComboBox.Style>
                                    <Style TargetType="ComboBox" BasedOn="{StaticResource EditorFieldComboBoxStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsContentReadOnly}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </hc:ComboBox.Style>
                            </hc:ComboBox>
                            <TextBlock Style="{StaticResource FieldHintStyle}" Text="{Binding [geo_example_category], Source={x:Static lg:LanguageService.Instance}, FallbackValue=例如：单矿物温压计}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_year], Source={x:Static lg:LanguageService.Instance}, FallbackValue=年份 *}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsContentReadOnly}"/>
                            <TextBlock Style="{StaticResource FieldHintStyle}" Text="{Binding [geo_example_year], Source={x:Static lg:LanguageService.Instance}, FallbackValue=例如：2020}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 0.5: Tags -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_tags], Source={x:Static lg:LanguageService.Instance}, FallbackValue=温压计标签 *}"/>
                        <ItemsControl ItemsSource="{Binding TagParts}" Margin="0,0,0,6">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#E8F4FD" BorderBrush="#B3D9F2" BorderThickness="1"
                                            CornerRadius="4" Padding="8,3" Margin="0,0,6,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="11" Foreground="#0078D4" VerticalAlignment="Center"/>
                                            <Button Tag="{Binding}" Click="RemoveTag_Click" Margin="6,0,0,0"
                                                    Cursor="Hand" Background="Transparent" BorderThickness="0"
                                                    Padding="0" Width="14" Height="14"
                                                    Visibility="{Binding DataContext.IsContentReadOnly, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityReConverter}}">
                                                <TextBlock Text="✕" FontSize="9" FontWeight="Bold" Foreground="#0078D4"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityReConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <hc:ComboBox x:Name="TagCombo"
                                         Grid.Column="0"
                                         IsEditable="True"
                                         StaysOpenOnEdit="True"
                                         hc:InfoElement.Placeholder="{Binding [geo_tag_enter_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=输入标签后按 Enter 确认}"
                                         DisplayMemberPath="DisplayName"
                                         SelectedValuePath="DisplayName"
                                         SelectionChanged="TagCombo_SelectionChanged"
                                         PreviewKeyDown="TagCombo_PreviewKeyDown"
                                         Style="{StaticResource EditorFieldComboBoxStyle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding [geo_tag_enter_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=输入标签后按 Enter 确认}"
                                       VerticalAlignment="Center"
                                       Foreground="#AAA"
                                       Margin="16,0,0,0"
                                       FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                        <TextBlock Style="{StaticResource FieldHintStyle}" Text="{Binding [geo_example_tag], Source={x:Static lg:LanguageService.Instance}, FallbackValue=例如：石英}"/>
                    </StackPanel>

                    <!-- Row 1: Author, FormulaName -->
                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_author], Source={x:Static lg:LanguageService.Instance}, FallbackValue=作者 *}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsContentReadOnly}"/>
                            <TextBlock Style="{StaticResource FieldHintStyle}" Text="{Binding [geo_example_author], Source={x:Static lg:LanguageService.Instance}, FallbackValue=例如：Smith 等}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_formula_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=公式名称 *}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding FormulaName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding [geo_tooltip_formula_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=仅限字母、数字和下划线，如 MyFormula_v1}"
                                     IsReadOnly="{Binding IsContentReadOnly}"/>
                            <TextBlock Style="{StaticResource FieldHintStyle}" Text="{Binding [geo_example_formula_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=例如：MyFormula_v1}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Reference -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_reference], Source={x:Static lg:LanguageService.Instance}, FallbackValue=参考文献 *}"/>
                        <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsContentReadOnly}"/>
                        <TextBlock Style="{StaticResource FieldHintStyle}" Text="{Binding [geo_example_reference], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如：Smith (2020) Geochim. Cosmochim. Acta 280, 123-145'}"/>
                    </StackPanel>

                    <!-- Row 3: Version (left: app version, right: set thermometer version) -->
                    <Border Grid.Row="4" Background="#FAFAFC" BorderBrush="#E4E4E8" BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_version], Source={x:Static lg:LanguageService.Instance}, FallbackValue=版本}" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 左侧：当前软件版本 -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="11" Foreground="#86868B" Margin="0,0,0,4"
                                               Text="{Binding [geo_current_app_format_version], Source={x:Static lg:LanguageService.Instance}, FallbackValue=当前软件温压计版本}"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1D1D1F"
                                               Text="{Binding AppFormatVersion, Mode=OneWay}"/>

                                    <StackPanel Margin="0,10,0,0"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock FontSize="11" Foreground="#86868B" Margin="0,0,0,4"
                                                   Text="{Binding [geo_current_template_version], Source={x:Static lg:LanguageService.Instance}, FallbackValue=当前温压计模板版本}"/>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1D1D1F"
                                                   Text="{Binding OriginalTemplateVersion, Mode=OneWay}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 右侧：设定温压计版本 -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="11" Foreground="#86868B" Margin="0,0,0,4"
                                               Text="{Binding [geo_editor_set_version], Source={x:Static lg:LanguageService.Instance}, FallbackValue=设定温压计版本}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0"
                                                   Foreground="#666"
                                                   FontSize="12"
                                                   Text="{Binding FormatVersionPrefix, Mode=OneWay}"/>
                                        <TextBox Grid.Column="1"
                                                 Style="{StaticResource FieldInputStyle}"
                                                 Text="{Binding PatchVersion, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{Binding [geo_tooltip_version_patch], Source={x:Static lg:LanguageService.Instance}, FallbackValue=修订号 z；格式基线 x.y 跟随程序版本}"
                                                 IsReadOnly="{Binding IsContentReadOnly}"/>
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"
                                                   FontSize="11"
                                                   Foreground="#86868B">
                                            <Run Text="{Binding [diagram_editor_saved_version], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay, FallbackValue=保存后版本：}"/>
                                            <Run Text="{Binding TemplateVersion, Mode=OneWay}" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Style="{StaticResource FieldHintStyle}" Margin="0,4,0,0"
                                               Text="{Binding [geo_tooltip_version_patch], Source={x:Static lg:LanguageService.Instance}, FallbackValue=修订号 z；格式基线 x.y 跟随程序版本}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Row 4: Preview -->
                    <StackPanel Grid.Row="5" Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_preview_title], Source={x:Static lg:LanguageService.Instance}, FallbackValue=效果预览}"/>
                        <TextBlock FontSize="10" Foreground="#888" Margin="0,0,0,8"
                                   Text="{Binding [geo_preview_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=根据上方元数据实时生成，分别预览左侧列表项和右侧详情顶部的显示效果。}"/>

                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_preview_list_item], Source={x:Static lg:LanguageService.Instance}, FallbackValue=温压计列表项预览}"/>
                        <Border Background="#FAFAFC" BorderBrush="#E4E4E8" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,0,10">
                            <Border Background="Transparent" CornerRadius="6" Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding PreviewName, Mode=OneWay}" FontSize="13" Foreground="#333"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding PreviewMetaLine, Mode=OneWay}" FontSize="11" Foreground="#888"
                                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="4" Background="#FFF3E0" Padding="5,2"
                                            VerticalAlignment="Center" Margin="4,0,0,0">
                                        <TextBlock Text="{Binding [geo_label_custom_chip],Source={x:Static lg:LanguageService.Instance}, FallbackValue=自定义}"
                                                   FontSize="9" Foreground="#E65100"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Border>

                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_preview_detail_header], Source={x:Static lg:LanguageService.Instance}, FallbackValue=右侧顶部预览}"/>
                        <Border Background="#FAFAFC" BorderBrush="#E4E4E8" BorderThickness="1" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="{Binding PreviewName, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Foreground="#333"/>
                                <TextBlock FontSize="12" Foreground="#666" Margin="0,4,0,0"
                                           Text="{Binding PreviewReference, Mode=OneWay}" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <ItemsControl ItemsSource="{Binding PreviewTags, Mode=OneWay}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Background="#E8F4FD" Padding="8,3" Margin="0,0,6,0">
                                                    <TextBlock FontSize="11" Foreground="#0078D4" Text="{Binding Mode=OneWay}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border CornerRadius="4" Background="#F0F0F0" Padding="8,3" Margin="0,0,6,0">
                                        <TextBlock FontSize="11" Foreground="#555">
                                            <Run Text="v"/>
                                            <Run Text="{Binding PreviewVersion, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Border>
                                    <Border CornerRadius="4" Background="#FFF3E0" Padding="8,3">
                                        <TextBlock FontSize="11" Foreground="#E65100"
                                                   Text="{Binding [geo_label_custom_chip],Source={x:Static lg:LanguageService.Instance}, FallbackValue=自定义}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Row 5: Hint -->
                    <TextBlock Grid.Row="6" FontSize="11" Foreground="#999" Margin="0,4,0,0"
                               Text="{Binding [geo_field_required_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=必填字段标有 *。格式基线 x.y 跟随软件温压计版本，修订号 z 为模板内容版本。公式名称将作为 ReoGrid 中的自定义函数名称注册。}"/>
                </Grid>
            </Border>

            <!-- ========== Step 2: 帮助文档 ========== -->
            <Border Background="White" CornerRadius="8" Padding="0" BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 语言管理栏 -->
                    <Border Grid.Row="0" Background="#F8F8FA" Padding="14,10" CornerRadius="8,8,0,0"
                            BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding [geo_help_current_lang], Source={x:Static lg:LanguageService.Instance}, FallbackValue=当前语言：}" FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding AddedLanguageOptions}" 
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding SelectedLanguage}" 
                                      Width="140" VerticalAlignment="Center"/>

                            <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="14,0"
                                       Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityReConverter}}"/>

                            <TextBlock Text="{Binding [geo_help_add_lang], Source={x:Static lg:LanguageService.Instance}, FallbackValue=添加语言：}" FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"
                                       Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityReConverter}}"/>
                            <ComboBox ItemsSource="{Binding AvailableLanguageOptions}" 
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding NewLanguageToAdd}" 
                                      Width="140" VerticalAlignment="Center"
                                      Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityReConverter}}"/>
                            <Button Style="{StaticResource LangActionButtonStyle}" 
                                    Command="{Binding AddLanguageCommand}" Margin="6,0,0,0"
                                    ToolTip="{Binding [geo_help_add_doc], Source={x:Static lg:LanguageService.Instance}, FallbackValue=添加该语言的帮助文档}"
                                    Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityReConverter}}">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#0078D4"/>
                            </Button>
                            <Button Style="{StaticResource LangActionButtonStyle}" 
                                    Command="{Binding RemoveLanguageCommand}" Margin="4,0,0,0"
                                    ToolTip="{Binding [geo_help_delete_doc], Source={x:Static lg:LanguageService.Instance}, FallbackValue=删除当前语言的帮助文档}"
                                    Visibility="{Binding IsContentReadOnly, Converter={StaticResource BooleanToVisibilityReConverter}}">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#D13438"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 当有语言选中时：显示格式工具栏（只读模式隐藏） -->
                    <Border Grid.Row="1" Background="White" Padding="12,6" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLanguage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsContentReadOnly}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource FormatButtonStyle}" Click="BoldButton_Click" ToolTip="{Binding [geo_help_bold], Source={x:Static lg:LanguageService.Instance}, FallbackValue=加粗 (Ctrl+B)}">
                                <TextBlock Text="B" FontWeight="Bold" FontSize="13"/>
                            </Button>
                            <Button Style="{StaticResource FormatButtonStyle}" Click="ItalicButton_Click" Margin="4,0,0,0" ToolTip="{Binding [geo_help_italic], Source={x:Static lg:LanguageService.Instance}, FallbackValue=斜体 (Ctrl+I)}">
                                <TextBlock Text="I" FontStyle="Italic" FontSize="13"/>
                            </Button>
                            <Button Style="{StaticResource FormatButtonStyle}" Click="UnderlineButton_Click" Margin="4,0,0,0" ToolTip="{Binding [geo_help_underline], Source={x:Static lg:LanguageService.Instance}, FallbackValue=下划线 (Ctrl+U)}">
                                <TextBlock Text="U" FontSize="13" TextDecorations="Underline"/>
                            </Button>

                            <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="10,0"/>

                            <TextBlock Text="{Binding [geo_help_font_size], Source={x:Static lg:LanguageService.Instance}, FallbackValue=字号：}" FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="FontSizeComboBox" Width="65" SelectedIndex="1" IsEditable="True"
                                      SelectionChanged="FontSizeComboBox_SelectionChanged">
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="12"/>
                                <ComboBoxItem Content="14"/>
                                <ComboBoxItem Content="16"/>
                                <ComboBoxItem Content="18"/>
                                <ComboBoxItem Content="20"/>
                                <ComboBoxItem Content="24"/>
                                <ComboBoxItem Content="28"/>
                                <ComboBoxItem Content="36"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- RichTextBox 编辑器 -->
                    <RichTextBox Grid.Row="2" x:Name="HelpDocEditor" 
                                 Padding="16,12" BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 AcceptsTab="True"
                                 IsReadOnly="{Binding IsContentReadOnly}">
                        <RichTextBox.Style>
                            <Style TargetType="RichTextBox">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLanguage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RichTextBox.Style>
                        <RichTextBox.Resources>
                            <Style TargetType="{x:Type FlowDocument}">
                                <Setter Property="ColumnWidth" Value="999999"/>
                                <Setter Property="PagePadding" Value="10"/>
                            </Style>
                        </RichTextBox.Resources>
                        <FlowDocument/>
                    </RichTextBox>

                    <!-- 无语言时的提示 -->
                    <StackPanel Grid.Row="1" Grid.RowSpan="2" 
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLanguage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="36" 
                                   Foreground="#CCC" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding [geo_help_no_lang_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=请点击上方的 + 按钮添加语言，然后编辑帮助文档。}" 
                                   FontSize="14" Foreground="#999" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding [geo_help_optional_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=帮助文档为可选内容，支持多语言 RTF 富文本格式。}" 
                                   FontSize="12" Foreground="#BBB" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            </Grid>
            </Grid>
            </ScrollViewer>
            </Grid>

            <!-- ==================== 底部：步骤条 + 操作按钮栏 ==================== -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16,12" Margin="0,12,0,0"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <DockPanel>
                    <!-- 左侧：上一步（step > 0 时显示） -->
                    <Button DockPanel.Dock="Left" Command="{Binding PrevStepCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource EditorButtonStyle}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding [geo_btn_prev], Source={x:Static lg:LanguageService.Instance}, FallbackValue=上一步}" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- 右侧：导航和保存按钮 -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">

                        <!-- 下一步（step < 2 时显示） -->
                        <Button Command="{Binding NextStepCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryEditorButtonStyle}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding [geo_btn_next], Source={x:Static lg:LanguageService.Instance}, FallbackValue=下一步}" FontSize="13"/>
                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                        </Button>

                        <!-- 保存并导出 ZIP（step == 2 时显示，只读模式隐藏） -->
                        <Button Command="{Binding SaveAndExportCommand}" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource EditorButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding CurrentStep}" Value="2"/>
                                            <Condition Binding="{Binding IsContentReadOnly}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE78C;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding [geo_btn_save_export_zip], Source={x:Static lg:LanguageService.Instance}, FallbackValue=保存并导出 ZIP}" FontSize="13"/>
                        </StackPanel>
                        </Button>

                        <!-- 保存（step == 2 时显示，只读模式隐藏） -->
                        <Button Command="{Binding SaveCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryEditorButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding CurrentStep}" Value="2"/>
                                            <Condition Binding="{Binding IsContentReadOnly}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" 
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding [geo_btn_save], Source={x:Static lg:LanguageService.Instance}, FallbackValue=保存}" FontSize="13"/>
                        </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 中间：步骤条 -->
                    <hc:StepBar StepIndex="{Binding CurrentStep, Mode=OneWay}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="20,0">
                        <hc:StepBarItem Content="{Binding [geo_step_basic], Source={x:Static lg:LanguageService.Instance}, FallbackValue=基本信息}"/>
                        <hc:StepBarItem Content="{Binding [geo_step_script], Source={x:Static lg:LanguageService.Instance}, FallbackValue=公式脚本}"/>
                        <hc:StepBarItem Content="{Binding [geo_step_help_doc], Source={x:Static lg:LanguageService.Instance}, FallbackValue=帮助文档}"/>
                    </hc:StepBar>
                </DockPanel>
            </Border>
        </Grid>

        <ScrollViewer VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,20,20,0"
                      MaxHeight="650" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly"
                      IsHitTestVisible="True" BorderThickness="0" Background="Transparent">
            <ItemsControl ItemsSource="{Binding ElementName=RootWindow, Path=LocalNotifications}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:NotificationItem/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
