<Window x:Class="GeoChemistryNexus.Views.GeothermometerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:GeoChemistryNexus.ViewModels"
        xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
        mc:Ignorable="d"
        Title="{Binding EditorTitle}"
        Height="780" Width="960"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        Background="#F5F5F7">

    <Window.Resources>
        <!-- 标签样式 -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="FieldInputStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 多行输入框样式 -->
        <Style x:Key="MultiLineInputStyle" TargetType="TextBox" BasedOn="{StaticResource FieldInputStyle}">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Top"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="EditorButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryEditorButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorButtonStyle}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 格式化工具栏按钮样式 -->
        <Style x:Key="FormatButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D1D1D1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 语言管理小按钮样式 -->
        <Style x:Key="LangActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==================== StepBar ==================== -->
        <hc:StepBar Grid.Row="0" StepIndex="{Binding CurrentStep, Mode=OneWay}" Margin="40,0,40,16">
            <hc:StepBarItem Content="{Binding [geo_step_basic], Source={x:Static lg:LanguageService.Instance}, FallbackValue=基本信息}"/>
            <hc:StepBarItem Content="{Binding [geo_step_script], Source={x:Static lg:LanguageService.Instance}, FallbackValue=公式脚本}"/>
            <hc:StepBarItem Content="{Binding [geo_step_help_doc], Source={x:Static lg:LanguageService.Instance}, FallbackValue=帮助文档}"/>
        </hc:StepBar>

        <!-- ==================== 内容区域 ==================== -->
        <Grid Grid.Row="1">

            <!-- ========== Step 0: 基本信息 ========== -->
            <Border Background="White" CornerRadius="8" Padding="20,18" BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Name, Mineral, Year, Version -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=名称 *}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_mineral_category], Source={x:Static lg:LanguageService.Instance}, FallbackValue=矿物分类 *}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding Mineral, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_year], Source={x:Static lg:LanguageService.Instance}, FallbackValue=年份 *}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_version], Source={x:Static lg:LanguageService.Instance}, FallbackValue=版本 *}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding [geo_tooltip_version_format], Source={x:Static lg:LanguageService.Instance}, FallbackValue=语义化版本号，如 1.0.0、1.2.3}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 1: Author, FormulaName, WorksheetName -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_author], Source={x:Static lg:LanguageService.Instance}, FallbackValue=作者 *}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_formula_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=公式名称 *}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding FormulaName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding [geo_tooltip_formula_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=仅限字母、数字和下划线，如 MyFormula_v1}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_worksheet_name], Source={x:Static lg:LanguageService.Instance}, FallbackValue=工作表名称}"/>
                            <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding WorksheetName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Reference -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_reference], Source={x:Static lg:LanguageService.Instance}, FallbackValue=参考文献 *}"/>
                        <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Row 3: Description -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_field_description], Source={x:Static lg:LanguageService.Instance}, FallbackValue=简要描述}"/>
                        <TextBox Style="{StaticResource MultiLineInputStyle}" Height="80"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Row 4: Hint -->
                    <TextBlock Grid.Row="4" FontSize="11" Foreground="#999" Margin="0,4,0,0"
                               Text="{Binding [geo_field_required_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=必填字段标有 *。版本号格式为 x.x.x（如 1.0.0）。公式名称将作为 ReoGrid 中的自定义函数名称注册。}"/>
                </Grid>
            </Border>

            <!-- ========== Step 1: 公式脚本 ========== -->
            <Border Background="White" CornerRadius="8" Padding="0" BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 表格定义区 -->
                    <Border Grid.Row="0" Padding="16,14" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_script_headers], Source={x:Static lg:LanguageService.Instance}, FallbackValue=表头 *（逗号分隔）}"/>
                                <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding HeadersText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding [geo_tooltip_headers], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: SiO2, TiO2, Al2O3, T(K)'}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_script_sample_row], Source={x:Static lg:LanguageService.Instance}, FallbackValue=示例行（逗号分隔）}"/>
                                <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding ExampleRowText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding [geo_tooltip_sample_row_eg], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: 45.2, 0.8, 12.3, =MyFormula(A2,B2,C2)'}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding [geo_script_inputs], Source={x:Static lg:LanguageService.Instance}, FallbackValue=输入列（逗号分隔）}"/>
                                <TextBox Style="{StaticResource FieldInputStyle}" Text="{Binding InputColumnsText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding [geo_tooltip_inputs_eg], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: SiO2, TiO2, Al2O3'}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 脚本标题栏 -->
                    <Border Grid.Row="1" Background="#F8F8FA" Padding="14,10"
                            BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                       Foreground="#0078D4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [geo_script_javascript], Source={x:Static lg:LanguageService.Instance}, FallbackValue=JavaScript 脚本}" FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="  calculate(args) + calculateDetailed(inputs)" 
                                       FontSize="11" Foreground="#999" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 脚本编辑器 -->
                    <TextBox Grid.Row="2" 
                             Text="{Binding ScriptContent, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas, Courier New" FontSize="13"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" BorderThickness="0" Padding="14,10"
                             Background="White"/>

                    <!-- 测试栏 -->
                    <Border Grid.Row="3" Background="#F8F8FA" Padding="14,8" CornerRadius="0,0,8,8"
                            BorderBrush="#E8E8E8" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding [geo_script_test_input], Source={x:Static lg:LanguageService.Instance}, FallbackValue=测试输入：}" 
                                       FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1" Style="{StaticResource FieldInputStyle}" 
                                     Text="{Binding TestInputText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding [geo_tooltip_test_input_eg], Source={x:Static lg:LanguageService.Instance}, FallbackValue='例如: 45.2, 0.8, 12.3'}" Height="28" FontSize="12"/>

                            <Button Grid.Column="2" Content="{Binding [geo_script_run_test], Source={x:Static lg:LanguageService.Instance}, FallbackValue=运行测试}"
                                    Command="{Binding TestScriptCommand}" Margin="8,0"
                                    FontSize="12" Padding="12,4" Cursor="Hand"
                                    Background="#E8F4FD" Foreground="#0078D4" BorderBrush="#B3D9F2" BorderThickness="1">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#D0EAFB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock Grid.Column="3" Text="{Binding [geo_script_result], Source={x:Static lg:LanguageService.Instance}, FallbackValue=结果：}" 
                                       FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="8,0,8,0"/>
                            <TextBlock Grid.Column="4" Text="{Binding TestResultText}" FontSize="12" VerticalAlignment="Center"
                                       FontFamily="Consolas" TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#D13438"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTestSuccess}" Value="True">
                                                <Setter Property="Foreground" Value="#107C10"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ========== Step 2: 帮助文档 ========== -->
            <Border Background="White" CornerRadius="8" Padding="0" BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 语言管理栏 -->
                    <Border Grid.Row="0" Background="#F8F8FA" Padding="14,10" CornerRadius="8,8,0,0"
                            BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding [geo_help_current_lang], Source={x:Static lg:LanguageService.Instance}, FallbackValue=当前语言：}" FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding AddedLanguages}" 
                                      SelectedItem="{Binding SelectedLanguage}" 
                                      Width="110" VerticalAlignment="Center"/>

                            <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="14,0"/>

                            <TextBlock Text="{Binding [geo_help_add_lang], Source={x:Static lg:LanguageService.Instance}, FallbackValue=添加语言：}" FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{x:Static vm:GeothermometerEditorViewModel.AllLanguageCodes}" 
                                      SelectedItem="{Binding NewLanguageToAdd}" 
                                      Width="110" VerticalAlignment="Center"/>
                            <Button Style="{StaticResource LangActionButtonStyle}" 
                                    Command="{Binding AddLanguageCommand}" Margin="6,0,0,0"
                                    ToolTip="{Binding [geo_help_add_doc], Source={x:Static lg:LanguageService.Instance}, FallbackValue=添加该语言的帮助文档}">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#0078D4"/>
                            </Button>
                            <Button Style="{StaticResource LangActionButtonStyle}" 
                                    Command="{Binding RemoveLanguageCommand}" Margin="4,0,0,0"
                                    ToolTip="{Binding [geo_help_delete_doc], Source={x:Static lg:LanguageService.Instance}, FallbackValue=删除当前语言的帮助文档}">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#D13438"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 当有语言选中时：显示格式工具栏和编辑器 -->
                    <Border Grid.Row="1" Background="White" Padding="12,6" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLanguage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource FormatButtonStyle}" Click="BoldButton_Click" ToolTip="{Binding [geo_help_bold], Source={x:Static lg:LanguageService.Instance}, FallbackValue=加粗 (Ctrl+B)}">
                                <TextBlock Text="B" FontWeight="Bold" FontSize="13"/>
                            </Button>
                            <Button Style="{StaticResource FormatButtonStyle}" Click="ItalicButton_Click" Margin="4,0,0,0" ToolTip="{Binding [geo_help_italic], Source={x:Static lg:LanguageService.Instance}, FallbackValue=斜体 (Ctrl+I)}">
                                <TextBlock Text="I" FontStyle="Italic" FontSize="13"/>
                            </Button>
                            <Button Style="{StaticResource FormatButtonStyle}" Click="UnderlineButton_Click" Margin="4,0,0,0" ToolTip="{Binding [geo_help_underline], Source={x:Static lg:LanguageService.Instance}, FallbackValue=下划线 (Ctrl+U)}">
                                <TextBlock Text="U" FontSize="13" TextDecorations="Underline"/>
                            </Button>

                            <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="10,0"/>

                            <TextBlock Text="{Binding [geo_help_font_size], Source={x:Static lg:LanguageService.Instance}, FallbackValue=字号：}" FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="FontSizeComboBox" Width="65" SelectedIndex="1" IsEditable="True"
                                      SelectionChanged="FontSizeComboBox_SelectionChanged">
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="12"/>
                                <ComboBoxItem Content="14"/>
                                <ComboBoxItem Content="16"/>
                                <ComboBoxItem Content="18"/>
                                <ComboBoxItem Content="20"/>
                                <ComboBoxItem Content="24"/>
                                <ComboBoxItem Content="28"/>
                                <ComboBoxItem Content="36"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- RichTextBox 编辑器 -->
                    <RichTextBox Grid.Row="2" x:Name="HelpDocEditor" 
                                 Padding="16,12" BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 AcceptsTab="True">
                        <RichTextBox.Style>
                            <Style TargetType="RichTextBox">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLanguage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RichTextBox.Style>
                        <RichTextBox.Resources>
                            <Style TargetType="{x:Type FlowDocument}">
                                <Setter Property="ColumnWidth" Value="999999"/>
                                <Setter Property="PagePadding" Value="10"/>
                            </Style>
                        </RichTextBox.Resources>
                        <FlowDocument/>
                    </RichTextBox>

                    <!-- 无语言时的提示 -->
                    <StackPanel Grid.Row="1" Grid.RowSpan="2" 
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLanguage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="36" 
                                   Foreground="#CCC" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding [geo_help_no_lang_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=请点击上方的 + 按钮添加语言，然后编辑帮助文档。}" 
                                   FontSize="14" Foreground="#999" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding [geo_help_optional_hint], Source={x:Static lg:LanguageService.Instance}, FallbackValue=帮助文档为可选内容，支持多语言 RTF 富文本格式。}" 
                                   FontSize="12" Foreground="#BBB" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== 底部：操作按钮栏 ==================== -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="16,12" Margin="0,12,0,0"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <!-- 左侧：取消 -->
                <Button DockPanel.Dock="Left" Style="{StaticResource EditorButtonStyle}" 
                        Command="{Binding CancelCommand}" Content="{Binding [geo_btn_cancel], Source={x:Static lg:LanguageService.Instance}, FallbackValue=取消}"/>

                <!-- 右侧：导航和保存按钮 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">

                    <!-- 上一步（step > 0 时显示） -->
                    <Button Command="{Binding PrevStepCommand}" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource EditorButtonStyle}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding [geo_btn_prev], Source={x:Static lg:LanguageService.Instance}, FallbackValue=上一步}" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- 下一步（step < 2 时显示） -->
                    <Button Command="{Binding NextStepCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryEditorButtonStyle}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding [geo_btn_next], Source={x:Static lg:LanguageService.Instance}, FallbackValue=下一步}" FontSize="13"/>
                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- 保存并导出 ZIP（step == 2 时显示） -->
                    <Button Command="{Binding SaveAndExportCommand}" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource EditorButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE78C;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding [geo_btn_save_export_zip], Source={x:Static lg:LanguageService.Instance}, FallbackValue=保存并导出 ZIP}" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- 保存（step == 2 时显示） -->
                    <Button Command="{Binding SaveCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryEditorButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" 
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding [geo_btn_save], Source={x:Static lg:LanguageService.Instance}, FallbackValue=保存}" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
