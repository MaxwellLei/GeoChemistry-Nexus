<Window x:Class="GeoChemistryNexus.Views.GeothermometerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:GeoChemistryNexus.Controls"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="{Binding EditorTitle}"
        Height="720" Width="1180"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        Background="#F5F5F7">

    <Grid>
        <controls:GeothermometerEditorControl x:Name="EditorControl" DataContext="{Binding}"/>

        <ScrollViewer VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,16,16,0"
                      MaxHeight="480" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly"
                      IsHitTestVisible="True" BorderThickness="0" Background="Transparent">
            <ItemsControl ItemsSource="{Binding ElementName=RootWindow, Path=LocalNotifications}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:NotificationItem/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
