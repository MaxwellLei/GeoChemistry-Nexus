<Window x:Class="GeoChemistryNexus.Views.GeothermometerFreeSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rg="clr-namespace:unvell.ReoGrid;assembly=unvell.ReoGrid"
        xmlns:hp="clr-namespace:GeoChemistryNexus.Helpers"
        xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
        xmlns:controls="clr-namespace:GeoChemistryNexus.Controls"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="{Binding WindowTitle}"
        Width="1200" Height="720"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">

    <Window.Resources>
        <FontFamily x:Key="IconFont">pack://application:,,,/Data/Icon/#iconfont</FontFamily>
        <hp:BindingProxy x:Key="GridProxy" Data="{Binding ElementName=FreeReoGrid}" />

        <Style x:Key="ToolbarGroupBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#D8D8D8"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="ToolbarGroupLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="ToolbarButtonIconStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E5E5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D1D1D1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D0E8FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E5E5"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#B8DAFF"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarTextButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}" ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E5E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Home 工具栏 -->
        <Border Grid.Row="0" Background="#F9F9F9" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,6">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">

                    <!-- 编辑 -->
                    <Border Style="{StaticResource ToolbarGroupBorderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding UndoCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [undo], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding RedoCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [redo], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                </Button>
                                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                                              IsChecked="{Binding IsFormatPainterActive, Mode=TwoWay}"
                                              Command="{Binding ToggleFormatPainterCommand}"
                                              CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                              ToolTip="{Binding [geo_free_sheet_format_painter], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe6bb;" FontSize="14"/>
                                </ToggleButton>
                            </StackPanel>
                            <TextBlock Style="{StaticResource ToolbarGroupLabelStyle}"
                                       Text="{Binding [geo_free_sheet_group_edit], Source={x:Static lg:LanguageService.Instance}}"/>
                        </StackPanel>
                    </Border>

                    <!-- 字体 -->
                    <Border Style="{StaticResource ToolbarGroupBorderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <controls:FontFamilyControl Width="140" Margin="0,0,2,0" VerticalAlignment="Center"
                                                            FontFamilyName="{Binding SelectedFontName, Mode=TwoWay}"
                                                            ToolTip="{Binding [font_name], Source={x:Static lg:LanguageService.Instance}}"/>
                                <controls:FontSizeControl Width="64" Margin="2,0" VerticalAlignment="Center"
                                                          FontSizeValue="{Binding SelectedFontSize, Mode=TwoWay}"
                                                          ToolTip="{Binding [FontSize], Source={x:Static lg:LanguageService.Instance}}"/>
                                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                                              IsChecked="{Binding IsBold, Mode=OneWay}"
                                              Command="{Binding ToggleBoldCommand}"
                                              CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                              ToolTip="{Binding [geo_help_bold], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe7ed;" FontSize="14"/>
                                </ToggleButton>
                                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                                              IsChecked="{Binding IsItalic, Mode=OneWay}"
                                              Command="{Binding ToggleItalicCommand}"
                                              CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                              ToolTip="{Binding [geo_free_sheet_italic], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe7ee;" FontSize="14"/>
                                </ToggleButton>
                                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                                              IsChecked="{Binding IsUnderline, Mode=OneWay}"
                                              Command="{Binding ToggleUnderlineCommand}"
                                              CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                              ToolTip="{Binding [geo_free_sheet_underline], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe7f0;" FontSize="14"/>
                                </ToggleButton>
                                <controls:ToolbarColorButton Margin="2,0,0,0"
                                                             IconFontFamily="{StaticResource IconFont}"
                                                             IconText="&#xe7ef;"
                                                             SelectedColor="{Binding SelectedTextColor, Mode=TwoWay}"
                                                             ToolTip="{Binding [font_color], Source={x:Static lg:LanguageService.Instance}}"/>
                                <controls:ToolbarColorButton Margin="2,0,0,0"
                                                             IconFontFamily="{StaticResource IconFont}"
                                                             IconText="&#xe7eb;"
                                                             SelectedColor="{Binding SelectedFillColor, Mode=TwoWay}"
                                                             ToolTip="{Binding [geo_free_sheet_fill_color], Source={x:Static lg:LanguageService.Instance}}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource ToolbarGroupLabelStyle}"
                                       Text="{Binding [geo_free_sheet_group_font], Source={x:Static lg:LanguageService.Instance}}"/>
                        </StackPanel>
                    </Border>

                    <!-- 对齐 -->
                    <Border Style="{StaticResource ToolbarGroupBorderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding AlignLeftCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [geo_free_sheet_align_left], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock Text="&#xE8E4;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding AlignCenterCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [geo_free_sheet_align_center], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock Text="&#xE8E3;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding AlignRightCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [geo_free_sheet_align_right], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock Text="&#xE8E2;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding MergeCellsCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [geo_free_sheet_merge], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe780;" FontSize="14"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource ToolbarGroupLabelStyle}"
                                       Text="{Binding [geo_free_sheet_group_align], Source={x:Static lg:LanguageService.Instance}}"/>
                        </StackPanel>
                    </Border>

                    <!-- 单元格 -->
                    <Border Style="{StaticResource ToolbarGroupBorderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding AddRowUpCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [data_toolbar_add_row_above_tooltip], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe615;" FontSize="14"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding AddRowDownCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [data_toolbar_add_row_below_tooltip], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe613;" FontSize="14"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding DeleteRowCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [data_toolbar_delete_row_tooltip], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe89f;" FontSize="14" Foreground="#D92C2C"/>
                                </Button>
                                <Rectangle Width="1" Height="20" Fill="#D0D0D0" Margin="4,0"/>
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding AddColumnLeftCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [geo_free_sheet_insert_col_left], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe611;" FontSize="14"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding AddColumnRightCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [geo_free_sheet_insert_col_right], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe610;" FontSize="14"/>
                                </Button>
                                <Button Style="{StaticResource ToolbarButtonIconStyle}"
                                        Command="{Binding DeleteColumnCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        ToolTip="{Binding [geo_free_sheet_delete_col], Source={x:Static lg:LanguageService.Instance}}">
                                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xe907;" FontSize="14" Foreground="#D92C2C"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource ToolbarGroupLabelStyle}"
                                       Text="{Binding [geo_free_sheet_group_cells], Source={x:Static lg:LanguageService.Instance}}"/>
                        </StackPanel>
                    </Border>

                    <!-- 文件 -->
                    <Border Padding="8,6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ToolbarTextButtonStyle}"
                                        Command="{Binding ImportWorksheetCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        Content="{Binding [geo_free_sheet_import], Source={x:Static lg:LanguageService.Instance}}"/>
                                <Button Style="{StaticResource ToolbarTextButtonStyle}"
                                        Command="{Binding ExportWorksheetCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        Content="{Binding [geo_btn_export], Source={x:Static lg:LanguageService.Instance}}"/>
                                <Button Style="{StaticResource ToolbarTextButtonStyle}"
                                        Command="{Binding ClearWorksheetCommand}"
                                        CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                        Content="{Binding [geo_free_sheet_clear], Source={x:Static lg:LanguageService.Instance}}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource ToolbarGroupLabelStyle}"
                                       Text="{Binding [geo_free_sheet_group_file], Source={x:Static lg:LanguageService.Instance}}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 公式栏 -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="3" Padding="6,0">
                    <TextBlock Text="{Binding SelectedCellAddress}" VerticalAlignment="Center" FontSize="12" Foreground="#555"/>
                </Border>
                <TextBlock Grid.Column="1" Text="fx" Margin="8,0" VerticalAlignment="Center" FontStyle="Italic" Foreground="#888"/>
                <Border Grid.Column="2" Background="White" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="3" Padding="4,0">
                    <TextBox Text="{Binding SelectedCellContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsSelectedCellEditable}"
                             VerticalContentAlignment="Center"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <!-- ReoGrid -->
        <rg:ReoGridControl Grid.Row="2" x:Name="FreeReoGrid" SheetTabVisible="False">
            <rg:ReoGridControl.Resources>
                <ControlTemplate x:Key="ModernThumbTemplate" TargetType="Thumb">
                    <Border x:Name="thumbBorder" Background="#C2C3C9" CornerRadius="4" BorderThickness="0"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumbBorder" Property="Background" Value="#6E6E6E"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="thumbBorder" Property="Background" Value="#424242"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
                <Style TargetType="{x:Type ScrollBar}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="true" Focusable="false">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}" Opacity="0" Background="Transparent" BorderThickness="0" Focusable="false"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.LineDownCommand}" Opacity="0" Background="Transparent" BorderThickness="0" Focusable="false"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Template="{StaticResource ModernThumbTemplate}" Margin="1"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="Orientation" Value="Horizontal">
                                        <Setter TargetName="PART_Track" Property="Orientation" Value="Horizontal"/>
                                        <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="false"/>
                                        <Setter Property="Height" Value="10"/>
                                        <Setter Property="Width" Value="Auto"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </rg:ReoGridControl.Resources>
        </rg:ReoGridControl>

        <!-- 状态栏 -->
        <Border Grid.Row="3" Background="#F1F1F1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="10,6">
            <TextBlock Text="{Binding StatusHint}" FontSize="11" Foreground="#666"/>
        </Border>
        </Grid>

        <ScrollViewer VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,16,16,0"
                      MaxHeight="650" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly"
                      IsHitTestVisible="True" BorderThickness="0" Background="Transparent">
            <ItemsControl ItemsSource="{Binding LocalNotifications, ElementName=RootWindow}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:NotificationItem/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
