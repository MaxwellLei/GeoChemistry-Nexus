<UserControl x:Class="GeoChemistryNexus.Views.Widgets.OfficialTemplatePublisherWidget"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

             xmlns:hc="https://handyorg.github.io/handycontrol"

             xmlns:lg="clr-namespace:GeoChemistryNexus.Services"

             mc:Ignorable="d"

             d:DesignHeight="720" d:DesignWidth="920">

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>



        <hc:ScrollViewer Grid.Row="0"

                         VerticalScrollBarVisibility="Auto"

                         HorizontalScrollBarVisibility="Disabled">

            <Grid Margin="20">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>



        <TextBlock Text="{Binding [official_template_publisher], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                   FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>



        <StackPanel Grid.Row="1" Margin="0,0,0,10">

            <StackPanel Orientation="Horizontal">

                <CheckBox Content="{Binding [official_publisher_include_diagrams], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                          IsChecked="{Binding PublishDiagrams}" Margin="0,0,24,0"/>

                <CheckBox Content="{Binding [official_publisher_include_geothermometers], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                          IsChecked="{Binding PublishGeothermometers}" Margin="0,0,24,0"/>

                <CheckBox Content="{Binding [official_publisher_include_home_links], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                          IsChecked="{Binding PublishHomeLinks}" Margin="0,0,24,0"/>

                <CheckBox Content="{Binding [official_publisher_include_announcement], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                          IsChecked="{Binding PublishAnnouncement}"/>

            </StackPanel>



            <Border Margin="0,10,0,0" Padding="12" BorderBrush="#007AFF" BorderThickness="1" CornerRadius="4"

                    Background="#F8FBFF"

                    Visibility="{Binding PublishAnnouncement, Converter={StaticResource BooleanToVisibilityConverter}}">

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="140"/>

                    </Grid.RowDefinitions>



                    <DockPanel Grid.Row="0" Margin="0,0,0,6">

                        <Button DockPanel.Dock="Right"

                                Content="{Binding [official_publisher_announcement_load], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                                Command="{Binding LoadAnnouncementFromServerCommand}"

                                MinWidth="108" Margin="8,0,0,0"/>

                        <TextBlock Text="{Binding [official_publisher_announcement_section], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>

                    </DockPanel>



                    <TextBlock Grid.Row="1"

                               Text="{Binding [official_publisher_announcement_edit_hint], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                               FontSize="12" Foreground="#636366" TextWrapping="Wrap" Margin="0,0,0,8"/>



                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">

                        <TextBlock Foreground="#FF9500" Margin="0,0,12,0"

                                   Visibility="{Binding AnnouncementHasRemoteChanges, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <Run Text="{Binding [official_publisher_announcement_pending], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        </TextBlock>

                        <TextBlock Foreground="#34C759"

                                   Visibility="{Binding AnnouncementHasRemoteChanges, Converter={StaticResource BooleanToVisibilityReConverter}}">

                            <Run Text="{Binding [official_publisher_announcement_up_to_date], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        </TextBlock>

                    </StackPanel>



                    <TextBox Grid.Row="3"

                             Text="{Binding AnnouncementText, UpdateSourceTrigger=PropertyChanged}"

                             AcceptsReturn="True"

                             TextWrapping="Wrap"

                             VerticalScrollBarVisibility="Auto"

                             BorderBrush="#DDDDDD" BorderThickness="1"

                             Padding="8"

                             MinHeight="120"/>

                </Grid>

            </Border>

        </StackPanel>



        <Border Grid.Row="2" Padding="12" Margin="0,0,0,10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="100"/>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>



                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="SecretId"/>

                <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0,8,8" Text="{Binding SecretId, UpdateSourceTrigger=PropertyChanged}"/>



                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="SecretKey"/>

                <PasswordBox x:Name="SecretKeyBox" Grid.Row="1" Grid.Column="1" Margin="8,0,8,8"

                             PasswordChanged="SecretKeyBox_OnPasswordChanged"/>



                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Region"/>

                <TextBox Grid.Row="2" Grid.Column="1" Margin="8,0,8,8" Text="{Binding Region, UpdateSourceTrigger=PropertyChanged}"/>



                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Bucket"/>

                <TextBox Grid.Row="3" Grid.Column="1" Margin="8,0,8,8" Text="{Binding Bucket, UpdateSourceTrigger=PropertyChanged}"/>



                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"

                           Text="{Binding [official_publisher_staging_dir], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                <TextBox Grid.Row="4" Grid.Column="1" Margin="8,0,8,0"

                         Text="{Binding StagingDirectory, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Row="4" Grid.Column="2" Content="..."

                        Command="{Binding BrowseStagingDirectoryCommand}" MinWidth="36"/>



                <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="5" Orientation="Vertical" Margin="8,0,0,0">

                    <Button Content="{Binding [cos_save_settings], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                            Command="{Binding SaveCosSettingsCommand}" Margin="0,0,0,8" MinWidth="120"/>

                    <Button Content="{Binding [cos_test_connection], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                            Command="{Binding TestCosConnectionCommand}" IsEnabled="{Binding IsNotBusy}" MinWidth="120"/>

                </StackPanel>

            </Grid>

        </Border>



        <TabControl Grid.Row="3" Margin="0,0,0,8">

            <TabItem Header="{Binding [official_publisher_diagram_section], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}">

                <StackPanel Orientation="Horizontal" Margin="4">

                    <TextBlock Margin="0,0,16,0">

                        <Run Text="{Binding [official_publisher_new], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        <Run Text=": "/>

                        <Run Text="{Binding DiagramNewCount, Mode=OneWay}"/>

                    </TextBlock>

                    <TextBlock Margin="0,0,16,0">

                        <Run Text="{Binding [official_publisher_updated], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        <Run Text=": "/>

                        <Run Text="{Binding DiagramUpdatedCount, Mode=OneWay}"/>

                    </TextBlock>

                    <TextBlock Margin="0,0,16,0">

                        <Run Text="{Binding [official_publisher_removed], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        <Run Text=": "/>

                        <Run Text="{Binding DiagramRemovedCount, Mode=OneWay}"/>

                    </TextBlock>

                    <TextBlock>

                        <Run Text="{Binding [official_publisher_unchanged], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        <Run Text=": "/>

                        <Run Text="{Binding DiagramUnchangedCount, Mode=OneWay}"/>

                    </TextBlock>

                </StackPanel>

            </TabItem>

            <TabItem Header="{Binding [official_publisher_geothermometer_section], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}">

                <StackPanel Orientation="Horizontal" Margin="4">

                    <TextBlock Margin="0,0,16,0">

                        <Run Text="{Binding [official_publisher_new], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        <Run Text=": "/>

                        <Run Text="{Binding GeoNewCount, Mode=OneWay}"/>

                    </TextBlock>

                    <TextBlock Margin="0,0,16,0">

                        <Run Text="{Binding [official_publisher_updated], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        <Run Text=": "/>

                        <Run Text="{Binding GeoUpdatedCount, Mode=OneWay}"/>

                    </TextBlock>

                    <TextBlock Margin="0,0,16,0">

                        <Run Text="{Binding [official_publisher_removed], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        <Run Text=": "/>

                        <Run Text="{Binding GeoRemovedCount, Mode=OneWay}"/>

                    </TextBlock>

                    <TextBlock>

                        <Run Text="{Binding [official_publisher_unchanged], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        <Run Text=": "/>

                        <Run Text="{Binding GeoUnchangedCount, Mode=OneWay}"/>

                    </TextBlock>

                </StackPanel>

            </TabItem>

            <TabItem Header="{Binding [official_publisher_home_links_section], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}">

                <StackPanel Orientation="Horizontal" Margin="4">

                    <TextBlock Margin="0,0,16,0">

                        <Run Text="{Binding [official_publisher_home_groups], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        <Run Text=": "/>

                        <Run Text="{Binding HomeLinkGroupCount, Mode=OneWay}"/>

                    </TextBlock>

                    <TextBlock Margin="0,0,16,0">

                        <Run Text="{Binding [official_publisher_home_link_items], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                        <Run Text=": "/>

                        <Run Text="{Binding HomeLinkCount, Mode=OneWay}"/>

                    </TextBlock>

                    <TextBlock Foreground="#FF9500"

                               Visibility="{Binding HomeLinksHasRemoteChanges, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <Run Text="{Binding [official_publisher_home_links_pending], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                    </TextBlock>

                </StackPanel>

            </TabItem>

            <TabItem Header="{Binding [official_publisher_announcement_section], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}">

                <StackPanel Orientation="Horizontal" Margin="4">

                    <TextBlock Foreground="#FF9500"

                               Visibility="{Binding AnnouncementHasRemoteChanges, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <Run Text="{Binding [official_publisher_announcement_pending], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                    </TextBlock>

                    <TextBlock Foreground="#34C759"

                               Visibility="{Binding AnnouncementHasRemoteChanges, Converter={StaticResource BooleanToVisibilityReConverter}}">

                        <Run Text="{Binding [official_publisher_announcement_up_to_date], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>

                    </TextBlock>

                </StackPanel>

            </TabItem>

        </TabControl>



        <TabControl Grid.Row="4" Margin="0,0,0,10" MinHeight="220">

            <TabItem Header="{Binding [official_publisher_diagram_section], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}">

                <ListBox ItemsSource="{Binding DiagramPreviewLines}" BorderBrush="#EEEEEE" BorderThickness="1"/>

            </TabItem>

            <TabItem Header="{Binding [official_publisher_geothermometer_section], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}">

                <ListBox ItemsSource="{Binding GeothermometerPreviewLines}" BorderBrush="#EEEEEE" BorderThickness="1"/>

            </TabItem>

            <TabItem Header="{Binding [official_publisher_home_links_section], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}">

                <Grid Margin="4">

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">

                        <Button Content="{Binding [official_publisher_home_add_group], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                                Command="{Binding AddHomeLinkGroupCommand}" Margin="0,0,8,0" MinWidth="88"/>

                        <Button Content="{Binding [official_publisher_home_edit_group], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                                Command="{Binding EditHomeLinkGroupCommand}" Margin="0,0,8,0" MinWidth="88"/>

                        <Button Content="{Binding [Delete], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                                Command="{Binding RemoveHomeLinkGroupCommand}" Margin="0,0,8,0" MinWidth="72"/>

                        <Button Content="{Binding [add_link], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                                Command="{Binding AddHomeLinkCommand}" Margin="0,0,8,0" MinWidth="88"/>

                        <Button Content="{Binding [Edit], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                                Command="{Binding EditHomeLinkCommand}" Margin="0,0,8,0" MinWidth="72"/>

                        <Button Content="{Binding [Delete], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                                Command="{Binding RemoveHomeLinkCommand}" Margin="0,0,8,0" MinWidth="72"/>

                        <Button Content="{Binding [official_publisher_home_save_draft], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                                Command="{Binding SaveHomeLinksDraftCommand}" Margin="0,0,8,0" MinWidth="100"/>

                        <Button Content="{Binding [refresh], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                                Command="{Binding ReloadHomeLinksEditorCommand}" MinWidth="72"/>

                    </StackPanel>

                    <Grid Grid.Row="1" MinHeight="180">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="180"/>

                            <ColumnDefinition Width="8"/>

                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0"

                                 ItemsSource="{Binding HomeLinkGroups}"

                                 SelectedItem="{Binding SelectedHomeLinkGroup}"

                                 DisplayMemberPath="Title"

                                 BorderBrush="#EEEEEE" BorderThickness="1"/>

                        <ListBox Grid.Column="2"

                                 ItemsSource="{Binding SelectedHomeLinkGroup.Links}"

                                 SelectedItem="{Binding SelectedHomeLink}"

                                 BorderBrush="#EEEEEE" BorderThickness="1">

                            <ListBox.ItemTemplate>

                                <DataTemplate>

                                    <StackPanel Margin="2">

                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>

                                        <TextBlock Text="{Binding Url}" FontSize="11" Foreground="#666666" TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding Icon}" FontSize="10" Foreground="#999999" TextTrimming="CharacterEllipsis"/>

                                    </StackPanel>

                                </DataTemplate>

                            </ListBox.ItemTemplate>

                        </ListBox>

                    </Grid>

                </Grid>

            </TabItem>

        </TabControl>



        <hc:ScrollViewer Grid.Row="5" Background="#F5F5F5" Padding="10"

                         VerticalScrollBarVisibility="Auto" MinHeight="100" MaxHeight="160">

            <TextBlock Text="{Binding LogText}" TextWrapping="Wrap"/>

        </hc:ScrollViewer>



            </Grid>

        </hc:ScrollViewer>



        <Border Grid.Row="1" BorderBrush="#E5E5EA" BorderThickness="0,1,0,0" Background="White"

                Padding="20,12,20,16">

            <StackPanel>

            <StackPanel Margin="0,0,0,12"
                        Visibility="{Binding IsPublishing, Converter={StaticResource BooleanToVisibilityConverter}}">

                <Grid Margin="0,0,0,6">

                    <TextBlock Text="{Binding PublishProgressText}" FontSize="12" Foreground="#666666" TextTrimming="CharacterEllipsis"/>

                    <TextBlock Text="{Binding PublishProgress, StringFormat={}{0:0}%}"
                               FontSize="12" Foreground="#666666" HorizontalAlignment="Right"/>

                </Grid>

                <ProgressBar Value="{Binding PublishProgress}" Maximum="100" Height="6" BorderThickness="0"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

            <Button Content="{Binding [official_publisher_refresh], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                    Command="{Binding RefreshPreviewCommand}" Margin="0,0,8,0"

                    IsEnabled="{Binding IsNotBusy}" MinWidth="100"/>

            <Button Content="{Binding [official_publisher_export_local], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                    Command="{Binding ExportLocalCommand}" Margin="0,0,8,0"

                    IsEnabled="{Binding IsNotBusy}" MinWidth="120"/>

            <Button Content="{Binding [official_publisher_publish_cos], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"

                    Command="{Binding PublishToCosCommand}"

                    Style="{StaticResource ButtonPrimary}" IsEnabled="{Binding IsNotBusy}" MinWidth="140"/>

            </StackPanel>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>

