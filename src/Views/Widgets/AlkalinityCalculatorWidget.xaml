<UserControl x:Class="GeoChemistryNexus.Views.Widgets.AlkalinityCalculatorWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="640"
             Background="White">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="{Binding [alkalinity_calculator], Source={x:Static lg:LanguageService.Instance}}"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding [alkalinity_calculator_hint], Source={x:Static lg:LanguageService.Instance}}"
                       Style="{StaticResource ModernSettingsItemHintStyle}"
                       Margin="0,0,0,16"/>

            <!-- 滴定输入 -->
            <Border Style="{StaticResource ModernCardStyle}" Padding="16">
                <StackPanel>
                    <TextBlock Text="{Binding [alkalinity_calc_titration], Source={x:Static lg:LanguageService.Instance}}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding [alkalinity_calc_hcl_molarity], Source={x:Static lg:LanguageService.Instance}}"
                                       FontSize="12" Margin="0,0,0,6"/>
                            <hc:NumericUpDown Value="{Binding HclMolarity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource ModernNumericUpDownStyle}"
                                              Minimum="0" Increment="0.01"/>
                            <TextBlock Text="mol/L" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding [alkalinity_calc_sample_volume], Source={x:Static lg:LanguageService.Instance}}"
                                       FontSize="12" Margin="0,0,0,6"/>
                            <hc:NumericUpDown Value="{Binding SampleVolumeMl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource ModernNumericUpDownStyle}"
                                              Minimum="0" Increment="1"/>
                            <TextBlock Text="ml" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{Binding [alkalinity_calc_hcl_volume], Source={x:Static lg:LanguageService.Instance}}"
                                       FontSize="12" Margin="0,0,0,6"/>
                            <hc:NumericUpDown Value="{Binding HclVolumeMl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource ModernNumericUpDownStyle}"
                                              Minimum="0" Increment="0.1"/>
                            <TextBlock Text="ml" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                        </StackPanel>
                    </Grid>

                    <DockPanel Margin="0,16,0,0" LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Content="{Binding [alkalinity_calc_reset], Source={x:Static lg:LanguageService.Instance}}"
                                Command="{Binding ResetCommand}"
                                Padding="14,6" Margin="12,0,0,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AlkalinitySummary}"
                                   FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="#0078D4"
                                   TextWrapping="Wrap"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- 结果表 -->
            <Border Style="{StaticResource ModernCardStyle}" Padding="0" Margin="0">
                <StackPanel>
                    <TextBlock Text="{Binding [alkalinity_calc_results], Source={x:Static lg:LanguageService.Instance}}"
                               FontSize="14" FontWeight="SemiBold" Margin="16,16,16,8"/>
                    <TextBlock Text="{Binding [alkalinity_calc_results_hint], Source={x:Static lg:LanguageService.Instance}}"
                               Style="{StaticResource ModernSettingsItemHintStyle}"
                               Margin="16,0,16,12"/>

                    <!-- 表头 -->
                    <Border Background="#F5F7FA" BorderBrush="#E5E5E5" BorderThickness="0,1,0,1" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding [alkalinity_calc_form], Source={x:Static lg:LanguageService.Instance}}" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="g/L" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="meq/L" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="Molarity" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="ppm" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Results}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="12,10"
                                        Background="#E8F6FF">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding FormDisplay}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding GramsPerLiterText}" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding MeqPerLiterText}" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding MolarityText}" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding PpmText}" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 来源说明 -->
            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12" Foreground="#86868B">
                <Run Text="{Binding [alkalinity_calc_source_label], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>
                <Run Text=" "/>
                <Hyperlink Command="{Binding DataContext.OpenSourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <Run Text="{Binding [alkalinity_calc_source_link], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
