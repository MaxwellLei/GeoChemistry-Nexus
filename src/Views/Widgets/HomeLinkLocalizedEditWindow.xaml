<hc:Window x:Class="GeoChemistryNexus.Views.Widgets.HomeLinkLocalizedEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
        xmlns:controls="clr-namespace:GeoChemistryNexus.Controls"
        mc:Ignorable="d"
        Height="560" Width="440"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{Binding [home_links_edit_language], Source={x:Static lg:LanguageService.Instance}, FallbackValue=Editing language:}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="LanguageBox" Width="180"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="Code"
                      SelectionChanged="LanguageBox_SelectionChanged"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="{Binding [name], Source={x:Static lg:LanguageService.Instance}}" Margin="0,0,0,4"/>
        <controls:LocalizedStringControl x:Name="TitleControl" Grid.Row="2" Margin="0,0,0,12" MinHeight="32"
                                         ContentLanguageContext="{Binding LanguageContext, RelativeSource={RelativeSource AncestorType=hc:Window}}"/>

        <TextBlock x:Name="DescriptionLabel" Grid.Row="3"
                   Text="{Binding [description], Source={x:Static lg:LanguageService.Instance}}"
                   Margin="0,0,0,4"/>
        <controls:LocalizedStringControl x:Name="DescriptionControl" Grid.Row="4" Margin="0,0,0,12" MinHeight="48"
                                         ContentLanguageContext="{Binding LanguageContext, RelativeSource={RelativeSource AncestorType=hc:Window}}"/>

        <hc:TextBox x:Name="UrlBox" Grid.Row="5"
                    hc:InfoElement.Title="{Binding [link_url], Source={x:Static lg:LanguageService.Instance}}"
                    hc:InfoElement.Necessary="True" Margin="0,0,0,12"/>

        <hc:ComboBox x:Name="IconBox" Grid.Row="6"
                     hc:InfoElement.Title="{Binding [icon], Source={x:Static lg:LanguageService.Instance}}"
                     Margin="0,0,0,12" SelectedValuePath="Code">
            <hc:ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Code}" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Name}"/>
                    </StackPanel>
                </DataTemplate>
            </hc:ComboBox.ItemTemplate>
        </hc:ComboBox>

        <hc:TextBox x:Name="IconUrlBox" Grid.Row="7"
                    hc:InfoElement.Title="{Binding [home_icon_url], Source={x:Static lg:LanguageService.Instance}}"
                    hc:InfoElement.Placeholder="{Binding [home_icon_url_hint], Source={x:Static lg:LanguageService.Instance}}"
                    Margin="0,0,0,12"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding [Cancel], Source={x:Static lg:LanguageService.Instance}}" Click="Cancel_Click" Margin="0,0,10,0"/>
            <Button Content="{Binding [Confirm], Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource ButtonPrimary}" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</hc:Window>
