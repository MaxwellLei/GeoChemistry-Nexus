<UserControl x:Class="GeoChemistryNexus.Views.Widgets.BlackBodyRadiationCalculatorWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="900"
             Background="White"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded"
             DataContextChanged="OnDataContextChanged">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="320"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{Binding [black_body_radiation_calculator], Source={x:Static lg:LanguageService.Instance}}"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding [black_body_radiation_calculator_hint], Source={x:Static lg:LanguageService.Instance}}"
                       Style="{StaticResource ModernSettingsItemHintStyle}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- 整体左右：左=温度+定律，右=光谱 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.85*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.35*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：上温度，下辐射定律 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding [black_body_radiation_calc_input], Source={x:Static lg:LanguageService.Instance}}"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <hc:NumericUpDown Value="{Binding TemperatureKelvin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource ModernNumericUpDownStyle}"
                                                  Minimum="1" Maximum="100000" Increment="100"/>
                                <TextBlock Text="K" Style="{StaticResource ModernSettingsItemHintStyle}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="{Binding [black_body_radiation_calc_reset], Source={x:Static lg:LanguageService.Instance}}"
                                    Command="{Binding ResetCommand}"
                                    Padding="14,6" Margin="12,0,0,0"
                                    VerticalAlignment="Top"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource ModernCardStyle}" Padding="14">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding [black_body_radiation_calc_laws], Source={x:Static lg:LanguageService.Instance}}"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="13"
                                       Foreground="#C42B1C"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding [black_body_radiation_calc_stefan_title], Source={x:Static lg:LanguageService.Instance}}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding StefanBoltzmannText}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#0078D4"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <TextBlock Text="{Binding [black_body_radiation_calc_wien_title], Source={x:Static lg:LanguageService.Instance}}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding WienText}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#0078D4"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding SpectrumPeakText}"
                                       Style="{StaticResource ModernSettingsItemHintStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 右侧：黑体光谱 -->
            <Border Grid.Column="2" Style="{StaticResource ModernCardStyle}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="{Binding [black_body_radiation_calc_spectrum], Source={x:Static lg:LanguageService.Instance}}"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding [black_body_radiation_calc_spectrum_hint], Source={x:Static lg:LanguageService.Instance}}"
                                   Style="{StaticResource ModernSettingsItemHintStyle}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Border Grid.Row="1" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="4">
                        <ScottPlot:WpfPlot x:Name="SpectrumPlot"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 来源说明 -->
        <TextBlock Grid.Row="2" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="12" Foreground="#86868B">
            <Run Text="{Binding [black_body_radiation_calc_source_label], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>
            <Run Text=" "/>
            <Hyperlink Command="{Binding DataContext.OpenSourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Run Text="{Binding [black_body_radiation_calc_source_link], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>
            </Hyperlink>
        </TextBlock>
    </Grid>
</UserControl>
