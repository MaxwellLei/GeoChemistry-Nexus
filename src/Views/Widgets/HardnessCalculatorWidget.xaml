<UserControl x:Class="GeoChemistryNexus.Views.Widgets.HardnessCalculatorWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="560"
             Background="White">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="{Binding [hardness_calculator], Source={x:Static lg:LanguageService.Instance}}"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding [hardness_calculator_hint], Source={x:Static lg:LanguageService.Instance}}"
                       Style="{StaticResource ModernSettingsItemHintStyle}"
                       Margin="0,0,0,16"/>

            <!-- 浓度输入 -->
            <Border Style="{StaticResource ModernCardStyle}" Padding="16">
                <StackPanel>
                    <TextBlock Text="{Binding [hardness_calc_concentrations], Source={x:Static lg:LanguageService.Instance}}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding [hardness_calc_mg], Source={x:Static lg:LanguageService.Instance}}"
                                       FontSize="12" Margin="0,0,0,6"/>
                            <hc:NumericUpDown Value="{Binding MgPpm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource ModernNumericUpDownStyle}"
                                              Minimum="0" Increment="0.1"/>
                            <TextBlock Text="ppm (mg/L)" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding [hardness_calc_ca], Source={x:Static lg:LanguageService.Instance}}"
                                       FontSize="12" Margin="0,0,0,6"/>
                            <hc:NumericUpDown Value="{Binding CaPpm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource ModernNumericUpDownStyle}"
                                              Minimum="0" Increment="0.1"/>
                            <TextBlock Text="ppm (mg/L)" Style="{StaticResource ModernSettingsItemHintStyle}"/>
                        </StackPanel>
                    </Grid>

                    <DockPanel Margin="0,16,0,0" LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Content="{Binding [hardness_calc_reset], Source={x:Static lg:LanguageService.Instance}}"
                                Command="{Binding ResetCommand}"
                                Padding="14,6" Margin="12,0,0,0"
                                VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding HardnessSummary}"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="#0078D4"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ClassificationText}"
                                       FontSize="13"
                                       Margin="0,4,0,0"
                                       Foreground="#323130"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Text="{Binding EquationText}"
                               Style="{StaticResource ModernSettingsItemHintStyle}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- USGS 分级 -->
            <Border Style="{StaticResource ModernCardStyle}" Padding="0" Margin="0">
                <StackPanel>
                    <TextBlock Text="{Binding [hardness_calc_usgs_title], Source={x:Static lg:LanguageService.Instance}}"
                               FontSize="14" FontWeight="SemiBold" Margin="16,16,16,8"/>
                    <TextBlock Text="{Binding [hardness_calc_usgs_hint], Source={x:Static lg:LanguageService.Instance}}"
                               Style="{StaticResource ModernSettingsItemHintStyle}"
                               Margin="16,0,16,12"/>

                    <Border Background="#F5F7FA" BorderBrush="#E5E5E5" BorderThickness="0,1,0,1" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.6*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding [hardness_calc_class], Source={x:Static lg:LanguageService.Instance}}"
                                       FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding [hardness_calc_range], Source={x:Static lg:LanguageService.Instance}}"
                                       FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding ClassificationRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="12,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#E8F6FF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.6*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding RangeText}" FontSize="13"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 来源说明 -->
            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12" Foreground="#86868B">
                <Run Text="{Binding [hardness_calc_source_label], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>
                <Run Text=" "/>
                <Hyperlink Command="{Binding DataContext.OpenSourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <Run Text="{Binding [hardness_calc_source_link], Source={x:Static lg:LanguageService.Instance}, Mode=OneWay}"/>
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
