<Page x:Class="GeoChemistryNexus.Views.GeothermometerPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:hc="https://handyorg.github.io/handycontrol"
      xmlns:rg="clr-namespace:unvell.ReoGrid;assembly=unvell.ReoGrid"
      xmlns:local="clr-namespace:GeoChemistryNexus.Views"
      xmlns:cvs="clr-namespace:GeoChemistryNexus.Converter"
      xmlns:hp="clr-namespace:GeoChemistryNexus.Helpers"
      xmlns:models="clr-namespace:GeoChemistryNexus.Models"
      xmlns:vm="clr-namespace:GeoChemistryNexus.ViewModels"
      xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1100"
      Title="GeothermometerPageView">

    <Page.Resources>
        <FontFamily x:Key="IconFont">pack://application:,,,/Data/Icon/#iconfont</FontFamily>
        <cvs:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <cvs:GeoTPluginSelectedMultiConverter x:Key="GeoTPluginSelectedMultiConverter"/>
        <hp:BindingProxy x:Key="GridProxy" Data="{Binding ElementName=MyReoGrid}" />
        <hp:BindingProxy x:Key="ViewModelProxy" Data="{Binding}" />

        <!-- 左侧导航按钮样式（矿物分组） -->
        <Style x:Key="MineralGroupButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BorderElement"
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                Margin="8,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderElement" Property="Background" Value="#EAEAEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 二级类别分组按钮样式 -->
        <Style x:Key="GeoTCategoryGroupButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CategoryBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                Margin="16,1,8,1"
                                BorderThickness="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AccentBar" Width="3" CornerRadius="2" Margin="0,2,8,2"
                                        Background="Transparent" VerticalAlignment="Stretch"/>
                                <ContentPresenter Grid.Column="1"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CategoryBorder" Property="Background" Value="#ECECF0"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                <Setter TargetName="CategoryBorder" Property="Background" Value="#ECECF0"/>
                                <Setter TargetName="AccentBar" Property="Background" Value="#0078D4"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 温度计算法条目样式 - 现代化交互动画 -->
        <Style x:Key="PluginItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BorderElement"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="5"
                                Margin="20,0,8,0"
                                RenderTransformOrigin="0,0.5">
                            <Border.Background>
                                <SolidColorBrush x:Name="ItemBgBrush" Color="Transparent"/>
                            </Border.Background>
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ItemTranslate" X="0"/>
                            </Border.RenderTransform>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 现代化悬停：平滑颜色过渡 + 微位移 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="ItemHoverIn">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ItemBgBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="#E0E7FF" Duration="0:0:0.18">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ItemTranslate"
                                                Storyboard.TargetProperty="X"
                                                To="3" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="ItemHoverIn"/>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ItemBgBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="Transparent" Duration="0:0:0.25">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ItemTranslate"
                                                Storyboard.TargetProperty="X"
                                                To="0" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <!-- 现代化按压反馈：颜色加深 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="ItemPressIn">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ItemBgBrush"
                                                Storyboard.TargetProperty="Color"
                                                To="#D0DBFF" Duration="0:0:0.06"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="ItemPressIn"/>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 工具栏按钮样式 -->
        <Style x:Key="GTMToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                Padding="{TemplateBinding Padding}" ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E5E5"/>
                                <Setter Property="Foreground" Value="#000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D1D1D1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 面板控制小按钮样式（与 CIPW 计算详情一致） -->
        <Style x:Key="PanelControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" 
                                ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                                <Setter Property="Foreground" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D4D4D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 温压计右键菜单（x:Shared=False：每项独立实例，便于用 ContextMenu.IsOpen 保持悬停高亮） -->
        <ContextMenu x:Key="GeoTPluginContextMenu" x:Shared="False">
            <MenuItem Command="{Binding PlacementTarget.Tag.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                        <Setter Property="Header" Value="{Binding [favorite],Source={x:Static lg:LanguageService.Instance}, FallbackValue=收藏}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsFavorite, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                                <Setter Property="Header" Value="{Binding [unfavorite],Source={x:Static lg:LanguageService.Instance}, FallbackValue=取消收藏}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
                <MenuItem.Icon>
                    <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="{Binding [geo_ctx_edit],Source={x:Static lg:LanguageService.Instance}, FallbackValue=编辑}"
                      Command="{Binding PlacementTarget.Tag.EditCustomThermometerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding [geo_ctx_export_zip],Source={x:Static lg:LanguageService.Instance}, FallbackValue=导出 ZIP}"
                      Command="{Binding PlacementTarget.Tag.ExportPluginCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xe673;" FontFamily="{StaticResource IconFont}" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding [force_update_template],Source={x:Static lg:LanguageService.Instance}, TargetNullValue='强制更新'}"
                      Command="{Binding PlacementTarget.Tag.ForceUpdatePluginCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                </MenuItem.Icon>
                <MenuItem.Style>
                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding PlacementTarget.Tag.IsDeveloperMode, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True"/>
                                    <Condition Binding="{Binding PlacementTarget.DataContext.IsBuiltIn, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <Separator>
                <Separator.Style>
                    <Style TargetType="Separator">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding PlacementTarget.Tag.IsDeveloperMode, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True"/>
                                    <Condition Binding="{Binding PlacementTarget.DataContext.IsBuiltIn, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Separator.Style>
            </Separator>
            <MenuItem Header="{Binding [geo_ctx_demote],Source={x:Static lg:LanguageService.Instance}, FallbackValue=降级为自定义}"
                      Command="{Binding PlacementTarget.Tag.ConvertToCustomCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#E65100"/>
                </MenuItem.Icon>
                <MenuItem.Style>
                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding PlacementTarget.Tag.IsDeveloperMode, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True"/>
                                    <Condition Binding="{Binding PlacementTarget.DataContext.IsBuiltIn, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <MenuItem Header="{Binding [geo_ctx_promote],Source={x:Static lg:LanguageService.Instance}, FallbackValue=转换为官方}"
                      Command="{Binding PlacementTarget.Tag.ConvertToOfficialCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#107C10"/>
                </MenuItem.Icon>
                <MenuItem.Style>
                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding PlacementTarget.Tag.IsDeveloperMode, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True"/>
                                    <Condition Binding="{Binding PlacementTarget.DataContext.IsBuiltIn, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
            <Separator>
                <Separator.Style>
                    <Style TargetType="Separator">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PlacementTarget.Tag.IsDeveloperMode, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Separator.Style>
            </Separator>
            <MenuItem Header="{Binding [geo_ctx_delete],Source={x:Static lg:LanguageService.Instance}, FallbackValue=删除}"
                      Command="{Binding PlacementTarget.Tag.DeleteCustomThermometerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Foreground="#D13438">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#D13438"/>
                </MenuItem.Icon>
                <MenuItem.Style>
                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PlacementTarget.Tag.IsDeveloperMode, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
        </ContextMenu>

        <!-- 温压计列表项容器样式（虚拟化 ListBox） -->
        <Style x:Key="GeoTPluginListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Tag" Value="{Binding Data, Source={StaticResource ViewModelProxy}}"/>
            <Setter Property="ContextMenu" Value="{StaticResource GeoTPluginContextMenu}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Margin="4,1,8,1" Padding="16,4,8,4"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                ClipToBounds="False" MinHeight="42"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding Data.SelectPluginCommand, Source={StaticResource ViewModelProxy}}"
                                              CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=DataContext}"/>
                            </Border.InputBindings>
                            <ContentPresenter x:Name="ItemContent"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- 鼠标悬停高亮 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E4E8EF"/>
                </Trigger>
                <!-- 右键菜单打开时保持悬停高亮（指针移到菜单后 IsMouseOver 会变为 False） -->
                <DataTrigger Binding="{Binding ContextMenu.IsOpen, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#E4E8EF"/>
                </DataTrigger>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource GeoTPluginSelectedMultiConverter}">
                            <Binding Path="DataContext" RelativeSource="{RelativeSource Self}"/>
                            <Binding Path="Data.SelectedPlugin" Source="{StaticResource ViewModelProxy}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="#EAF3FF"/>
                    <Setter Property="BorderBrush" Value="#BBD7F5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 温压计条目标题（选中时高亮） -->
        <Style x:Key="GeoTPluginNameTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="LineHeight" Value="18"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource GeoTPluginSelectedMultiConverter}">
                            <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ListBoxItem}"/>
                            <Binding Path="Data.SelectedPlugin" Source="{StaticResource ViewModelProxy}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Foreground" Value="#333333"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 温压计条目作者行 -->
        <Style x:Key="GeoTPluginMetaTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
            <Setter Property="LineHeight" Value="15"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource GeoTPluginSelectedMultiConverter}">
                            <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ListBoxItem}"/>
                            <Binding Path="Data.SelectedPlugin" Source="{StaticResource ViewModelProxy}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Foreground" Value="#666666"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 温压计条目 DataTemplate -->
        <DataTemplate x:Key="GeoTPluginItemTemplate" DataType="{x:Type models:Geothermometer}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource GeoTPluginNameTextStyle}"/>
                    <TextBlock Style="{StaticResource GeoTPluginMetaTextStyle}">
                        <Run Text="{Binding Author, Mode=OneWay}"/>
                        <Run Text=" ("/>
                        <Run Text="{Binding Year, Mode=OneWay}"/>
                        <Run Text=")"/>
                    </TextBlock>
                </StackPanel>
                <Border Grid.Column="1" CornerRadius="4" Background="#FFF3E0" Padding="5,2"
                        VerticalAlignment="Center" Margin="4,0,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBuiltIn}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding [geo_label_custom_chip],Source={x:Static lg:LanguageService.Instance}, FallbackValue=自定义}"
                               FontSize="9" Foreground="#E65100"/>
                </Border>
                <Border Grid.Column="2" Width="6" Height="6" CornerRadius="3"
                        Background="#2B7DE9"
                        VerticalAlignment="Center" Margin="8,0,2,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Value="True">
                                    <DataTrigger.Binding>
                                        <MultiBinding Converter="{StaticResource GeoTPluginSelectedMultiConverter}">
                                            <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ListBoxItem}"/>
                                            <Binding Path="Data.SelectedPlugin" Source="{StaticResource ViewModelProxy}"/>
                                        </MultiBinding>
                                    </DataTrigger.Binding>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- 二级类别分组 DataTemplate -->
        <DataTemplate x:Key="GeoTCategoryGroupTemplate" DataType="{x:Type vm:CategoryGroupViewModel}">
            <StackPanel Margin="0,0,0,2">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PluginCount}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Button Command="{Binding Data.ToggleCategoryGroupCommand, Source={StaticResource ViewModelProxy}}"
                        CommandParameter="{Binding}"
                        Style="{StaticResource GeoTCategoryGroupButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontSize="12.5" Foreground="#555" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#333"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Border Grid.Column="1" CornerRadius="10" Padding="5,1" Margin="4,0"
                                Background="#E3E3EA" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PluginCount}" FontSize="10" Foreground="#666"/>
                        </Border>
                        <TextBlock Grid.Column="2" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#999"
                                   VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.Text>&#xE76C;</TextBlock.Text>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="0"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="90"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Button>

                <ListBox ItemsSource="{Binding Plugins}"
                         Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="20,0,0,0"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionMode="Single"
                         Focusable="False"
                         SelectedItem="{Binding Data.SelectedPlugin, Source={StaticResource ViewModelProxy}, Mode=OneWay}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Item"
                         MaxHeight="480"
                         ItemContainerStyle="{StaticResource GeoTPluginListBoxItemStyle}"
                         ItemTemplate="{StaticResource GeoTPluginItemTemplate}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </StackPanel>
        </DataTemplate>

        <!-- 一级侧栏区块 DataTemplate -->
        <DataTemplate x:Key="GeoTSidebarSectionTemplate" DataType="{x:Type vm:GeoTSidebarSectionViewModel}">
            <StackPanel>
                <!-- 区块间浅分隔线（官方温压计上方不显示） -->
                <Rectangle Height="1" Fill="#ECECEF" Margin="16,6,16,2">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SectionKey}" Value="Custom">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SectionKey}" Value="Favorite">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <Button Command="{Binding Data.ToggleSidebarSectionCommand, Source={StaticResource ViewModelProxy}}"
                        CommandParameter="{Binding}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MineralGroupButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <Setter Property="Background" Value="#EAEAEA"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontSize="14" Foreground="#333" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Border Grid.Column="1" CornerRadius="10" Padding="6,2" Margin="4,0"
                                Background="#E9E9EF" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalCount}" FontSize="11" Foreground="#555"/>
                        </Border>
                        <TextBlock Grid.Column="2" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#808080"
                                   VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.Text>&#xE76C;</TextBlock.Text>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="0"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="90"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Button>

                <ItemsControl ItemsSource="{Binding CategoryGroups}"
                              ItemTemplate="{StaticResource GeoTCategoryGroupTemplate}"
                              Margin="0,2,0,4"
                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- 收藏区块为空时的提示 -->
                <TextBlock Margin="20,6,20,4" FontSize="11" Foreground="#AAA" TextWrapping="Wrap"
                           Text="{Binding [diagram_hint_no_favorites],Source={x:Static lg:LanguageService.Instance}, FallbackValue=暂无收藏。}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding SectionKey}" Value="Favorite"/>
                                        <Condition Binding="{Binding IsExpanded}" Value="True"/>
                                        <Condition Binding="{Binding TotalCount}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 自定义区块为空时的提示 + 新建按钮 -->
                <Grid Margin="20,4,16,6">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding SectionKey}" Value="Custom"/>
                                        <Condition Binding="{Binding IsExpanded}" Value="True"/>
                                        <Condition Binding="{Binding TotalCount}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontSize="11" Foreground="#AAA" TextWrapping="Wrap" VerticalAlignment="Center"
                               Text="{Binding [geo_hint_no_custom],Source={x:Static lg:LanguageService.Instance}, FallbackValue=暂无自定义温压计，点击 + 创建。}"/>
                    <Button Grid.Column="1" Cursor="Hand" ToolTip="{Binding [geo_tooltip_new],Source={x:Static lg:LanguageService.Instance}, FallbackValue=新建}"
                            Command="{Binding Data.CreateCustomThermometerCommand, Source={StaticResource ViewModelProxy}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="4" Width="22" Height="22">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#0078D4"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E0E7FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

            </StackPanel>
        </DataTemplate>

        <!-- 主操作按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#004578"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <i:Interaction.Behaviors>
            <hp:FileDropBehavior DropCommand="{Binding ImportPluginFromPathCommand}"
                                 AllowedExtensions=".gngtm,.zip"
                                 OverlayIcon="&#xE896;"
                                 HintText="{Binding [file_drop_release_to_import], Source={x:Static lg:LanguageService.Instance}}"
                                 SubHintText="{Binding [file_drop_supported_geothermometer], Source={x:Static lg:LanguageService.Instance}}"
                                 InvalidHintText="{Binding [file_drop_invalid_format], Source={x:Static lg:LanguageService.Instance}}"/>
        </i:Interaction.Behaviors>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== 左侧：矿物导航面板 ==================== -->
        <DockPanel Grid.Column="0" Background="#F5F5F7">

            <!-- 顶部菜单栏 -->
            <Border DockPanel.Dock="Top" Background="#F1F1F1" BorderBrush="#D4D4D4" BorderThickness="0,0,0,1">
                <Menu Background="Transparent" VerticalAlignment="Center" Margin="2,5,0,5">
                    <MenuItem Header="{Binding [File],Source={x:Static lg:LanguageService.Instance}, FallbackValue=文件}">
                        <MenuItem Header="{Binding [geo_menu_new_custom],Source={x:Static lg:LanguageService.Instance}, FallbackValue=新建自定义地质温压计}" 
                                  Command="{Binding CreateCustomThermometerCommand}"
                                  Icon="&#x1f4c4;"/>
                        <Separator />
                        <MenuItem Header="{Binding [geo_menu_import_zip],Source={x:Static lg:LanguageService.Instance}, FallbackValue=导入地质温压计 (ZIP)}" 
                                  Command="{Binding ImportPluginCommand}"/>
                        <MenuItem Header="{Binding [geo_menu_open_free_sheet],Source={x:Static lg:LanguageService.Instance}, FallbackValue=打开自由表格}" 
                                  Command="{Binding OpenFreeSheetCommand}"/>
                    </MenuItem>
                    <MenuItem Header="{Binding [geo_menu_update],Source={x:Static lg:LanguageService.Instance}, FallbackValue=更新}">
                        <MenuItem Header="{Binding [geo_menu_check_update],Source={x:Static lg:LanguageService.Instance}, FallbackValue=检查更新}" 
                                  Command="{Binding CheckForPluginUpdatesCommand}"/>
                    </MenuItem>
                </Menu>
            </Border>

            <!-- 搜索框 + 筛选按钮 -->
            <Border DockPanel.Dock="Top" Margin="12,12,12,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Height="32" Padding="8,6" Margin="0,0,6,0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="13" BorderBrush="#D0D0D0" BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" 
                                                               FontSize="14" Foreground="#999" Margin="8,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding [geo_placeholder_search],Source={x:Static lg:LanguageService.Instance}, FallbackValue=搜索...}" 
                                                               FontSize="13" Foreground="#999" Margin="10,0,8,0" VerticalAlignment="Center"
                                                               IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <ScrollViewer Grid.Column="1" x:Name="PART_ContentHost" 
                                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="#0078D4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button x:Name="TagFilterButton" Grid.Column="1"
                            Width="32" Height="32"
                            Command="{Binding ToggleTagFilterMenuCommand}"
                            ToolTip="{Binding [geo_tooltip_tag_filter], Source={x:Static lg:LanguageService.Instance}, FallbackValue=按标签筛选}"
                            Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Cursor="Hand">
                        <TextBlock Text="&#xe8b6;" FontFamily="{StaticResource IconFont}" FontSize="14" Foreground="#666"/>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="FilterButtonBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="FilterButtonBorder" Property="Background" Value="#F5F5F5"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="FilterButtonBorder" Property="Background" Value="#E8F4FD"/>
                                                    <Setter TargetName="FilterButtonBorder" Property="BorderBrush" Value="#0078D4"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding HasActiveTagFilter}" Value="True">
                                                    <Setter TargetName="FilterButtonBorder" Property="BorderBrush" Value="#0078D4"/>
                                                    <Setter TargetName="FilterButtonBorder" Property="Background" Value="#E8F4FD"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTagFilterMenuOpen}" Value="True">
                                                    <Setter TargetName="FilterButtonBorder" Property="BorderBrush" Value="#0078D4"/>
                                                    <Setter TargetName="FilterButtonBorder" Property="Background" Value="#E8F4FD"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Popup PlacementTarget="{Binding ElementName=TagFilterButton}"
                           Placement="Bottom"
                           HorizontalOffset="-4"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           IsOpen="{Binding IsTagFilterMenuOpen, Mode=TwoWay}">
                        <Border Background="White" CornerRadius="6" BorderBrush="#D0D0D0" BorderThickness="1"
                                MinWidth="160" MaxWidth="240" Padding="4,6">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="3" Opacity="0.18"/>
                            </Border.Effect>
                            <StackPanel>
                                <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding AvailableTagFilters}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:GeoTTagFilterItemViewModel}">
                                                <CheckBox Content="{Binding DisplayName}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Margin="8,3" FontSize="13"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock Text="{Binding [geo_msg_no_tags_available], Source={x:Static lg:LanguageService.Instance}, FallbackValue=暂无可用标签}"
                                           FontSize="12" Foreground="#999" Margin="8,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasAvailableTagFilters}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <!-- 温压计导航列表 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,4,0,12">
                    <ItemsControl ItemsSource="{Binding SidebarSections}"
                                  ItemTemplate="{StaticResource GeoTSidebarSectionTemplate}"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- 分隔条 -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True">
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Grid Background="Transparent">
                        <Rectangle Width="1" HorizontalAlignment="Center" Fill="#E0E0E0"/>
                    </Grid>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- ==================== 右侧：内容区域 ==================== -->
        <Grid Grid.Column="2" Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部：温压计信息卡片 + 操作按钮 -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：选中的温压计信息 -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <!-- 未选中时的提示 -->
                        <TextBlock FontSize="16" Foreground="#999" Margin="0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Text" Value="{Binding [geo_hint_select_thermometer],Source={x:Static lg:LanguageService.Instance}, FallbackValue=请从左侧面板选择温压计}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPlugin}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 选中时的信息 -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedPlugin}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- 温压计名称 -->
                            <TextBlock Text="{Binding SelectedPluginDisplayName}" FontSize="18" FontWeight="SemiBold" Foreground="#333"/>

                            <!-- 参考文献 -->
                            <TextBlock FontSize="12" Foreground="#666" Margin="0,4,0,0"
                                       Text="{Binding SelectedPlugin.Reference}" TextTrimming="CharacterEllipsis"/>

                            <!-- 标签 · 版本 · 内置/自定义 -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <ItemsControl ItemsSource="{Binding SelectedPlugin.Tags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Background="#E8F4FD" Padding="8,3" Margin="0,0,6,0">
                                                <TextBlock FontSize="11" Foreground="#0078D4" Text="{Binding Mode=OneWay}"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border CornerRadius="4" Background="#F0F0F0" Padding="8,3" Margin="0,0,6,0">
                                    <TextBlock FontSize="11" Foreground="#555">
                                        <Run Text="v"/>
                                        <Run Text="{Binding SelectedPlugin.Version, Mode=OneWay}"/>
                                    </TextBlock>
                                </Border>
                                <Border CornerRadius="4" Padding="8,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8F8E8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPlugin.IsBuiltIn}" Value="False">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding [geo_label_builtin],Source={x:Static lg:LanguageService.Instance}, FallbackValue=内置}"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPlugin.IsBuiltIn}" Value="False">
                                                        <Setter Property="Text" Value="{Binding [geo_label_custom_chip],Source={x:Static lg:LanguageService.Instance}, FallbackValue=自定义}"/>
                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- 右侧：操作按钮 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPlugin}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- ===== 应用前：仅显示【应用】按钮 ===== -->
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ApplyPluginCommand}"
                                CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                Visibility="{Binding IsPluginApplied, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" 
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding [geo_btn_apply],Source={x:Static lg:LanguageService.Instance}, FallbackValue=应用}" 
                                           FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- ===== 应用后：显示【帮助说明】【导出】【重置】 ===== -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPluginApplied}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- 帮助文档切换按钮 -->
                            <Button Style="{StaticResource GTMToolbarButtonStyle}"
                                    Command="{Binding ToggleHelpDocumentCommand}"
                                    ToolTip="{Binding [geo_tooltip_help],Source={x:Static lg:LanguageService.Instance}, FallbackValue=帮助说明}"
                                    Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xe665;" FontFamily="{StaticResource IconFont}" FontSize="15" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding [geo_btn_help],Source={x:Static lg:LanguageService.Instance}, FallbackValue=帮助说明}" 
                                               VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <!-- 导出当前工作表按钮 -->
                            <Button Style="{StaticResource GTMToolbarButtonStyle}"
                                    Command="{Binding ExportWorksheetCommand}"
                                    CommandParameter="{Binding Data, Source={StaticResource GridProxy}}"
                                    ToolTip="{Binding [geo_tooltip_export_csv],Source={x:Static lg:LanguageService.Instance}, FallbackValue=导出当前工作表为CSV}"
                                    Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xe673;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding [geo_btn_export],Source={x:Static lg:LanguageService.Instance}, FallbackValue=导出}"
                                               VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <!-- 重置按钮（功能等同于应用） -->
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ApplyPluginCommand}"
                                    CommandParameter="{Binding Data, Source={StaticResource GridProxy}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" 
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding [geo_btn_reset],Source={x:Static lg:LanguageService.Instance}, FallbackValue=重置}" 
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 下方：帮助文档区域 / ReoGrid 表格 + 计算详情面板 -->
            <Grid Grid.Row="1">

                <!-- ==================== 数据表格区域（IsHelpDocVisible=False 时显示） ==================== -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHelpDocVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="TableRow" Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition x:Name="DetailRow" Height="Auto"/>
                    </Grid.RowDefinitions>

                    <rg:ReoGridControl Grid.Row="0" x:Name="MyReoGrid" SheetTabVisible="False">
                        <rg:ReoGridControl.Resources>
                            <ControlTemplate x:Key="ModernThumbTemplate" TargetType="Thumb">
                                <Border x:Name="thumbBorder" Background="#C2C3C9" CornerRadius="4" BorderThickness="0"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="thumbBorder" Property="Background" Value="#6E6E6E"/>
                                    </Trigger>
                                    <Trigger Property="IsDragging" Value="True">
                                        <Setter TargetName="thumbBorder" Property="Background" Value="#424242"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                            <Style TargetType="{x:Type ScrollBar}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                                            <Grid x:Name="GridRoot" Background="Transparent">
                                                <Track x:Name="PART_Track" IsDirectionReversed="true" Focusable="false">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}" Opacity="0" Background="Transparent" BorderThickness="0" Focusable="false"/>
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Command="{x:Static ScrollBar.LineDownCommand}" Opacity="0" Background="Transparent" BorderThickness="0" Focusable="false"/>
                                                    </Track.IncreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb Template="{StaticResource ModernThumbTemplate}" Margin="1"/>
                                                    </Track.Thumb>
                                                </Track>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Orientation" Value="Horizontal">
                                                    <Setter TargetName="PART_Track" Property="Orientation" Value="Horizontal"/>
                                                    <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="false"/>
                                                    <Setter Property="Width" Value="NaN"/>
                                                    <Setter Property="Height" Value="10"/>
                                                    <Setter Property="Width" Value="Auto"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </rg:ReoGridControl.Resources>
                    </rg:ReoGridControl>

                    <!-- 表格与计算详情之间的可拖动分隔条 -->
                    <GridSplitter x:Name="DetailSplitter" Grid.Row="1"
                                  Height="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  Background="Transparent"
                                  ShowsPreview="True"
                                  Visibility="Collapsed"
                                  DragCompleted="OnDetailSplitterDragCompleted"
                                  Cursor="SizeNS">
                        <GridSplitter.Template>
                            <ControlTemplate TargetType="GridSplitter">
                                <Grid Background="Transparent">
                                    <Border Height="1" VerticalAlignment="Center" Background="#E0E0E0"/>
                                </Grid>
                            </ControlTemplate>
                        </GridSplitter.Template>
                    </GridSplitter>

                    <!-- ==================== 计算详情面板（始终显示在底部） ==================== -->
                    <Border x:Name="DetailPanelBorder" Grid.Row="2" BorderBrush="#D4D4D4" BorderThickness="0,1,0,0"
                            Background="White">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 面板标题栏 -->
                            <Border Grid.Row="0" Background="#F8F8FA" Padding="12,8" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" MinHeight="36">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" 
                                               FontSize="14" Foreground="#0078D4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    
                                    <!-- 有数据时显示：计算详情 - Row X -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCalculationData}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="{Binding [geo_section_calc_details],Source={x:Static lg:LanguageService.Instance}, FallbackValue=计算详情}" 
                                                   FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                                        <TextBlock Text=" - " FontSize="12" Foreground="#999" Margin="4,0"/>
                                        <TextBlock Text="{Binding SelectedRowInfo}" FontSize="12" Foreground="#666" 
                                                   TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                    </StackPanel>
                                    
                                    <!-- 无数据时显示：请选择数据行 -->
                                    <TextBlock Grid.Column="1" Text="{Binding [geo_hint_select_data_row],Source={x:Static lg:LanguageService.Instance}, FallbackValue=请选择数据行}" 
                                               FontSize="13" Foreground="#999" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasCalculationData}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- 面板控制按钮：展开/收缩（与 CIPW 一致） -->
                                    <Button Grid.Column="2" Style="{StaticResource PanelControlButtonStyle}"
                                            Click="OnToggleDetailExpandClick"
                                            ToolTip="{Binding [cipw_tooltip_expand], Source={x:Static lg:LanguageService.Instance}, FallbackValue=展开/收缩}">
                                        <TextBlock x:Name="DetailExpandIcon" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- 计算步骤列表 -->
                            <hc:ScrollViewer x:Name="CalculationDetailScrollViewer" Grid.Row="1"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             Padding="0">
                                <hc:ScrollViewer.Style>
                                    <Style TargetType="hc:ScrollViewer" BasedOn="{StaticResource {x:Type hc:ScrollViewer}}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDetailPanelMinimized}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </hc:ScrollViewer.Style>
                                <ItemsControl ItemsSource="{Binding CalculationSteps}" Margin="8,4,8,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,1" Padding="10,6" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsResult}" Value="True">
                                                                <Setter Property="Background" Value="#F0F7FF"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F5F5F7"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 步骤名称 -->
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontSize" Value="12"/>
                                                                <Setter Property="Foreground" Value="#555"/>
                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsResult}" Value="True">
                                                                        <Setter Property="Foreground" Value="#0078D4"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                                    </TextBlock>

                                                    <!-- 步骤值 -->
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontSize" Value="12"/>
                                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                                <Setter Property="Foreground" Value="#333"/>
                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsResult}" Value="True">
                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                        <Setter Property="FontSize" Value="13"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="{Binding Value, Mode=OneWay}"/>
                                                    </TextBlock>

                                                    <!-- 描述 -->
                                                    <TextBlock Grid.Column="2" Text="{Binding Description}" FontSize="11" 
                                                               Foreground="#999" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Description}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </hc:ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ==================== 帮助文档区域（IsHelpDocVisible=True 时显示） ==================== -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHelpDocVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 帮助文档内容 -->
                    <Border Grid.Row="0" Background="White" Margin="0">
                        <Grid>
                            <RichTextBox x:Name="HelpDocRichTextBox" IsReadOnly="True" 
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         Padding="20,16" BorderThickness="0">
                                <RichTextBox.Resources>
                                    <Style TargetType="{x:Type FlowDocument}">
                                        <Setter Property="ColumnWidth" Value="999999"/>
                                        <Setter Property="IsOptimalParagraphEnabled" Value="True"/>
                                        <Setter Property="PagePadding" Value="10"/>
                                    </Style>
                                </RichTextBox.Resources>
                                <FlowDocument />
                            </RichTextBox>

                            <!-- 帮助文档异步加载遮罩 -->
                            <Border Background="#CCFFFFFF"
                                    Panel.ZIndex="10"
                                    Visibility="{Binding IsHelpDocLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <ProgressBar Style="{StaticResource FlatProgressBarStyle}"
                                                 Width="180"
                                                 IsIndeterminate="True"
                                                 Margin="0,0,0,12"/>
                                    <TextBlock Text="{Binding [loading_status], Source={x:Static lg:LanguageService.Instance}, FallbackValue=加载中...}"
                                               FontSize="13"
                                               Foreground="#666"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 底部确认按钮栏 -->
                    <Border Grid.Row="1" Background="#F8F8FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" 
                            Padding="20,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="12" Foreground="#888"
                                       Text="{Binding [geo_placeholder_help_read_confirm], Source={x:Static lg:LanguageService.Instance}, FallbackValue=阅读文档后点击确认继续。}"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding ConfirmAndShowTableCommand}"
                                    HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13" 
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding [geo_btn_help_confirm], Source={x:Static lg:LanguageService.Instance}, FallbackValue=确定}" 
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- 温压计更新遮罩层 -->
        <Border Grid.ColumnSpan="3"
                Panel.ZIndex="1000"
                Background="#80000000"
                Visibility="{Binding IsUpdateOverlayVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White"
                    CornerRadius="12"
                    Width="420"
                    Padding="36,28"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#333"
                               HorizontalAlignment="Center"
                               LineHeight="24"
                               Padding="0,2"
                               Margin="0,0,0,16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding [geo_msg_checking_update], Source={x:Static lg:LanguageService.Instance}, FallbackValue=Checking for updates...}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUpdateProgressIndeterminate}" Value="False">
                                        <Setter Property="Text" Value="{Binding [geo_msg_downloading_update], Source={x:Static lg:LanguageService.Instance}, FallbackValue=Downloading...}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Grid Margin="0,0,0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="{Binding UpdateStatusText}"
                                       FontSize="13"
                                       Foreground="#666"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       LineHeight="18"
                                       Padding="0,2"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock FontSize="12"
                                       Foreground="#888"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Padding="0,2"
                                       LineHeight="16"
                                       Text="{Binding UpdateProgress, StringFormat={}{0:0}%}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUpdateProgressIndeterminate}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <ProgressBar Grid.Row="1"
                                       Style="{StaticResource FlatProgressBarStyle}"
                                       Maximum="100"
                                       Value="{Binding UpdateProgress}"
                                       IsIndeterminate="{Binding IsUpdateProgressIndeterminate}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
