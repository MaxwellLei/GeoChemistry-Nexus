<Page x:Class="GeoChemistryNexus.Views.DataPreprocessingPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:rg="clr-namespace:unvell.ReoGrid;assembly=unvell.ReoGrid"
      xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
      mc:Ignorable="d"
      d:DesignHeight="950"
      d:DesignWidth="1500"
      Title="DataPreprocessingPageView"
      Background="#F4F7FB">
    <Page.Resources>
        <Style x:Key="DataPrepRibbonSectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0,16,6"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="False">
                    <Setter Property="Opacity" Value="0.82"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataPrepRibbonContentStyle" TargetType="Grid">
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.58"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataPrepRibbonGroupTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,8,10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding [dataPreprocessing],Source={x:Static lg:LanguageService.Instance}, FallbackValue=数据预处理}"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           VerticalAlignment="Center"/>

                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <Button Style="{StaticResource RibbonSmallButton}" Margin="0,0,6,0"
                            Command="{Binding LoadSampleDataCommand}"
                            CommandParameter="{Binding ElementName=DataPrepGrid}">
                        <TextBlock Text="{Binding [demoData],Source={x:Static lg:LanguageService.Instance}, FallbackValue=示例数据}"/>
                    </Button>
                    <Button Style="{StaticResource RibbonSmallButton}" Margin="0,0,6,0"
                            Command="{Binding ClearTemplateTableCommand}"
                            CommandParameter="{Binding ElementName=DataPrepGrid}">
                        <TextBlock Text="{Binding [clearTemplateTable],Source={x:Static lg:LanguageService.Instance}, FallbackValue=清除模板表}"/>
                    </Button>
                    <Button Style="{StaticResource RibbonSmallButton}" Margin="0,0,6,0"
                            Command="{Binding StartProcessingCommand}"
                            CommandParameter="{Binding ElementName=DataPrepGrid}">
                        <TextBlock Text="{Binding [runProcessing],Source={x:Static lg:LanguageService.Instance}, FallbackValue=执行处理}"/>
                    </Button>
                    <Button Style="{StaticResource RibbonSmallButton}"
                            Command="{Binding ExportWorksheetCommand}"
                            CommandParameter="{Binding ElementName=DataPrepGrid}">
                        <TextBlock Text="{Binding [dataPrep_exportCurrentTable],Source={x:Static lg:LanguageService.Instance}, FallbackValue=导出当前表}"/>
                    </Button>
                </WrapPanel>
            </Grid>

            <Border Grid.Row="0" VerticalAlignment="Bottom" BorderBrush="#E5EAF2" BorderThickness="0,0,0,1"/>

            <Grid Grid.Row="1" Margin="10,6,10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DataPrepRibbonSectionBorderStyle}"
                        Tag="{Binding IncludeAnhydrousNormalization}"
                        Margin="0,0,14,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False">
                            <TextBlock Text="{Binding [dataPrep_enable],Source={x:Static lg:LanguageService.Instance}, FallbackValue=启用}" Foreground="#64748B" VerticalAlignment="Center"/>
                            <ToggleButton DockPanel.Dock="Right"
                                          Style="{StaticResource ToggleButtonSwitch}"
                                          IsChecked="{Binding IncludeAnhydrousNormalization}"/>
                        </DockPanel>

                        <Grid Grid.Row="1"
                              Style="{StaticResource DataPrepRibbonContentStyle}"
                              IsEnabled="{Binding IncludeAnhydrousNormalization}"
                              Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding [dataPrep_parameterOptions],Source={x:Static lg:LanguageService.Instance}, FallbackValue=参数选项}" Foreground="#334155" Margin="0,0,0,4"/>
                            <WrapPanel Grid.Row="1">
                                <CheckBox Content="{Binding [dataPrep_excludeVolatiles],Source={x:Static lg:LanguageService.Instance}, FallbackValue=扣除挥发份}" IsChecked="{Binding ExcludeVolatiles}" Margin="0,0,12,0"/>
                                <CheckBox Content="{Binding [dataPrep_normalizeToHundred],Source={x:Static lg:LanguageService.Instance}, FallbackValue=归一到 100%}" IsChecked="{Binding NormalizeToHundred}"/>
                            </WrapPanel>
                        </Grid>

                        <TextBlock Grid.Row="2" Text="{Binding [dataPrep_normalization],Source={x:Static lg:LanguageService.Instance}, FallbackValue=归一化}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataPrepRibbonGroupTitleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IncludeAnhydrousNormalization}" Value="False">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
                <Border Grid.Column="0" HorizontalAlignment="Right" Width="1" Margin="0,8,6,10" Background="#E5EAF2"/>

                <Border Grid.Column="1"
                        Style="{StaticResource DataPrepRibbonSectionBorderStyle}"
                        Tag="{Binding IncludeIronValenceEstimation}"
                        Margin="0,0,14,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False">
                            <TextBlock Text="{Binding [dataPrep_enable],Source={x:Static lg:LanguageService.Instance}, FallbackValue=启用}" Foreground="#64748B" VerticalAlignment="Center"/>
                            <ToggleButton DockPanel.Dock="Right"
                                          Style="{StaticResource ToggleButtonSwitch}"
                                          IsChecked="{Binding IncludeIronValenceEstimation}"/>
                        </DockPanel>

                        <Grid Grid.Row="1"
                              Style="{StaticResource DataPrepRibbonContentStyle}"
                              IsEnabled="{Binding IncludeIronValenceEstimation}"
                              Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="82"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding [dataPrep_method],Source={x:Static lg:LanguageService.Instance}, FallbackValue=方法}" Foreground="#334155" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding IronValenceMethods}" DisplayMemberPath="Display" SelectedValuePath="Value" SelectedValue="{Binding SelectedIronValenceMethod}" Height="28" Margin="0,0,8,0"/>
                            <TextBox Grid.Row="0"
                                     Grid.Column="2"
                                     Text="{Binding Fe3Fraction, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                     Height="28"
                                     VerticalContentAlignment="Center"
                                     ToolTip="{Binding [dataPrep_fe3Tooltip],Source={x:Static lg:LanguageService.Instance}, FallbackValue=仅用于“使用经验比例校正”，表示 Fe3+/Fe 的经验比例}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedIronValenceMethod}" Value="iron_valence_empirical_ratio">
                                                <Setter Property="IsEnabled" Value="True"/>
                                                <Setter Property="Background" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <CheckBox Grid.Row="1" Grid.ColumnSpan="3" Content="{Binding [dataPrep_autoBackfillIronOxides],Source={x:Static lg:LanguageService.Instance}, FallbackValue=缺失时自动回填 FeO / Fe2O3}" IsChecked="{Binding AutoBackfillIronOxides}" Margin="0,6,0,0"/>
                        </Grid>

                        <TextBlock Grid.Row="2" Text="{Binding [dataPrep_ironValence],Source={x:Static lg:LanguageService.Instance}, FallbackValue=铁价态}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataPrepRibbonGroupTitleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IncludeIronValenceEstimation}" Value="False">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
                <Border Grid.Column="1" HorizontalAlignment="Right" Width="1" Margin="0,8,6,10" Background="#E5EAF2"/>

                <Border Grid.Column="2"
                        Style="{StaticResource DataPrepRibbonSectionBorderStyle}"
                        Tag="{Binding IncludeGeochemicalIndexCalculation}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False">
                            <TextBlock Text="{Binding [dataPrep_enable],Source={x:Static lg:LanguageService.Instance}, FallbackValue=启用}" Foreground="#64748B" VerticalAlignment="Center"/>
                            <ToggleButton DockPanel.Dock="Right"
                                          Style="{StaticResource ToggleButtonSwitch}"
                                          IsChecked="{Binding IncludeGeochemicalIndexCalculation}"/>
                        </DockPanel>

                        <Grid Grid.Row="1"
                              Style="{StaticResource DataPrepRibbonContentStyle}"
                              IsEnabled="{Binding IncludeGeochemicalIndexCalculation}"
                              Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding [dataPrep_calculationItems],Source={x:Static lg:LanguageService.Instance}, FallbackValue=计算项目}" Foreground="#334155" Margin="0,0,0,4"/>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Content="Mg#" IsChecked="{Binding CalculateMgNumber}" Margin="0,0,10,0"/>
                                <CheckBox Grid.Column="1" Content="A/CNK" IsChecked="{Binding CalculateACNK}" Margin="0,0,10,0"/>
                                <CheckBox Grid.Column="2" Content="A/NK" IsChecked="{Binding CalculateANK}"/>
                            </Grid>
                        </Grid>

                        <TextBlock Grid.Row="2" Text="{Binding [dataPrep_indices],Source={x:Static lg:LanguageService.Instance}, FallbackValue=指标}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource DataPrepRibbonGroupTitleStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IncludeGeochemicalIndexCalculation}" Value="False">
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E5EAF2" BorderThickness="0,1,0,1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="720"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#E2E8F0" CornerRadius="4" Padding="10,4" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedCellAddress}" FontWeight="SemiBold" Foreground="#0F172A"/>
                    </Border>

                    <TextBox Grid.Column="1"
                             Text="{Binding SelectedCellContent, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsSelectedCellEditable}"
                             Height="30"
                             VerticalContentAlignment="Center"
                             ToolTip="{Binding SelectedCellDisplayText}"/>
                </Grid>

            </Grid>
        </Border>

        <Grid Grid.Row="2" Background="White">
            <rg:ReoGridControl x:Name="DataPrepGrid"
                               SheetTabVisible="False"
                               ScrollViewer.HorizontalScrollBarVisibility="Auto"
                               ScrollViewer.VerticalScrollBarVisibility="Auto">
                <rg:ReoGridControl.Resources>
                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ScrollBarBaseStyle}"/>
                </rg:ReoGridControl.Resources>
            </rg:ReoGridControl>
        </Grid>
    </Grid>
</Page>
