<Window x:Class="GeoChemistryNexus.Views.CipwHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
        Title="{Binding [cipw_help_window_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='CIPW 标准矿物计算 - 算法说明'}"
        Height="680" Width="750"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#FAFBFC">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题区 -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="24,16">
            <StackPanel>
                <TextBlock Text="{Binding [cipw_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='CIPW 标准矿物计算'}" FontSize="20" FontWeight="SemiBold" Foreground="#333"/>
                <TextBlock Text="Cross-Iddings-Pirsson-Washington Norm Calculation" 
                           FontSize="12" Foreground="#888" Margin="0,4,0,0" FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- 内容区 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>
                <!-- 概述 -->
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#444" LineHeight="22" Margin="0,0,0,16"
                           Text="{Binding [cipw_overview],Source={x:Static lg:LanguageService.Instance}, FallbackValue='CIPW标准矿物计算（又称CIPW Norm）是由Cross、Iddings、Pirsson和Washington四位岩石学家于1902年提出的一种岩石化学计算方法。该方法根据全岩主量元素氧化物的化学分析数据，按照固定的优先顺序将氧化物分配到一组理想化的标准矿物中，用于岩石分类和对比研究。'}"/>

                <!-- 步骤1 -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0078D4" CornerRadius="12" Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock Text="1" Foreground="White" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding [cipw_step1_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='数据预处理与归一化'}" FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#555" LineHeight="20" Margin="34,0,0,0"
                                   Text="{Binding [cipw_step1_detail],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Border>

                <!-- 步骤2 -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0078D4" CornerRadius="12" Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock Text="2" Foreground="White" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding [cipw_step2_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='形成挥发分矿物'}" FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#555" LineHeight="20" Margin="34,0,0,0"
                                   Text="{Binding [cipw_step2_detail],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Border>

                <!-- 步骤3 -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0078D4" CornerRadius="12" Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock Text="3" Foreground="White" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding [cipw_step3_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='形成副矿物'}" FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#555" LineHeight="20" Margin="34,0,0,0"
                                   Text="{Binding [cipw_step3_detail],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Border>

                <!-- 步骤4 -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0078D4" CornerRadius="12" Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock Text="4" Foreground="White" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding [cipw_step4_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='判断铝饱和状态'}" FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#555" LineHeight="20" Margin="34,0,0,0"
                                   Text="{Binding [cipw_step4_detail],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Border>

                <!-- 步骤5 -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0078D4" CornerRadius="12" Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock Text="5" Foreground="White" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding [cipw_step5_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='形成长石和碱金属硅酸盐'}" FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#555" LineHeight="20" Margin="34,0,0,0"
                                   Text="{Binding [cipw_step5_detail],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Border>

                <!-- 步骤6 -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0078D4" CornerRadius="12" Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock Text="6" Foreground="White" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding [cipw_step6_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='形成铁氧化物'}" FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#555" LineHeight="20" Margin="34,0,0,0"
                                   Text="{Binding [cipw_step6_detail],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Border>

                <!-- 步骤7 -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0078D4" CornerRadius="12" Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock Text="7" Foreground="White" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding [cipw_step7_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='形成暗色硅酸盐矿物'}" FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#555" LineHeight="20" Margin="34,0,0,0"
                                   Text="{Binding [cipw_step7_detail],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Border>

                <!-- 步骤8 -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0078D4" CornerRadius="12" Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock Text="8" Foreground="White" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding [cipw_step8_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='硅饱和度校正'}" FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#555" LineHeight="20" Margin="34,0,0,0"
                                   Text="{Binding [cipw_step8_detail],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Border>

                <!-- 步骤9 -->
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0078D4" CornerRadius="12" Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock Text="9" Foreground="White" FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding [cipw_step9_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='结果输出'}" FontSize="14" FontWeight="SemiBold" Foreground="#333" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#555" LineHeight="20" Margin="34,0,0,0"
                                   Text="{Binding [cipw_step9_detail],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Border>

                <!-- 参考文献 -->
                <Border Background="#F0F4FF" CornerRadius="6" Padding="16" Margin="0,8,0,0"
                        BorderBrush="#D0DCFF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{Binding [cipw_references_title],Source={x:Static lg:LanguageService.Instance}, FallbackValue='参考文献'}" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#555" LineHeight="20"
                                   Text="{Binding [cipw_references_content],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮区 -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="24,12">
            <Button Content="{Binding [cipw_btn_close],Source={x:Static lg:LanguageService.Instance}, FallbackValue=关闭}" HorizontalAlignment="Right" Width="80" Height="30"
                    Click="OnCloseClick" IsCancel="True"
                    Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="1"
                    FontSize="13" Cursor="Hand"/>
        </Border>
    </Grid>
</Window>
