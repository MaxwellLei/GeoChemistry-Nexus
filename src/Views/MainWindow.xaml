<Window x:Class="GeoChemistryNexus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GeoChemistryNexus"
        xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
        xmlns:services="clr-namespace:GeoChemistryNexus.Services"
        xmlns:controls="clr-namespace:GeoChemistryNexus.Controls"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:converter="clr-namespace:GeoChemistryNexus.Converter"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"
        WindowStartupLocation="Manual" Loaded="Window_Loaded" Closing="Window_Closing" SourceInitialized="Window_SourceInitialized"
        Title="{Binding Title}" Height="760" Width="1360" BorderThickness="0">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="15" GlassFrameThickness="1"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <converter:BorderClipConverter x:Key="BorderClipConverter"/>

        <!-- 现代化风格侧边栏按钮 -->
        <Style x:Key="ModernSideButton" TargetType="{x:Type RadioButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A4A4A"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="border" CornerRadius="8" SnapsToDevicePixels="True">
                            <Border.Background>
                                <SolidColorBrush x:Name="borderBrush" Color="Transparent"/>
                            </Border.Background>
                            <Grid>
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 未选中时的悬停动画 -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.EnterActions>
                                    <StopStoryboard BeginStoryboardName="HoverExit"/>
                                    <StopStoryboard BeginStoryboardName="CheckedEnter"/>
                                    <StopStoryboard BeginStoryboardName="CheckedExit"/>
                                    <BeginStoryboard x:Name="HoverEnter">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="borderBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#E5E5EA" Duration="0:0:0.15">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.EnterActions>
                                <MultiTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="HoverEnter"/>
                                    <BeginStoryboard x:Name="HoverExit">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="borderBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="Transparent" Duration="0:0:0.2">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.ExitActions>
                            </MultiTrigger>
                            <!-- 选中状态动画 -->
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <StopStoryboard BeginStoryboardName="HoverEnter"/>
                                    <StopStoryboard BeginStoryboardName="HoverExit"/>
                                    <StopStoryboard BeginStoryboardName="CheckedExit"/>
                                    <BeginStoryboard x:Name="CheckedEnter">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="borderBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#007AFF" Duration="0:0:0.25">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="CheckedEnter"/>
                                    <StopStoryboard BeginStoryboardName="HoverEnter"/>
                                    <StopStoryboard BeginStoryboardName="HoverExit"/>
                                    <BeginStoryboard x:Name="CheckedExit">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="borderBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="Transparent" Duration="0:0:0.2">
                                                <ColorAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarNavButton" TargetType="{x:Type RadioButton}" BasedOn="{StaticResource ModernSideButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSideBarNavCentered}" Value="True">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarNavIconStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="pack://application:,,,/GeoChemistryNexus;component/Data/Icon/#iconfont"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SidebarLabelTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSideBarInIconMode}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="SidebarLabelFadeOut">
                            <Storyboard>
                                <!-- 先随边栏宽度裁切收缩，末段再淡出文字 -->
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.14"
                                                 BeginTime="0:0:0.14">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="SidebarLabelFadeOut"/>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.2"
                                                 BeginTime="0:0:0.1">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSideBarNavCentered}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarNavItemPanelStyle" TargetType="{x:Type StackPanel}">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSideBarNavCentered}" Value="True">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Window Control Button Style (Dark Text) -->
        <Style x:Key="ModernWinBtn" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="pack://application:,,,/GeoChemistryNexus;component/Data/Icon/#iconfont"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E5E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernCloseBtn" TargetType="{x:Type Button}">
             <Setter Property="Background" Value="Transparent"/>
             <Setter Property="Foreground" Value="#333"/>
             <Setter Property="FontSize" Value="14"/>
             <Setter Property="FontFamily" Value="pack://application:,,,/GeoChemistryNexus;component/Data/Icon/#iconfont"/>
             <Setter Property="Width" Value="46"/>
             <Setter Property="Height" Value="40"/>
             <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
             <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borderClose" Background="{TemplateBinding Background}" SnapsToDevicePixels="True" CornerRadius="0,10,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <!-- 最大化时去除圆角 -->
                            <DataTrigger Binding="{Binding IsWindowMaximized}" Value="True">
                                <Setter TargetName="borderClose" Property="CornerRadius" Value="0"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
             </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Container with Rounded Corners and Shadow Simulation -->
    <Border>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#F5F5F7"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="BorderBrush" Value="#D1D1D1"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="15"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsWindowMaximized}" Value="True">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="CornerRadius" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Effect" Value="{x:Null}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Height="40">
                <!-- Drag Handle -->
                <Border Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                </Border>

                <!-- Content -->
                <Grid>
                    <!-- Left: Hamburger Menu & Title -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0">
                        <!-- Hamburger Menu Button -->
                        <Button Command="{Binding ToggleSideBarCommand}" Background="Transparent" BorderThickness="0" 
                                WindowChrome.IsHitTestVisibleInChrome="True" Cursor="Hand" Margin="0,0,15,0">
                            <Path Data="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z" Fill="#333" Stretch="Uniform" Width="18" Height="14"/>
                        </Button>
                        
                        <!-- App Title -->
                        <TextBlock Text="GeoChemistry Nexus" Foreground="#333" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: Window Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button Content="&#xe622;" Style="{StaticResource ModernWinBtn}" Command="{Binding HelpCommand}" ToolTip="{Binding [view_help_docs],Source={x:Static lg:LanguageService.Instance}, FallbackValue=帮助手册}"/>
                        <Border Width="1" Height="16" Background="#D0D0D0" VerticalAlignment="Center" Margin="0,0,2,0"/>
                        <Button Content="&#xe67a;" Style="{StaticResource ModernWinBtn}" Command="{Binding MinimizeWindowCommand}" 
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="{Binding [minimize],Source={x:Static lg:LanguageService.Instance}}"/>
                        <Button x:Name="MaximizeButton" Content="&#xf2b2;" Style="{StaticResource ModernWinBtn}" Command="{Binding MaximizeWindowCommand}" 
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="{Binding [maximize],Source={x:Static lg:LanguageService.Instance}}"/>
                        <Button Content="&#xeaf2;" Style="{StaticResource ModernCloseBtn}" Command="{Binding CloseWindowCommand}" 
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                ToolTip="{Binding [close],Source={x:Static lg:LanguageService.Instance}}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 现代化可折叠侧边栏 -->
                <Border Background="#F0F0F5" CornerRadius="0,12,0,10" ClipToBounds="True">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Width" Value="240"/>
                            <Setter Property="Margin" Value="0,0,15,0"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSideBarVisible}" Value="False"/>
                                        <Condition Binding="{Binding UseIconOnlySidebarCollapse}" Value="False"/>
                                        <Condition Binding="{Binding SidebarCollapseModeTransition}" Value="1"/>
                                    </MultiDataTrigger.Conditions>
                                    <MultiDataTrigger.EnterActions>
                                        <StopStoryboard BeginStoryboardName="SidebarIconCollapse"/>
                                        <StopStoryboard BeginStoryboardName="SidebarExpand"/>
                                        <BeginStoryboard x:Name="SidebarIconToHiddenCollapse">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                 From="68" To="0" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                    From="0,0,15,0" To="0" Duration="0:0:0.3">
                                                    <ThicknessAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut"/>
                                                    </ThicknessAnimation.EasingFunction>
                                                </ThicknessAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.EnterActions>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSideBarVisible}" Value="False"/>
                                        <Condition Binding="{Binding UseIconOnlySidebarCollapse}" Value="True"/>
                                        <Condition Binding="{Binding SidebarCollapseModeTransition}" Value="2"/>
                                    </MultiDataTrigger.Conditions>
                                    <MultiDataTrigger.EnterActions>
                                        <StopStoryboard BeginStoryboardName="SidebarFullCollapse"/>
                                        <StopStoryboard BeginStoryboardName="SidebarExpand"/>
                                        <BeginStoryboard x:Name="SidebarHiddenToIconExpand">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                 From="0" To="68" Duration="0:0:0.28">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                    From="0" To="0,0,15,0" Duration="0:0:0.28">
                                                    <ThicknessAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut"/>
                                                    </ThicknessAnimation.EasingFunction>
                                                </ThicknessAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.EnterActions>
                                </MultiDataTrigger>
                                <!-- 全部收起动画 -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSideBarVisible}" Value="False"/>
                                        <Condition Binding="{Binding UseIconOnlySidebarCollapse}" Value="False"/>
                                        <Condition Binding="{Binding SidebarCollapseModeTransition}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <MultiDataTrigger.EnterActions>
                                        <StopStoryboard BeginStoryboardName="SidebarHiddenToIconExpand"/>
                                        <StopStoryboard BeginStoryboardName="SidebarIconCollapse"/>
                                        <StopStoryboard BeginStoryboardName="SidebarExpand"/>
                                        <BeginStoryboard x:Name="SidebarFullCollapse">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                 To="0" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                    To="0" Duration="0:0:0.3">
                                                    <ThicknessAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut"/>
                                                    </ThicknessAnimation.EasingFunction>
                                                </ThicknessAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.EnterActions>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSideBarVisible}" Value="False"/>
                                        <Condition Binding="{Binding UseIconOnlySidebarCollapse}" Value="True"/>
                                        <Condition Binding="{Binding SidebarCollapseModeTransition}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <MultiDataTrigger.EnterActions>
                                        <StopStoryboard BeginStoryboardName="SidebarIconToHiddenCollapse"/>
                                        <StopStoryboard BeginStoryboardName="SidebarFullCollapse"/>
                                        <StopStoryboard BeginStoryboardName="SidebarExpand"/>
                                        <BeginStoryboard x:Name="SidebarIconCollapse">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                 To="68" Duration="0:0:0.28">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                    To="0,0,15,0" Duration="0:0:0.28">
                                                    <ThicknessAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut"/>
                                                    </ThicknessAnimation.EasingFunction>
                                                </ThicknessAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.EnterActions>
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding IsSideBarVisible}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <StopStoryboard BeginStoryboardName="SidebarIconToHiddenCollapse"/>
                                        <StopStoryboard BeginStoryboardName="SidebarHiddenToIconExpand"/>
                                        <StopStoryboard BeginStoryboardName="SidebarFullCollapse"/>
                                        <StopStoryboard BeginStoryboardName="SidebarIconCollapse"/>
                                        <BeginStoryboard x:Name="SidebarExpand">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                 To="240" Duration="0:0:0.32">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                    To="0,0,15,0" Duration="0:0:0.32">
                                                    <ThicknessAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </ThicknessAnimation.EasingFunction>
                                                </ThicknessAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <!-- 侧边栏内容（带淡入淡出动画） -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSideBarVisible}" Value="False"/>
                                            <Condition Binding="{Binding UseIconOnlySidebarCollapse}" Value="False"/>
                                            <Condition Binding="{Binding SidebarCollapseModeTransition}" Value="1"/>
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.EnterActions>
                                            <StopStoryboard BeginStoryboardName="ContentIconModeFadeIn"/>
                                            <BeginStoryboard x:Name="ContentIconToHiddenFadeOut">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiDataTrigger.EnterActions>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSideBarVisible}" Value="False"/>
                                            <Condition Binding="{Binding UseIconOnlySidebarCollapse}" Value="True"/>
                                            <Condition Binding="{Binding SidebarCollapseModeTransition}" Value="2"/>
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.EnterActions>
                                            <StopStoryboard BeginStoryboardName="ContentFadeOut"/>
                                            <BeginStoryboard x:Name="ContentHiddenToIconFadeIn">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1" Duration="0:0:0.12">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiDataTrigger.EnterActions>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSideBarVisible}" Value="False"/>
                                            <Condition Binding="{Binding UseIconOnlySidebarCollapse}" Value="False"/>
                                            <Condition Binding="{Binding SidebarCollapseModeTransition}" Value="0"/>
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.EnterActions>
                                            <StopStoryboard BeginStoryboardName="ContentHiddenToIconFadeIn"/>
                                            <BeginStoryboard x:Name="ContentFadeOut">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiDataTrigger.EnterActions>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSideBarVisible}" Value="False"/>
                                            <Condition Binding="{Binding UseIconOnlySidebarCollapse}" Value="True"/>
                                            <Condition Binding="{Binding SidebarCollapseModeTransition}" Value="0"/>
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.EnterActions>
                                            <StopStoryboard BeginStoryboardName="ContentIconToHiddenFadeOut"/>
                                            <StopStoryboard BeginStoryboardName="ContentFadeOut"/>
                                            <BeginStoryboard x:Name="ContentIconModeFadeIn">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.12">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiDataTrigger.EnterActions>
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding IsSideBarVisible}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <StopStoryboard BeginStoryboardName="ContentIconToHiddenFadeOut"/>
                                            <StopStoryboard BeginStoryboardName="ContentHiddenToIconFadeIn"/>
                                            <StopStoryboard BeginStoryboardName="ContentFadeOut"/>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     To="1" Duration="0:0:0.2"
                                                                     BeginTime="0:0:0.08">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <StackPanel Margin="0,20,0,0" VerticalAlignment="Top">
                            <!-- Home -->
                            <RadioButton Name="RadioButton1" Style="{StaticResource SidebarNavButton}" GroupName="SideBar" 
                                         Command="{Binding StartPageCommand}" CommandParameter="{Binding ElementName=MyNav}" IsChecked="True"
                                         ToolTip="{Binding [home],Source={x:Static lg:LanguageService.Instance}}">
                                <StackPanel Style="{StaticResource SidebarNavItemPanelStyle}">
                                    <TextBlock Text="&#xe635;" Style="{StaticResource SidebarNavIconStyle}"/>
                                    <TextBlock Text="{Binding [home],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource SidebarLabelTextStyle}"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- Data Preprocessing -->
                            <RadioButton Name="RadioButtonPreprocessing" Style="{StaticResource SidebarNavButton}" GroupName="SideBar"
                                         Command="{Binding DataPreprocessingPageCommand}" CommandParameter="{Binding ElementName=MyNav}"
                                         ToolTip="{Binding [dataPreprocessing],Source={x:Static lg:LanguageService.Instance}}">
                                <StackPanel Style="{StaticResource SidebarNavItemPanelStyle}">
                                    <TextBlock Text="&#xe865;" Style="{StaticResource SidebarNavIconStyle}"/>
                                    <TextBlock Text="{Binding [dataPreprocessing],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource SidebarLabelTextStyle}"/>
                                </StackPanel>
                            </RadioButton>
                            
                            <!-- Plot -->
                            <RadioButton Name="RadioButton2" Style="{StaticResource SidebarNavButton}" GroupName="SideBar" 
                                         Command="{Binding HomePageCommand}" CommandParameter="{Binding ElementName=MyNav}"
                                         ToolTip="{Binding [Plot],Source={x:Static lg:LanguageService.Instance}}">
                                <StackPanel Style="{StaticResource SidebarNavItemPanelStyle}">
                                    <TextBlock Text="&#xe639;" Style="{StaticResource SidebarNavIconStyle}"/>
                                    <TextBlock Text="{Binding [Plot],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource SidebarLabelTextStyle}"/>
                                </StackPanel>
                            </RadioButton>
                            
                            <!-- Geothermometer -->
                            <RadioButton Name="RadioButton3" Style="{StaticResource SidebarNavButton}" GroupName="SideBar" 
                                         Command="{Binding GTMNewPageCommand}" CommandParameter="{Binding ElementName=MyNav}"
                                         ToolTip="{Binding [Geothermometer],Source={x:Static lg:LanguageService.Instance}}">
                                <StackPanel Style="{StaticResource SidebarNavItemPanelStyle}">
                                    <TextBlock Text="&#xe716;" Style="{StaticResource SidebarNavIconStyle}"/>
                                    <TextBlock Text="{Binding [Geothermometer],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource SidebarLabelTextStyle}"/>
                                </StackPanel>
                            </RadioButton>

                            <!-- CIPW -->
                            <RadioButton Name="RadioButton5" Style="{StaticResource SidebarNavButton}" GroupName="SideBar" 
                                         Command="{Binding CipwPageCommand}" CommandParameter="{Binding ElementName=MyNav}"
                                         ToolTip="CIPW">
                                <StackPanel Style="{StaticResource SidebarNavItemPanelStyle}">
                                    <TextBlock Text="&#xe626;" Style="{StaticResource SidebarNavIconStyle}" FontWeight="Bold"/>
                                    <TextBlock Text="CIPW" Style="{StaticResource SidebarLabelTextStyle}"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>

                        <!-- Settings at the bottom -->
                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,20">
                            <RadioButton Name="RadioButton4" Style="{StaticResource SidebarNavButton}" GroupName="SideBar" 
                                         Command="{Binding SettingPageCommand}" CommandParameter="{Binding ElementName=MyNav}"
                                         ToolTip="{Binding [Setting],Source={x:Static lg:LanguageService.Instance}}">
                                <StackPanel Style="{StaticResource SidebarNavItemPanelStyle}">
                                    <TextBlock Text="&#xe60f;" Style="{StaticResource SidebarNavIconStyle}"/>
                                    <TextBlock Text="{Binding [Setting],Source={x:Static lg:LanguageService.Instance}}" Style="{StaticResource SidebarLabelTextStyle}"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Navigation Content -->
                <Border x:Name="NavContentBorder" Grid.Column="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="0,0,10,10"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasVisibleSideBarSurface}" Value="True">
                                    <Setter Property="CornerRadius" Value="0,0,10,0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsWindowMaximized}" Value="True">
                                    <Setter Property="CornerRadius" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.Clip>
                        <MultiBinding Converter="{StaticResource BorderClipConverter}">
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}"/>
                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}"/>
                            <Binding Path="CornerRadius" RelativeSource="{RelativeSource Self}"/>
                        </MultiBinding>
                    </Border.Clip>
                    <Frame Name="MyNav" NavigationUIVisibility="Hidden" Background="White"/>
                </Border>
            </Grid>
            
            <!-- Modal Mask -->
            <Border Grid.Row="1" Background="#40000000" 
                    Visibility="{Binding IsModal, Source={x:Static services:NotificationManager.Instance}, Converter={StaticResource BooleanToVisibilityConverter}}"
                    IsHitTestVisible="True"/>

            <!-- Notification Area -->
            <ScrollViewer Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,20,20,0"
                          MaxHeight="650" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly"
                          IsHitTestVisible="True" BorderThickness="0" Background="Transparent">
                <ItemsControl ItemsSource="{Binding Notifications, Source={x:Static services:NotificationManager.Instance}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel VerticalAlignment="Top"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:NotificationItem/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Notify Icon (Tray) -->
            <hc:NotifyIcon Name="notifyIcon" Text="GeoChemistry Nexus" IsBlink="False" Visibility="Visible" Icon="pack://application:,,,/GeoChemistryNexus;component/Data/Icon/logo.png">
                <hc:NotifyIcon.ContextMenu>
                    <ContextMenu Width="160" Placement="Right">
                        <MenuItem Header="{Binding [Show],Source={x:Static lg:LanguageService.Instance}}" Click="ShowWindow"/>
                        <Separator/>
                        <MenuItem Header="{Binding [Exit],Source={x:Static lg:LanguageService.Instance}}" Click="ShutDownWindow"/>
                    </ContextMenu>
                </hc:NotifyIcon.ContextMenu>
            </hc:NotifyIcon>

        </Grid>
    </Border>
</Window>

