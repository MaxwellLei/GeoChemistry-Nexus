<Window x:Class="GeoChemistryNexus.Views.NewTemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"       
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uc="clr-namespace:GeoChemistryNexus.Controls"
        xmlns:controls="clr-namespace:GeoChemistryNexus.Controls"
        xmlns:lg="clr-namespace:GeoChemistryNexus.Services"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="{Binding [new_template],Source={x:Static lg:LanguageService.Instance}}"
        Height="550" Width="800"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        Background="#F5F5F7">
    <Grid>
        <uc:NewTemplateControl x:Name="TemplateControl"
                               ConfirmCommand="{Binding ConfirmCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                               CancelCommand="{Binding CancelCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>

        <ScrollViewer VerticalAlignment="Top"
                      HorizontalAlignment="Right"
                      Margin="0,20,20,0"
                      MaxHeight="500"
                      VerticalScrollBarVisibility="Hidden"
                      PanningMode="VerticalOnly"
                      IsHitTestVisible="True"
                      BorderThickness="0"
                      Background="Transparent">
            <ItemsControl ItemsSource="{Binding ElementName=RootWindow, Path=LocalNotifications}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:NotificationItem/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
