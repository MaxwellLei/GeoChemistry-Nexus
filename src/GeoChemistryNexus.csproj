<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Data\Icon\logo.ico</ApplicationIcon>
	<!--软件版本号-->
    <AssemblyVersion>0.6.1</AssemblyVersion>
	<!--图解格式版本号 x.y.z -->
    <FileVersion>1.2.0</FileVersion>
    <!--地质温压计格式版本号 x.y.z -->
    <GeothermometerFormatVersion>1.0.0</GeothermometerFormatVersion>
    <Copyright>Copyright ©️ 2024</Copyright>
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>GeothermometerFormatVersion</_Parameter1>
      <_Parameter2>$(GeothermometerFormatVersion)</_Parameter2>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <None Remove="Data\Documents\template.rtf" />
    <None Remove="Data\Icon\iconfont.ttf" />
    <None Remove="Data\Icon\logo.png" />
    <None Remove="Data\Image\StartPic\1.jpg" />
    <None Remove="Data\Image\StartPic\2.jpg" />
    <None Remove="Data\Image\StartPic\3.jpg" />
    <None Remove="Data\Image\StartPic\4.jpg" />
    <None Remove="Data\PlotData\PlotTemplateCategories.json" />
    <None Remove="Data\Plugins\GeoTMineralCategories.json" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Data\Documents\template.rtf">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Resource Include="Data\Icon\iconfont.ttf" />
    <Content Include="Data\Icon\logo.ico" />
    <Resource Include="Data\Icon\logo.png" />
    <Content Include="Data\Image\StartPic\1.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Data\Image\StartPic\2.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Data\Image\StartPic\3.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Data\Image\StartPic\4.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Data\PlotData\PlotTemplateCategories.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Data\Plugins\GeoTMineralCategories.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Data\Home\HomeLinksCatalog.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Tencent.QCloud.Cos.Sdk" Version="5.4.49" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.3.2" />
    <PackageReference Include="gong-wpf-dragdrop" Version="4.0.0" />
    <PackageReference Include="HandyControl" Version="3.6.0-rc3" />
    <PackageReference Include="Jint" Version="4.2.0" />
    <PackageReference Include="LiteDB" Version="5.0.21" />
    <PackageReference Include="Microsoft.Xaml.Behaviors.Wpf" Version="1.1.135" />
    <PackageReference Include="net6.ReoGridWPF.dll" Version="3.0.3" />
    <PackageReference Include="Ookii.Dialogs.Wpf" Version="5.0.1" />
    <PackageReference Include="ScottPlot.WPF" Version="5.0.56" />
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
    <PackageReference Include="VirtualizingWrapPanel" Version="2.3.2" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Data\Language\Language.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Language.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Data\Language\Language.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Language.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Others\**\*" />
    <Page Remove="Others\**\*" />
    <EmbeddedResource Remove="Others\**\*" />
    <None Remove="Others\**\*" />
    <Compile Remove="_build_out\**\*" />
    <Content Remove="_build_out\**\*" />
    <None Remove="_build_out\**\*" />
  </ItemGroup>

</Project>
